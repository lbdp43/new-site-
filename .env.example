# === WooCommerce Store API ===
# URL de base du site WordPress (sans slash final).
# Ex : https://www.labrasseriedesplantes.fr
PUBLIC_WC_BASE_URL=https://www.labrasseriedesplantes.fr

# === Stripe (via WooPayments) ===
# Clé publique Stripe (commence par pk_test_ ou pk_live_).
# Récupérable via l'endpoint /wp-json/wc/v3/payments/accounts (champ
# live_publishable_key ou test_publishable_key).
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ID du compte Stripe Connect utilisé par WooPayments. Indispensable pour que
# Stripe.js crée les PaymentMethod sur le bon compte marchand.
# Champ "account_id" renvoyé par /wp-json/wc/v3/payments/accounts.
PUBLIC_STRIPE_ACCOUNT_ID=acct_xxx

# === WooCommerce REST API (optionnel, pour le build SSG) ===
# Clés consumer/secret générées dans WooCommerce → Réglages → Avancé → API REST.
# Nécessaires si on décide de lire les produits depuis WooCommerce au build.
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
