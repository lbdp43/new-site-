---
import '../styles/global.css';
import { site } from '../data/site';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AgeGate from '../components/AgeGate.astro';
import MiniCartDrawer from '../components/cart/MiniCartDrawer';
import {
  getLangFromUrl,
  getOgLocale,
  getHtmlLang,
  getHreflangLinks,
  alternateLangPath,
  type Lang,
} from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  /** JSON-LD structured data (object or array of objects) injecté dans <head>. */
  schema?: Record<string, unknown> | Record<string, unknown>[];
  /** Type OpenGraph. Par défaut 'website'. Utiliser 'article' pour les blogs. */
  ogType?: 'website' | 'article' | 'product';
  /** Langue forcée (override de la détection par URL). Utile pour pages dynamiques. */
  lang?: Lang;
  /** Page avec hero scroll-expansion (home FR/EN). Quand true, le bandeau
   *  principal du header est caché tant qu'on n'a pas scrollé — pour laisser
   *  le hero respirer. Sur les autres pages, le header reste visible en
   *  permanence. */
  hasHero?: boolean;
  /** Image à précharger en priorité (candidat LCP). Typiquement le poster
   *  d'une vidéo hero ou la première image au-dessus de la ligne de flottaison.
   *  Génère un <link rel="preload" as="image" fetchpriority="high"> dans le head. */
  preloadImage?: string;
  /** Vidéo à précharger (en plus de son poster) — uniquement pour le hero
   *  critique above-the-fold. Génère un <link rel="preload" as="video">. */
  preloadVideo?: string;
}

const {
  title,
  description = site.defaultDescription,
  canonical,
  ogImage = site.defaultOgImage,
  noindex = false,
  schema,
  ogType = 'website',
  lang: langProp,
  hasHero = false,
  preloadImage,
  preloadVideo,
} = Astro.props;

// Détection de la langue — priorité à la prop, sinon détection par URL
const lang: Lang = langProp ?? getLangFromUrl(Astro.url);
const htmlLang = getHtmlLang(lang);
const ogLocale = getOgLocale(lang);

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site.url).toString();
const ogImageUrl = new URL(ogImage, site.url).toString();
const fullTitle = title.includes(site.name) ? title : `${title} | ${site.name}`;

// hreflang — getHreflangLinks gère maintenant les 4 langues nativement et
// recalcule le chemin FR canonique en interne. On lui passe directement la
// vraie langue source pour qu'il puisse générer les alternates EN/ES/IT
// correctement, y compris quand la page courante est /es/ ou /it/.
const alternates = getHreflangLinks(Astro.url.pathname, lang, site.url);

// og:locale:alternate — on déclare toutes les autres langues du site
// (et pas seulement EN), aligné avec hreflang.
const otherLocales: Lang[] = (['fr', 'en', 'es', 'it'] as Lang[]).filter((l) => l !== lang);
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex
      ? <meta name="robots" content="noindex, follow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    }

    <!-- hreflang — versions linguistiques alternatives -->
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    {otherLocales.map((l) => (
      <meta property="og:locale:alternate" content={getOgLocale(l)} />
    ))}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- LCP booster : préchargement du poster vidéo / image hero en haute priorité -->
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}
    {preloadVideo && (
      <link rel="preload" as="video" href={preloadVideo} type="video/mp4" />
    )}

    <!-- Fonts (locaux — déclarés dans global.css, WOFF2 avec fallback TTF) -->
    <link rel="preload" href="/fonts/Joane-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/BarlowCondensed-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/BarlowCondensed-Medium.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/SunshineScript.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/images/brand/logo-lbdp.webp" />

    <!--
      Preconnect — réduit le TTFB de la première requête vers chaque tiers.
      WC Store API : appelée dès que le panier s'hydrate (cart-store.tsx).
      Stripe : chargé sur /commande mais l'init handshake est long, on ouvre
      le canal en avance.
    -->
    <link rel="preconnect" href="https://www.labrasseriedesplantes.fr" crossorigin />
    <link rel="dns-prefetch" href="https://www.labrasseriedesplantes.fr" />
    <link rel="preconnect" href="https://js.stripe.com" crossorigin />
    <link rel="dns-prefetch" href="https://js.stripe.com" />

    <!--
      Speculation Rules API (Chrome 121+, Edge) — prerender les pages internes
      survolées plus de 200ms. Gain INP/FCP énorme sur le clic suivant. On
      exclut les pages transactionnelles (panier/commande/admin) et les ancres.
      Ignoré silencieusement par les navigateurs qui ne supportent pas.
    -->
    <script
      type="speculationrules"
      set:html={JSON.stringify({
        prerender: [
          {
            where: {
              and: [
                { href_matches: '/*' },
                { not: { href_matches: '/panier*' } },
                { not: { href_matches: '/commande*' } },
                { not: { href_matches: '/admin*' } },
                { not: { href_matches: '/*\\?*' } },
                { not: { selector_matches: '[rel~="external"]' } },
                { not: { selector_matches: '[rel~="nofollow"]' } },
              ],
            },
            eagerness: 'moderate',
          },
        ],
      })}
    />

    {schema && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
      />
    )}
  </head>
  <body class="min-h-screen flex flex-col" data-has-hero={hasHero ? 'true' : undefined}>
    <AgeGate />
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <!-- Mini-panier slide-in (overlay sur toutes les pages) -->
    <MiniCartDrawer client:idle />
  </body>
</html>
