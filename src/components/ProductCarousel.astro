---
import type { Product } from '../data/products';
import { GlowCard } from './ui/spotlight-card';

interface Props {
  items: Product[];
  heading?: string;
  kicker?: string;
  subtitle?: string;
  /** Thème : `light` (crème) ou `dark` (forest). */
  theme?: 'light' | 'dark';
  /** Vitesse d'autoplay en px/s (défaut 30 ≈ ancien Marquee 61s). */
  speed?: number;
  /** Inverser le sens de l'autoplay. */
  reverse?: boolean;
}

const {
  items,
  heading = 'Notre gamme',
  kicker = 'Toutes nos liqueurs',
  subtitle,
  theme = 'light',
  speed = 30,
  reverse = false,
} = Astro.props;

const bg = theme === 'dark' ? 'bg-forest-900 text-cream-100' : 'bg-white text-forest-900';
const accent = theme === 'dark' ? 'text-gold-400' : 'text-gold-600';
const muted = theme === 'dark' ? 'text-cream-200/70' : 'text-ink-500';
const fadeFrom = theme === 'dark' ? 'from-forest-900' : 'from-white';

// Dupliqué une fois pour la boucle infinie invisible (mêmes items affichés deux fois,
// scrollLeft est réinitialisé silencieusement quand on franchit la moitié de la piste).
const track = [...items, ...items];
---
<section class:list={['py-20 md:py-24 overflow-hidden relative', bg]}>
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-10 max-w-3xl mx-auto">
      <div class:list={['text-[10px] md:text-xs uppercase tracking-[0.35em] font-medium mb-3', accent]}>
        {kicker}
      </div>
      <h2 class="font-display text-4xl md:text-5xl leading-tight">{heading}</h2>
      {subtitle && <p class:list={['mt-4 max-w-2xl mx-auto leading-relaxed', muted]}>{subtitle}</p>}
      <div class="gold-divider mt-6"></div>
    </div>
  </div>

  <div class="relative w-full">
    <!-- Dégradés sur les bords (blend out) -->
    <div
      class:list={[
        'pointer-events-none absolute top-0 left-0 z-10 h-full w-24 md:w-40 bg-gradient-to-r to-transparent',
        fadeFrom,
      ]}
    ></div>
    <div
      class:list={[
        'pointer-events-none absolute top-0 right-0 z-10 h-full w-24 md:w-40 bg-gradient-to-l to-transparent',
        fadeFrom,
      ]}
    ></div>

    <!-- Boutons desktop prev/next -->
    <button
      type="button"
      data-slider-prev
      aria-label="Précédent"
      class:list={[
        'hidden md:flex absolute left-4 top-1/2 -translate-y-1/2 z-20 items-center justify-center w-11 h-11 rounded-full transition-all duration-200 hover:scale-105 active:scale-95 shadow-md',
        theme === 'dark'
          ? 'bg-cream-50/90 text-forest-900 hover:bg-cream-50'
          : 'bg-forest-900/90 text-cream-50 hover:bg-forest-900',
      ]}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button
      type="button"
      data-slider-next
      aria-label="Suivant"
      class:list={[
        'hidden md:flex absolute right-4 top-1/2 -translate-y-1/2 z-20 items-center justify-center w-11 h-11 rounded-full transition-all duration-200 hover:scale-105 active:scale-95 shadow-md',
        theme === 'dark'
          ? 'bg-cream-50/90 text-forest-900 hover:bg-cream-50'
          : 'bg-forest-900/90 text-cream-50 hover:bg-forest-900',
      ]}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    <div
      data-slider-track
      data-speed={speed}
      data-reverse={reverse ? 'true' : 'false'}
      class="product-slider flex overflow-x-auto gap-5 md:gap-6 py-4 px-6 md:px-10"
      style="scroll-behavior:auto;scrollbar-width:none;-ms-overflow-style:none;touch-action:pan-x pan-y;-webkit-overflow-scrolling:touch;overscroll-behavior-x:contain;"
    >
      {track.map((p, i) => {
        const isClone = i >= items.length;
        return (
          <a
            href={`/boutique/${p.slug}`}
            aria-hidden={isClone ? 'true' : undefined}
            tabindex={isClone ? -1 : undefined}
            class="product-slider-card flex-none w-[62vw] sm:w-[300px] md:w-[280px] lg:w-[260px] block transition-transform duration-300 hover:-translate-y-1 snap-start"
          >
            <GlowCard
              client:visible
              glowColor="gold"
              customSize
              padding="none"
              className={`!aspect-auto w-full overflow-hidden ${
                theme === 'dark'
                  ? 'bg-forest-800/40 border border-cream-100/10'
                  : 'bg-white border border-forest-100/60'
              }`}
            >
              <div class="aspect-[4/5] bg-white relative overflow-hidden">
                <img
                  src={p.image}
                  alt={`${p.name} — liqueur artisanale aux plantes d'Auvergne`}
                  class:list={[
                    'absolute inset-0 w-full h-full object-contain p-6 transition-all duration-500 ease-out',
                    p.image2 ? 'opacity-100 group-hover/card:opacity-0' : 'group-hover/card:scale-105',
                  ]}
                  loading="lazy"
                  draggable="false"
                />
                {p.image2 && (
                  <img
                    src={p.image2}
                    alt={`${p.name} — vue d'ambiance, mise en situation`}
                    class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover/card:opacity-100 transition-opacity duration-500 ease-out"
                    loading="lazy"
                    draggable="false"
                  />
                )}
                {p.highlight && (
                  <span class="absolute top-3 left-3 z-10 inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-gold-500 text-cream-50 text-[10px] font-medium uppercase tracking-wide shadow-sm">
                    <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
                    {p.highlight}
                  </span>
                )}
                {p.alcohol > 0 && (
                  <span class:list={[
                    'absolute top-3 right-3 z-10 text-[11px] font-medium px-2.5 py-1 rounded-full',
                    theme === 'dark' ? 'bg-cream-50/10 text-cream-50 border border-cream-100/20' : 'bg-forest-800/90 text-cream-50',
                  ]}>
                    {p.alcohol}°
                  </span>
                )}
              </div>
              <div class="p-5">
                <h3 class="font-display text-xl leading-tight mb-1.5">{p.name}</h3>
                <p class:list={['text-xs italic leading-relaxed line-clamp-2', muted]}>{p.tagline}</p>
                <div class:list={['mt-3 pt-3 border-t flex items-center justify-between text-xs',
                  theme === 'dark' ? 'border-cream-100/10' : 'border-forest-100'
                ]}>
                  <span class="font-medium text-gold-600">
                    {p.priceMin === p.priceMax ? `${p.priceMin} €` : `dès ${p.priceMin} €`}
                  </span>
                  <span class:list={['inline-flex items-center gap-1 group-hover:translate-x-0.5 transition-transform', accent]}>
                    Découvrir
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </span>
                </div>
              </div>
            </GlowCard>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style is:global>
  .product-slider::-webkit-scrollbar { display: none; }
</style>

<script>
  // Autoplay + swipe/drag natif + pause-on-interact, sans dépendance.
  // Piste dupliquée une fois : on incrémente scrollLeft en continu et on
  // soustrait silencieusement la moitié de la largeur quand on franchit le
  // point de boucle — l'utilisateur ne voit aucun saut.
  type SliderState = {
    paused: boolean;
    resumeTimer: number | null;
    lastTs: number;
  };

  const initSlider = (track: HTMLElement) => {
    const speed = Number(track.dataset.speed) || 30; // px/s
    const reverse = track.dataset.reverse === 'true';
    const dir = reverse ? -1 : 1;

    const state: SliderState = { paused: false, resumeTimer: null, lastTs: 0 };

    const halfWidth = () => track.scrollWidth / 2;

    // Démarre à 0 côté forward, à halfWidth côté reverse (pour pouvoir reculer)
    if (reverse) track.scrollLeft = halfWidth();

    const pauseFor = (ms: number) => {
      state.paused = true;
      if (state.resumeTimer) window.clearTimeout(state.resumeTimer);
      state.resumeTimer = window.setTimeout(() => {
        state.paused = false;
        state.resumeTimer = null;
      }, ms);
    };

    const holdPause = () => {
      state.paused = true;
      if (state.resumeTimer) {
        window.clearTimeout(state.resumeTimer);
        state.resumeTimer = null;
      }
    };

    track.addEventListener('mouseenter', holdPause);
    track.addEventListener('mouseleave', () => pauseFor(400));
    track.addEventListener('pointerdown', () => pauseFor(3500));
    track.addEventListener('touchstart', () => pauseFor(3500), { passive: true });
    track.addEventListener('wheel', () => pauseFor(2500), { passive: true });
    track.addEventListener('focusin', holdPause);
    track.addEventListener('focusout', () => pauseFor(600));

    // Invisible wrap-around : corrige scrollLeft quand on franchit la moitié.
    const normalize = () => {
      const half = halfWidth();
      if (half <= 0) return;
      if (track.scrollLeft >= half * 2 - 1) {
        track.scrollLeft -= half;
      } else if (track.scrollLeft <= 0) {
        track.scrollLeft += half;
      }
    };
    track.addEventListener('scroll', normalize, { passive: true });

    // Boucle autoplay basée sur requestAnimationFrame — continue, fluide.
    const tick = (ts: number) => {
      if (state.lastTs === 0) state.lastTs = ts;
      const dt = (ts - state.lastTs) / 1000;
      state.lastTs = ts;
      if (!state.paused) {
        track.scrollLeft += speed * dir * dt;
        normalize();
      }
      requestAnimationFrame(tick);
    };

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduced) requestAnimationFrame(tick);

    // Boutons prev/next desktop
    const root = track.closest('section');
    const cardStep = () => {
      const card = track.querySelector('.product-slider-card') as HTMLElement | null;
      if (!card) return 300;
      const style = getComputedStyle(track);
      const gap = parseFloat(style.columnGap || style.gap || '20') || 20;
      return card.offsetWidth + gap;
    };

    const goto = (delta: number) => {
      pauseFor(4500);
      track.scrollBy({ left: delta, behavior: 'smooth' });
    };

    root?.querySelector('[data-slider-prev]')?.addEventListener('click', () => {
      goto(-cardStep() * 1.5);
    });
    root?.querySelector('[data-slider-next]')?.addEventListener('click', () => {
      goto(cardStep() * 1.5);
    });
  };

  document.querySelectorAll<HTMLElement>('[data-slider-track]').forEach(initSlider);
</script>
