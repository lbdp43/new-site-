---
/**
 * GoogleReviewsEmbed — avis Google en temps réel via Featurable (gratuit)
 *
 * Fonctionnement :
 *  1. Si `featurableWidgetId` est renseigné dans `site.ts`, on fetche l'API
 *     Featurable (https://featurable.com/api/v1/widgets/{id}) au build pour
 *     récupérer la vraie note Google et les derniers avis. Zéro clé requise.
 *  2. Sinon, on affiche les avis internes (reviews.ts) + un CTA "Laisser un
 *     avis Google" pointant vers la fiche Maps.
 *
 * Le CTA "Voir sur Google" est toujours affiché pour booster le signal GBP.
 */
import { site } from '../data/site';
import { reviews, aggregateRating } from '../data/reviews';

interface FeaturableReview {
  reviewer: { displayName: string; profilePhotoUrl?: string };
  starRating: number;
  comment: string;
  createTime: string;
}

interface FeaturableWidget {
  totalReviewCount: number;
  averageRating: number;
  reviews: FeaturableReview[];
}

let liveData: FeaturableWidget | null = null;

const id = site.googleBusiness.featurableWidgetId;
if (id) {
  try {
    const res = await fetch(`https://featurable.com/api/v1/widgets/${id}`);
    if (res.ok) {
      liveData = (await res.json()) as FeaturableWidget;
    }
  } catch {
    // offline build ou widget invalide — fallback sur les avis internes
  }
}

// Données à afficher : soit Featurable (live Google), soit nos reviews internes
const items = liveData
  ? liveData.reviews.slice(0, 6).map((r) => ({
      author: r.reviewer.displayName,
      context: 'Avis Google',
      rating: r.starRating,
      date: r.createTime.slice(0, 10),
      title: r.comment.split('.')[0].slice(0, 70) + (r.comment.length > 70 ? '…' : ''),
      body: r.comment,
      verified: true,
      photo: r.reviewer.profilePhotoUrl,
    }))
  : reviews.slice(0, 6).map((r) => ({ ...r, photo: undefined }));

const agg = liveData
  ? { ratingValue: liveData.averageRating, reviewCount: liveData.totalReviewCount }
  : aggregateRating(reviews);

const sourceLabel = liveData
  ? 'Avis Google en direct'
  : 'Avis clients vérifiés';
---
<section class="py-20 md:py-24 bg-cream-50 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-12 max-w-2xl mx-auto">
      <div class="inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.35em] font-medium mb-3 text-gold-600">
        {liveData && (
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        )}
        {sourceLabel}
      </div>
      <h2 class="font-display text-4xl md:text-5xl leading-tight text-forest-900 mb-6">
        Ce que disent nos clients
      </h2>

      {agg && (
        <div class="inline-flex items-center gap-3">
          <div class="flex items-center gap-0.5" aria-label={`Note moyenne : ${agg.ratingValue} sur 5`}>
            {[1, 2, 3, 4, 5].map((i) => (
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill={i <= Math.round(agg.ratingValue) ? '#cdb684' : 'none'}
                stroke="#cdb684"
                stroke-width="1.4"
                stroke-linejoin="round"
              >
                <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/>
              </svg>
            ))}
          </div>
          <div class="text-sm text-ink-700">
            <span class="font-display text-xl text-gold-600">{agg.ratingValue.toFixed(1)}</span>
            <span class="mx-1.5 opacity-60">·</span>
            {agg.reviewCount} avis
          </div>
        </div>
      )}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 stagger" style="--stagger-delay: 100ms;">
      {items.map((r) => (
        <article class="rounded-2xl p-6 md:p-7 bg-cream-100 border border-forest-100/60 transition-shadow hover:shadow-cream">
          <div class="flex items-center gap-0.5 mb-4" aria-label={`${r.rating} étoiles sur 5`}>
            {[1, 2, 3, 4, 5].map((i) => (
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill={i <= r.rating ? '#cdb684' : 'none'}
                stroke="#cdb684"
                stroke-width="1.4"
                stroke-linejoin="round"
              >
                <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/>
              </svg>
            ))}
          </div>

          <h3 class="font-display text-xl text-forest-900 leading-tight mb-2">
            {r.title}
          </h3>
          <p class="text-sm text-ink-700 leading-relaxed mb-5">
            « {r.body} »
          </p>

          <div class="flex items-center gap-3 text-xs">
            {r.photo ? (
              <img
                src={r.photo}
                alt={`Photo de profil de ${r.author}`}
                class="w-9 h-9 rounded-full object-cover flex-none"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            ) : (
              <div class="w-9 h-9 rounded-full bg-forest-800 text-gold-400 flex-none flex items-center justify-center font-display text-sm">
                {r.author.charAt(0)}
              </div>
            )}
            <div>
              <div class="font-medium text-forest-900">{r.author}</div>
              <div class="text-ink-500 mt-0.5">{r.context}</div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA Google : toujours visible, quel que soit le mode -->
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={site.googleBusiness.url}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-forest-800 hover:bg-forest-900 text-cream-100 font-medium transition-colors"
      >
        Voir tous les avis sur Google
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
      </a>
      <a
        href={site.googleBusiness.writeReviewUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-forest-200 hover:border-forest-500 text-forest-800 font-medium transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/>
        </svg>
        Laisser un avis Google
      </a>
    </div>
  </div>
</section>
