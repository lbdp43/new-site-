---
import { site } from '../data/site';
import CartIcon from './cart/CartIcon';
import { t, localizedPath, alternateLangPath, type Lang } from '../i18n/utils';
import type { UIKey } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'fr' } = Astro.props;
const tr = (key: UIKey) => t(key, lang);

/**
 * Navigation à 2 niveaux : items racine + sous-menus optionnels.
 *
 * Regroupement pensé pour que la barre principale reste aérée (5 items
 * racine seulement), tandis que les pages secondaires sont accessibles
 * via le dropdown du parent logique :
 *
 *   Maison         → Notre histoire, Nos plantes, Journal (blog)
 *   Boutique       → Toute la boutique, Lumière Obscure, Cocktails
 *   Ateliers       (direct)
 *   Pros           (direct)
 *   Contact        (direct)
 */
interface NavChild {
  labelKey: UIKey;
  href: string;
  description?: UIKey;
}
interface NavItem {
  labelKey: UIKey;
  href: string;
  children?: NavChild[];
}

const shopPath = localizedPath('/boutique', lang);

const navItems: NavItem[] = [
  {
    // La Maison = contenu éditorial / culture (pas de vente directe)
    labelKey: 'nav.maison',
    href: localizedPath('/notre-histoire', lang),
    children: [
      { labelKey: 'nav.story', href: localizedPath('/notre-histoire', lang) },
      { labelKey: 'nav.plants', href: localizedPath('/nos-plantes', lang) },
      { labelKey: 'nav.cocktails', href: localizedPath('/cocktails', lang) },
      { labelKey: 'nav.journal', href: localizedPath('/blog', lang) },
    ],
  },
  {
    // Boutique = catalogue par gamme. On scroll vers les sections de /boutique
    // via ancres (#brasserie, #aperitif, etc.) — c'est le pattern utilisé par
    // la page. Exception : Lumière Obscure a sa page dédiée (ambiance sombre).
    labelKey: 'nav.shop',
    href: shopPath,
    children: [
      { labelKey: 'nav.shop-all', href: shopPath },
      { labelKey: 'nav.range-brasserie', href: `${shopPath}#brasserie` },
      { labelKey: 'nav.range-aperitif', href: `${shopPath}#aperitif` },
      { labelKey: 'nav.lumiere', href: localizedPath('/lumiere-obscure', lang) },
      { labelKey: 'nav.range-edition', href: `${shopPath}#edition-limitee` },
      { labelKey: 'nav.range-accessoire', href: `${shopPath}#accessoire` },
    ],
  },
  { labelKey: 'nav.workshops', href: localizedPath('/ateliers', lang) },
  { labelKey: 'nav.pros', href: localizedPath('/professionnels', lang) },
  { labelKey: 'nav.contact', href: localizedPath('/contact', lang) },
];

// Language switcher — on génère le chemin équivalent dans l'autre langue
const otherLang: Lang = lang === 'fr' ? 'en' : 'fr';
const switchTargetPath = alternateLangPath(Astro.url.pathname, lang, otherLang);
const homeHref = lang === 'en' ? '/en/' : '/';
const shopHref = localizedPath('/boutique', lang);
---
<header
  id="site-header"
  class="sticky top-0 z-40 header-glass"
>
  <!-- Bandeau promo — toujours visible (info essentielle livraison) -->
  <div class="relative bg-forest-800 text-cream-100 text-center text-xs tracking-wide py-2 px-4">
    <span class="font-medium">{tr('promo.free-shipping')}</span>
    <span class="opacity-70 mx-2">·</span>
    <span class="opacity-80">{tr('promo.delivery-time')}</span>
    <!-- filet doré sous le bandeau promo (ornement signature) -->
    <div class="absolute inset-x-0 bottom-0 h-px gold-hairline"></div>
  </div>

  <!-- Couche liquid-glass (logo script + navigation + CTAs) — CACHÉE tant
       qu'on n'a pas scrollé, pour laisser le logo hero "dans le ciel" et
       l'image award respirer sans concurrence visuelle. Apparaît avec
       transition à la fin du scroll du hero. -->
  <div class="relative header-glass-body header-main-collapsible">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-5 flex items-center justify-between gap-4">
      <a href={homeHref} class="flex items-center gap-3 group shrink-0" aria-label={`${site.name} — ${tr('cta.back-home')}`}>
        <img
          src="/images/brand/logo-lbdp.png"
          alt={site.name}
          class="h-9 md:h-11 w-auto max-w-[180px] sm:max-w-[220px] object-contain shrink-0 group-hover:opacity-80 transition-opacity"
          width="240"
          height="44"
          fetchpriority="high"
        />
      </a>

      <!-- Nav regroupée en 5 items (avec dropdowns sur les 2 parents qui
           ont des enfants). Visible à partir de lg (1024px) maintenant que
           la nav est moins chargée. -->
      <nav class="hidden lg:flex items-center gap-6 xl:gap-8 text-sm">
        {navItems.map((item) => (
          item.children ? (
            <div class="relative group/nav">
              <a
                href={item.href}
                class="relative text-ink-700 hover:text-forest-700 transition-colors font-medium nav-link whitespace-nowrap inline-flex items-center gap-1 py-2"
                aria-haspopup="true"
                aria-expanded="false"
              >
                {tr(item.labelKey)}
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 group-hover/nav:rotate-180 transition-transform">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </a>
              <!-- Dropdown : apparaît au hover/focus du parent.
                   Pont invisible (padding-top) pour traverser le gap sans
                   que la souris quitte le group. -->
              <div class="absolute left-1/2 -translate-x-1/2 top-full pt-3 opacity-0 invisible group-hover/nav:opacity-100 group-hover/nav:visible group-focus-within/nav:opacity-100 group-focus-within/nav:visible transition-all duration-200 z-50 min-w-[220px]">
                <div class="bg-cream-50/98 backdrop-blur-md rounded-xl border border-forest-100 shadow-xl py-2 overflow-hidden">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-5 py-2.5 text-sm text-ink-700 hover:bg-cream-100 hover:text-forest-700 transition-colors whitespace-nowrap"
                    >
                      {tr(child.labelKey)}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="relative text-ink-700 hover:text-forest-700 transition-colors font-medium nav-link whitespace-nowrap py-2"
            >
              {tr(item.labelKey)}
            </a>
          )
        ))}
      </nav>

      <div class="flex items-center gap-2 md:gap-3 shrink-0">
        <!-- Language switcher (desktop) -->
        <a
          href={switchTargetPath}
          class="hidden md:inline-flex items-center gap-1 px-3 py-1.5 rounded-full border border-forest-200/60 text-xs font-medium text-forest-700 hover:border-forest-400 hover:text-forest-900 transition-colors"
          aria-label={tr('lang.switch')}
          title={otherLang === 'fr' ? tr('lang.fr') : tr('lang.en')}
        >
          <span class="uppercase tracking-wider">{otherLang}</span>
        </a>

        <CartIcon client:load />
        <!-- CTA "Découvrir la boutique" : visible à partir de lg (1024px)
             car la nav tient maintenant confortablement en lg. -->
        <a
          href={shopHref}
          class="hidden lg:inline-flex items-center gap-2 px-4 py-2 rounded-full bg-forest-700 hover:bg-forest-800 text-cream-100 text-sm font-medium transition-all shadow-[0_0_0_1px_rgba(205,182,132,0.2),0_4px_14px_-4px_rgba(10,107,67,0.4)] hover:shadow-[0_0_0_1px_rgba(205,182,132,0.6),0_8px_22px_-6px_rgba(205,182,132,0.4)] whitespace-nowrap"
        >
          {tr('nav.discover-shop')}
        </a>
        <button
          id="menu-toggle"
          aria-label={tr('nav.open-menu')}
          class="lg:hidden p-2 text-forest-900"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="7" x2="20" y2="7" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="17" x2="20" y2="17" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Filet doré en bas du header (apparaît au scroll) -->
    <div class="absolute inset-x-0 bottom-0 h-px gold-hairline opacity-0 transition-opacity duration-500" id="header-gold-line"></div>
  </div>

  <!-- Mobile menu — avec accordéons sur les items parents -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gold-500/20 bg-cream-50/95 backdrop-blur-md">
    <nav class="flex flex-col px-6 py-4 gap-0">
      {navItems.map((item) => (
        item.children ? (
          <details class="group/mob border-b border-forest-100/60">
            <summary class="py-3 flex items-center justify-between cursor-pointer text-ink-700 hover:text-forest-700 list-none">
              <span>{tr(item.labelKey)}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 group-open/mob:rotate-180 transition-transform">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>
            <div class="pb-3 pl-4 border-l border-forest-100 ml-1 flex flex-col gap-0.5">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="py-2 text-sm text-ink-500 hover:text-forest-700"
                >
                  {tr(child.labelKey)}
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a
            href={item.href}
            class="py-3 text-ink-700 hover:text-forest-700 border-b border-forest-100/60"
          >
            {tr(item.labelKey)}
          </a>
        )
      ))}
      <a
        href={switchTargetPath}
        class="py-3 text-ink-500 hover:text-forest-700 border-b border-forest-100/60 uppercase text-xs tracking-wider"
      >
        {otherLang === 'en' ? 'English' : 'Français'}
      </a>
      <a
        href={shopHref}
        class="mt-3 inline-flex justify-center items-center px-5 py-3 rounded-full bg-forest-700 text-cream-100 font-medium"
      >
        {tr('nav.discover-shop')}
      </a>
    </nav>
  </div>
</header>

<style>
  /* Liquid-glass : backdrop-blur fort + reflet intérieur blanc (edge refraction) */
  .header-glass-body {
    background-color: rgba(251, 248, 241, 0.72);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    /* Double inset : highlight blanc en haut + halo subtil */
    box-shadow:
      inset 0 1px 0 0 rgba(255, 255, 255, 0.6),
      inset 0 -1px 0 0 rgba(205, 182, 132, 0.08);
  }

  /* Classe sur le <header> racine pour préserver sticky + z-index */
  .header-glass {
    isolation: isolate;
  }

  /* Bandeau principal (logo script + nav + CTAs) — par défaut toujours
     visible sur toutes les pages. Uniquement sur les pages avec hero
     (body[data-has-hero]), on le cache tant qu'on n'a pas scrollé, pour
     laisser le logo hero respirer dans le ciel. */
  :global(body[data-has-hero]) .header-main-collapsible {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 360ms cubic-bezier(0.16, 1, 0.3, 1), opacity 260ms ease-out;
  }
  :global(body[data-has-hero]) .header-glass[data-scrolled="true"] .header-main-collapsible {
    max-height: 120px;
    opacity: 1;
    overflow: visible;
  }

  /* État au scroll : teinte légèrement plus dense + filet doré plus visible */
  .header-glass[data-scrolled="true"] .header-glass-body {
    background-color: rgba(251, 248, 241, 0.88);
    box-shadow:
      inset 0 1px 0 0 rgba(255, 255, 255, 0.7),
      inset 0 -1px 0 0 rgba(205, 182, 132, 0.18),
      0 2px 16px -8px rgba(10, 107, 67, 0.15);
  }
  .header-glass[data-scrolled="true"] #header-gold-line {
    opacity: 1;
  }

  /* Filet doré — dégradé horizontal luxe */
  .gold-hairline {
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(205, 182, 132, 0.35) 15%,
      rgba(220, 199, 151, 0.85) 50%,
      rgba(205, 182, 132, 0.35) 85%,
      transparent 100%
    );
  }

  /* Soulignement doré subtil au hover sur les liens nav */
  .nav-link::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -6px;
    height: 1.5px;
    width: 0;
    background: linear-gradient(to right, transparent, var(--color-gold-500), transparent);
    transform: translateX(-50%);
    transition: width 280ms cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
  .nav-link:hover::after {
    width: 100%;
  }

  /* Fallback pour navigateurs sans backdrop-filter */
  @supports not (backdrop-filter: blur(1px)) {
    .header-glass-body {
      background-color: rgba(251, 248, 241, 0.98);
    }
  }
</style>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Scroll detection — active le filet doré + densifie le glass quand on scrolle
  const header = document.getElementById('site-header');
  if (header) {
    let ticking = false;
    const updateScrolled = () => {
      const scrolled = window.scrollY > 8;
      header.dataset.scrolled = scrolled ? 'true' : 'false';
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateScrolled);
        ticking = true;
      }
    }, { passive: true });
    updateScrolled();
  }
</script>
