---
import { site, nav } from '../data/site';

const year = new Date().getFullYear();
---
<footer class="bg-forest-900 text-cream-100 mt-24">
  <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-4 gap-10">
    <div class="md:col-span-2">
      <div class="mb-4">
        <img
          src="/images/brand/logo-lbdp.png"
          alt="La Brasserie des Plantes"
          class="h-14 w-auto brightness-0 invert"
        />
      </div>
      <p class="text-cream-200/80 max-w-md text-sm leading-relaxed">
        Artisans liquoristes en Haute-Loire. Nous composons des liqueurs et
        infusions à partir de plantes oubliées, récoltées au plus près de nos
        montagnes d'Auvergne.
      </p>
      <p class="mt-4 text-xs text-cream-200/60">
        SIRET {site.siret}
      </p>
    </div>

    <div>
      <h3 class="font-display text-lg text-cream-100 mb-4">Navigation</h3>
      <ul class="space-y-2 text-sm">
        {nav.map((item) => (
          <li>
            <a href={item.href} class="text-cream-200/80 hover:text-cream-100 transition-colors">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-display text-lg text-cream-100 mb-4">Nous trouver</h3>
      <address class="not-italic text-sm text-cream-200/80 space-y-2 leading-relaxed">
        <div>
          {site.address.street}<br />
          {site.address.postalCode} {site.address.city}
        </div>
        <div>
          <a href={`tel:${site.phone}`} class="hover:text-cream-100 transition-colors">
            {site.phoneDisplay}
          </a>
        </div>
        <div>
          <a href={`mailto:${site.email}`} class="hover:text-cream-100 transition-colors break-all">
            {site.email}
          </a>
        </div>
        <div class="pt-2 text-xs text-cream-200/60">
          {site.hoursDisplay}
        </div>
      </address>
    </div>
  </div>

  <!-- Moyens de paiement -->
  <div class="border-t border-forest-700/50 bg-forest-950/50">
    <div class="max-w-7xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-xs uppercase tracking-[0.25em] text-cream-200/70">
        Paiement sécurisé
      </div>
      <div class="flex items-center gap-3 text-cream-100/90" aria-label="Moyens de paiement acceptés">
        <!-- Visa -->
        <div class="h-7 w-11 rounded bg-white flex items-center justify-center" title="Visa">
          <svg viewBox="0 0 48 32" class="h-4" aria-hidden="true">
            <text x="24" y="22" text-anchor="middle" font-family="Arial Black, sans-serif" font-size="14" font-weight="900" fill="#1a1f71" letter-spacing="-0.5">VISA</text>
          </svg>
        </div>
        <!-- Mastercard -->
        <div class="h-7 w-11 rounded bg-white flex items-center justify-center" title="Mastercard">
          <svg viewBox="0 0 48 32" class="h-5" aria-hidden="true">
            <circle cx="20" cy="16" r="9" fill="#eb001b"/>
            <circle cx="28" cy="16" r="9" fill="#f79e1b"/>
            <path d="M 24 9 a 9 9 0 0 0 0 14 a 9 9 0 0 0 0 -14" fill="#ff5f00"/>
          </svg>
        </div>
        <!-- American Express -->
        <div class="h-7 w-11 rounded bg-[#2e77bb] flex items-center justify-center text-white text-[9px] font-bold tracking-tight" title="American Express">
          AMEX
        </div>
        <!-- Apple Pay -->
        <div class="h-7 w-11 rounded bg-black text-white flex items-center justify-center gap-0.5" title="Apple Pay" aria-label="Apple Pay">
          <svg class="h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.72 6.35c-.92 1.11-2.4 1.97-3.88 1.85-.19-1.48.55-3 1.39-3.94.94-1.15 2.55-1.97 3.87-2.03.16 1.54-.47 3.05-1.38 4.12zm1.36 2.16c-2.14-.12-3.96 1.21-4.98 1.21-1.03 0-2.6-1.15-4.3-1.12-2.21.03-4.25 1.28-5.38 3.26-2.3 3.97-.6 9.85 1.64 13.08 1.09 1.6 2.39 3.36 4.09 3.3 1.64-.07 2.26-1.06 4.24-1.06 1.97 0 2.53 1.06 4.26 1.03 1.77-.03 2.88-1.6 3.95-3.2 1.23-1.83 1.74-3.6 1.77-3.69-.04-.02-3.4-1.31-3.44-5.2-.03-3.26 2.65-4.83 2.78-4.91-1.52-2.25-3.89-2.5-4.73-2.55z"/></svg>
          <span class="text-[8.5px] font-medium pr-0.5">Pay</span>
        </div>
        <!-- Google Pay -->
        <div class="h-7 w-11 rounded bg-white flex items-center justify-center gap-0.5 text-[#5f6368]" title="Google Pay">
          <svg class="h-3" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285f4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34a853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#fbbc05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#ea4335"/>
          </svg>
          <span class="text-[8.5px] font-medium pr-0.5">Pay</span>
        </div>
        <!-- PayPal -->
        <div class="h-7 w-11 rounded bg-white flex items-center justify-center" title="PayPal">
          <svg class="h-3" viewBox="0 0 48 24" aria-hidden="true">
            <text x="24" y="17" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" font-weight="700" fill="#003087" letter-spacing="-0.4">Pay</text>
            <text x="24" y="17" dx="10" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" font-weight="700" fill="#0070ba" letter-spacing="-0.4">Pal</text>
          </svg>
        </div>
        <!-- SEPA -->
        <div class="h-7 w-11 rounded bg-white flex items-center justify-center text-[#003087] text-[9px] font-bold" title="Virement SEPA">
          SEPA
        </div>
      </div>
      <div class="text-xs text-cream-200/60 flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        SSL sécurisé
      </div>
    </div>
  </div>

  <div class="border-t border-forest-700/50">
    <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-cream-200/60">
      <div>© {year} {site.name}. Tous droits réservés.</div>
      <div class="flex flex-wrap gap-5">
        <a href="/faq" class="hover:text-cream-100">FAQ</a>
        <a href="/presse" class="hover:text-cream-100">Presse</a>
        <a href="/mentions-legales" class="hover:text-cream-100">Mentions légales</a>
        <a href="/cgv" class="hover:text-cream-100">CGV</a>
        <a href="/politique-cookies" class="hover:text-cream-100">Cookies</a>
      </div>
      <div class="text-cream-200/60">
        L'abus d'alcool est dangereux pour la santé. À consommer avec modération.
      </div>
    </div>
  </div>
</footer>
