---
/**
 * MasonryGallery — grille masonry animée avec Scroll-Driven Animations (CSS natif).
 * Inspirée de https://21st.dev/community/components/ravikatiyar/masonry-grid-with-scroll-animation
 *
 * Adaptations LBDP :
 * - photos d'atelier / plantes / événements (pas de texte sous chaque carte)
 * - palette vert émeraude + dorure au hover
 * - anti-slop : pas de 4e colonne, reste aéré (VISUAL_DENSITY 4)
 */

interface GalleryItem {
  src: string;
  alt: string;
  aspect?: 'portrait' | 'landscape' | 'square';
}

interface Props {
  items: GalleryItem[];
  kicker?: string;
  heading?: string;
}

const { items, kicker = 'Galerie', heading = 'Notre atelier en images' } = Astro.props;
---
<section class="py-20 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12 max-w-2xl mx-auto">
      <div class="text-[10px] md:text-xs uppercase tracking-[0.35em] text-gold-600 font-medium mb-3">{kicker}</div>
      <h2 class="font-display text-4xl md:text-5xl leading-tight text-forest-900">{heading}</h2>
      <div class="gold-divider mt-6"></div>
    </div>

    <div class="masonry-grid grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
      {items.map((item, i) => {
        const aspectClass =
          item.aspect === 'portrait'
            ? 'aspect-[3/4]'
            : item.aspect === 'landscape'
            ? 'aspect-[4/3]'
            : 'aspect-square';
        return (
          <div
            class={`masonry-card ${aspectClass} rounded-xl overflow-hidden bg-cream-50 shadow-cream hover:shadow-cream-lg transition-shadow`}
            style={`--side: ${i % 2 === 0 ? 1 : -1}; --amp: ${Math.ceil((i % 6) / 2)};`}
          >
            <img
              src={item.src}
              alt={item.alt}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
            />
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  @keyframes masonry-slide-in {
    from {
      opacity: 0;
      transform: scale(0.88) rotate(calc(var(--side, 1) * (4deg * var(--amp, 1))));
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }

  .masonry-card {
    transform-origin: center 100%;
  }

  @media (prefers-reduced-motion: no-preference) {
    .masonry-card {
      animation: masonry-slide-in linear both;
      animation-timeline: view();
      animation-range: entry 0% cover 20%;
    }
  }

  /* Transform origin par colonne pour un effet asymétrique propre */
  .masonry-card:nth-of-type(2n + 1) { transform-origin: 25vw 100%; }
  .masonry-card:nth-of-type(2n)     { transform-origin: -25vw 100%; }

  @media (min-width: 768px) {
    .masonry-card:nth-of-type(3n + 1) { transform-origin: 40vw 100%; }
    .masonry-card:nth-of-type(3n + 2) { transform-origin: 0 100%; }
    .masonry-card:nth-of-type(3n)     { transform-origin: -40vw 100%; }
  }

  @media (min-width: 1024px) {
    .masonry-card:nth-of-type(4n + 1) { transform-origin: 50vw 100%; }
    .masonry-card:nth-of-type(4n + 2) { transform-origin: 15vw 100%; }
    .masonry-card:nth-of-type(4n + 3) { transform-origin: -15vw 100%; }
    .masonry-card:nth-of-type(4n)     { transform-origin: -50vw 100%; }
  }
</style>
