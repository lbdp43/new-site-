---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { plants } from '../data/plants';
import { site } from '../data/site';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Nos plantes', item: `${site.url}/nos-plantes` },
  ],
};

// ItemList schema — chaque plante est un DefinedTerm pour AI search + SEO sémantique.
const plantsListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Plantes et ingrédients botaniques de La Brasserie des Plantes',
  description:
    "Plantes aromatiques, racines, écorces, fleurs, agrumes, épices et fruits utilisés dans nos liqueurs artisanales. Sourcés chez des cueilleurs et maraîchers partenaires, en Haute-Loire et au-delà, avec une majorité issue de l'agriculture biologique.",
  numberOfItems: plants.length,
  itemListElement: plants.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'DefinedTerm',
      name: p.name,
      ...(p.latin && { alternateName: p.latin }),
      description: p.description,
      inDefinedTermSet: `${site.url}/nos-plantes`,
    },
  })),
};

const schema = [breadcrumbSchema, plantsListSchema];

const familyLabels: Record<string, string> = {
  aromatique: 'Plante aromatique',
  racine: 'Racine',
  ecorce: 'Écorce',
  epice: 'Épice',
  fleur: 'Fleur',
  agrume: 'Agrume',
  fruit: 'Fruit',
  autre: 'Spécialité',
};

// Ordre d'affichage des familles (ordre de dégustation logique)
const familyOrder = ['aromatique', 'fleur', 'racine', 'ecorce', 'agrume', 'epice', 'fruit', 'autre'] as const;
const sortedPlants = [...plants].sort((a, b) => {
  const fa = familyOrder.indexOf(a.family as typeof familyOrder[number]);
  const fb = familyOrder.indexOf(b.family as typeof familyOrder[number]);
  if (fa !== fb) return fa - fb;
  return a.name.localeCompare(b.name, 'fr');
});

---
<Layout
  title="Nos plantes — une quarantaine d'ingrédients botaniques | La Brasserie des Plantes"
  description="Verveine, mélisse, serpolet, carvi, hysope, gentiane, génépi, sureau, pitaya, amande… une quarantaine de plantes, racines, écorces, fleurs, agrumes, épices et fruits qui composent nos liqueurs artisanales de Haute-Loire."
  schema={schema}
>
  <PageHeader
    kicker="Botanique"
    title="Les plantes qui composent<br /><em class='not-italic font-normal text-forest-600' style='font-family: var(--font-script);'>nos liqueurs</em>"
    subtitle="Verveine, serpolet, carvi, mélisse, hysope, gentiane, génépi, sureau, ortie, chanvre, amande, pitaya… Une quarantaine d'ingrédients botaniques, sourcés chez des cueilleurs et maraîchers que nous choisissons un par un."
    breadcrumb={[{ label: 'Accueil', href: '/' }, { label: 'Nos plantes' }]}
  />

  <section class="pb-24">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Vidéo verveine -->
      <div class="aspect-[5/2] rounded-3xl overflow-hidden shadow-xl mb-16 bg-forest-50">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/videos/plante-verveine-poster.jpg"
          aria-label="Étienne, cofondateur, prépare la verveine fraîche — plante signature de La Brasserie des Plantes"
          class="w-full h-full object-cover"
        >
          <source src="/videos/plante-verveine.mp4" type="video/mp4" />
        </video>
      </div>

      <!-- Intro -->
      <div class="max-w-3xl mx-auto text-lg text-ink-700 leading-relaxed space-y-6 mb-16">
        <p>
          Une liqueur, c'est un paysage en bouteille. Certaines de nos
          recettes tiennent sur trois plantes — <em>L'Herbe des Druides</em>,
          c'est verveine, serpolet, carvi, point. D'autres sont des trios
          d'accord : <em>Le Zéleste</em>, c'est un trio de zestes (citron
          jaune, citron vert, orange) ; <em>Le Menthor</em>, un trio de menthes
          (poivrée, verte, agastache). Et puis il y a les grands assemblages —
          <em>L'Alchimie Végétale</em>, <strong class="font-medium text-forest-800">27 plantes, racines,
          écorces et épices</strong>, couronnée Meilleur Digestif du Monde en 2025.
        </p>
        <p>
          À travers toute la gamme, nous travaillons avec
          <strong class="font-medium text-forest-800">une quarantaine d'ingrédients
          botaniques</strong> — aromatiques, racines, écorces, fleurs, agrumes,
          épices, fruits. Nous ne cultivons pas nos plantes nous-mêmes : nous
          les sourçons chez des cueilleurs et des maraîchers que nous
          choisissons un par un. La plupart viennent de l'agriculture
          biologique ; certaines poussent à quelques kilomètres de l'atelier,
          d'autres plus loin quand la plante l'exige. Origine connue à chaque
          fois, producteur rencontré.
        </p>
      </div>

      <!-- Grille plantes -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPlants.map((plant) => (
          <article class="p-7 rounded-2xl bg-cream-50 border border-forest-100/60 hover:border-forest-300 hover:shadow-lg transition-all">
            <div class="flex items-start justify-between mb-3 gap-3">
              <div class="min-w-0">
                <h2 class="font-display text-2xl text-forest-900 leading-tight">{plant.name}</h2>
                {plant.latin && (
                  <div class="text-xs italic text-ink-500 mt-1">{plant.latin}</div>
                )}
              </div>
              <span class="text-[10px] uppercase tracking-[0.15em] text-forest-600 font-medium px-2 py-1 rounded-full bg-forest-50 whitespace-nowrap">
                {familyLabels[plant.family]}
              </span>
            </div>
            {plant.role && (
              <div class="text-xs font-medium text-gold-700 mb-3 tracking-wide">
                {plant.role}
              </div>
            )}
            <p class="text-sm text-ink-700 leading-relaxed mb-4">{plant.description}</p>
            <div class="pt-3 border-t border-forest-100/80 space-y-2">
              <div class="text-xs">
                <span class="text-ink-500 uppercase tracking-wide">Dans nos liqueurs</span>
                <div class="text-forest-800 font-medium mt-0.5 leading-snug">{plant.usedIn}</div>
              </div>
              {plant.season && (
                <div class="text-xs">
                  <span class="text-ink-500 uppercase tracking-wide">Saison</span>
                  <div class="text-ink-700 mt-0.5">{plant.season}</div>
                </div>
              )}
              {plant.signature && (
                <div class="mt-3 inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-gold-500/15 text-gold-700 text-[10px] font-medium tracking-wide uppercase">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
                  Plante signature
                </div>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- Clôture de la liste : on ne dit pas tout -->
      <div class="mt-12 max-w-3xl mx-auto text-center">
        <p class="text-base md:text-lg text-ink-600 italic leading-relaxed">
          … et bien d'autres, que nous gardons pour nous. Les secrets d'assemblage
          font aussi partie du métier.
        </p>
      </div>
    </div>
  </section>

  <!-- Pourquoi ce choix -->
  <section class="py-20 bg-cream-50">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">Notre démarche</div>
      <h2 class="font-display text-3xl md:text-4xl text-forest-900 mb-6 leading-tight">
        Le terroir,<br />
        <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">le patrimoine vivant</em>
      </h2>
      <div class="space-y-5 text-lg text-ink-700 leading-relaxed">
        <p>
          Nous n'écrivons jamais une recette sans savoir d'où viennent les
          plantes. Nous travaillons avec des <a href="/blog/producteurs-partenaires-bio-velay" class="text-forest-700 font-medium underline decoration-forest-300 underline-offset-4 hover:text-forest-900">cueilleurs
          et des maraîchers</a> que nous sélectionnons un par un : chaque
          plante a son récoltant, chaque récoltant est rencontré.
        </p>
        <p>
          On essaie de travailler au plus près, quand c'est possible — une
          bonne partie de nos plantes vient de Haute-Loire et des départements
          voisins. Pas toujours : certaines imposent leur terroir (le génépi
          des Alpes, par exemple), d'autres viennent de plus loin selon la
          saison et la qualité du moment (agrumes, réglisse, quinquina). La
          plupart sont issues de <strong class="font-medium text-forest-800">l'agriculture
          biologique</strong> — c'est ce vers quoi on tend, même si toutes ne
          le sont pas encore.
        </p>
        <p>
          Notre règle, c'est la plante avant tout : <strong class="font-medium text-forest-800">pas
          d'arôme ajouté, pas de colorant</strong>. Ce qu'il y a dans la
          bouteille, c'est ce qui a poussé dans la cuve.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-forest-900 text-cream-100">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl mb-6">
        Et la suite ?
      </h2>
      <p class="text-cream-200/80 leading-relaxed text-lg mb-8 max-w-xl mx-auto">
        Notre liste s'enrichit chaque saison — édition limitée, cuvée
        spéciale, collaboration avec un nouveau producteur. La meilleure
        façon de découvrir ce qui se passe dans nos cuves : goûter.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/boutique" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-cream-50 hover:bg-cream-100 text-forest-900 font-medium transition-colors">
          Explorer la boutique
        </a>
        <a href="/ateliers" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-cream-100/40 hover:border-cream-100/70 text-cream-100 font-medium transition-colors">
          Visite-dégustation à l'atelier
        </a>
      </div>
    </div>
  </section>
</Layout>
