---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import InstagramFeed from '../../../components/InstagramFeed.astro';
import { site } from '../../../data/site';

const posts = (await getCollection('blog-en')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Journal', item: `${site.url}/en/journal` },
  ],
};

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `Journal — ${site.name}`,
  url: `${site.url}/en/journal`,
  inLanguage: 'en-US',
  publisher: { '@id': `${site.url}#localbusiness` },
};
---
<Layout
  lang="en"
  title="Journal | Plants, recipes, terroir — La Brasserie des Plantes"
  description="Our journal: encounters with plants, cocktail recipes, workshop stories, behind-the-scenes from our distillery. An artisan's eye on botany and the Auvergne terroir."
  schema={[breadcrumb, blogSchema]}
>
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-6 text-center mb-12">
      <div class="text-[10px] uppercase tracking-[0.35em] text-gold-600 font-medium mb-3">
        Articles
      </div>
      <h1 class="font-display text-4xl md:text-5xl text-forest-900 mb-4">
        Our journal
      </h1>
      <p class="max-w-2xl mx-auto text-ink-700 leading-relaxed">
        Five key articles in English — the rest of our journal ({posts.length === 5 ? '20+ pieces' : 'more'}) is available
        in French at <a href="/blog" class="text-forest-700 underline underline-offset-2 hover:text-forest-900">labrasseriedesplantes.fr/blog</a>.
      </p>
    </div>
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a
            href={`/en/journal/${post.id}`}
            class="group flex flex-col rounded-2xl bg-cream-50 border border-forest-100/60 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
          >
            {post.data.cover && (
              <div class="aspect-[3/2] overflow-hidden bg-forest-100">
                <img
                  src={post.data.cover}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex items-center gap-3 text-xs text-ink-500 mb-3">
                <span class="uppercase tracking-wide text-forest-600 font-medium">{post.data.category}</span>
                <span>·</span>
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
              </div>
              <h2 class="font-display text-2xl text-forest-900 leading-tight mb-3 group-hover:text-forest-700 transition-colors">
                {post.data.title}
              </h2>
              <p class="text-sm text-ink-700 leading-relaxed mb-4 flex-1">
                {post.data.description}
              </p>
              <div class="text-xs text-ink-500">{post.data.readingTime} read</div>
            </div>
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="text-center text-ink-500 py-20">Articles coming soon.</p>
      )}
    </div>
  </section>

  <InstagramFeed variant="dark" kicker="Day by day" title="On Instagram" />
</Layout>
