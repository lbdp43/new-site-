---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { site } from '../../data/site';

interface FaqItem {
  q: string;
  a: string;
  category: 'Orders' | 'Tasting' | 'Products' | 'CBD' | 'Trade';
}

const faqs: FaqItem[] = [
  {
    category: 'Orders',
    q: 'What are your delivery times?',
    a: 'Orders are dispatched within 2 to 3 business days from our workshop in Haute-Loire (France). Delivery in metropolitan France is via Colissimo tracked shipping, within 48 to 72 hours after dispatch.',
  },
  {
    category: 'Orders',
    q: 'Is shipping free?',
    a: 'Yes — shipping is free on orders above €65 in metropolitan France. Below that, fees are calculated based on parcel weight.',
  },
  {
    category: 'Orders',
    q: 'Do you deliver outside France?',
    a: 'We currently deliver within metropolitan France and Belgium. For international shipping, please contact us directly.',
  },
  {
    category: 'Tasting',
    q: "How do you serve L'Alchimie Végétale?",
    a: "L'Alchimie Végétale is best enjoyed as a digestif, ideally at 3°C (straight from the freezer). A splash in an espresso, a long drink with a craft tonic, or neat — your choice. At 50% vol. and with its aromatic complexity, it's made to be savoured slowly, in small sips.",
  },
  {
    category: 'Tasting',
    q: 'Can your liqueurs be used in cooking?',
    a: "Absolutely. Our aperitifs pair very well with fruit desserts (strawberries, raspberries, citrus) and can flavour sorbets, ganaches or mousses. L'Herbe des Druides elevates a sabayon; La Flèche Ardente lifts a strawberry salad.",
  },
  {
    category: 'Tasting',
    q: 'How long do your liqueurs keep?',
    a: 'Our liqueurs keep for several years unopened, away from light and heat. Once opened, they retain all their qualities for 12 to 18 months — beyond that, the aromas soften but stay very pleasant.',
  },
  {
    category: 'Products',
    q: 'Are your products organic?',
    a: 'Our plants come from organic farming, harvested on our own parcels or with partner producers we select one by one. Organic certification is in progress for the whole range.',
  },
  {
    category: 'Products',
    q: 'Do you use flavourings or preservatives?',
    a: 'None. Our liqueurs are made of plants, alcohol and sugar. No artificial flavouring, no colouring, no preservatives. The colour, taste and body come solely from our craft work and the time given to the plants.',
  },
  {
    category: 'Products',
    q: 'What is the alcohol content of your liqueurs?',
    a: "L'Alchimie Végétale is 50% vol. The other signature range liqueurs fall between 30 and 45% vol. Aperitifs from the Nectar/Lime/Flèche range are lighter (18 to 22% vol.), as are the CBD-infused Lumière Obscure liqueurs.",
  },
  {
    category: 'CBD',
    q: 'Do your CBD infusions contain THC?',
    a: 'No. Our Lumière Obscure CBD range uses certified industrial hemp (Cannabis sativa L.), dosed at less than 0.1% THC, in line with French legislation. CBD is not psychotropic — you will feel the alcohol, not the THC.',
  },
  {
    category: 'CBD',
    q: 'Does CBD have effects?',
    a: 'Some studies suggest relaxing and anti-inflammatory effects, but the doses in a liqueur (a few mg per glass) are far below the therapeutic doses studied. We claim no medical effect — our CBD range is above all an aromatic proposition around hemp.',
  },
  {
    category: 'Trade',
    q: "I'm a wine merchant / restaurateur / fine grocer. Can I resell your products?",
    a: "Yes, we work directly with around twenty professionals across France. We have sale-or-return arrangements, quantity discounts, and we'll happily visit you for a tasting. Write to us with a few words about your establishment.",
  },
  {
    category: 'Trade',
    q: 'Do you make exclusive cuvées?',
    a: "Yes, we've already produced private cuvées (custom labels, specific blends) for weddings, corporate events and select wine merchants. Minimum order: 60 bottles. Contact us.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'en-US',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/en/` },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${site.url}/en/faq` },
  ],
};

const categories = ['Orders', 'Tasting', 'Products', 'CBD', 'Trade'] as const;
const faqsByCategory = Object.fromEntries(
  categories.map((cat) => [cat, faqs.filter((f) => f.category === cat)])
);
---
<Layout
  lang="en"
  title="FAQ | Shipping, tasting, CBD — La Brasserie des Plantes"
  description="Delivery, storage, tasting, CBD, trade partnerships: all answers to your questions about our craft liqueurs."
  schema={[faqSchema, breadcrumb]}
>
  <PageHeader
    kicker="Frequently Asked Questions"
    title="All<br />our answers"
    subtitle="Orders, tasting, storage, CBD, partnerships — it's all here. If you can't find what you need, write to us."
    breadcrumb={[{ label: 'Home', href: '/en/' }, { label: 'FAQ' }]}
  />

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6 space-y-14">
      {categories.map((cat) => (
        <div>
          <h2 class="font-display text-2xl md:text-3xl text-forest-900 mb-6 pb-2 border-b border-forest-200">
            {cat}
          </h2>
          <div class="space-y-3">
            {faqsByCategory[cat].map((f) => (
              <details class="group rounded-2xl bg-cream-50 border border-forest-100/60 overflow-hidden open:border-forest-300">
                <summary class="cursor-pointer px-6 py-4 font-medium text-forest-900 flex items-center justify-between gap-4 hover:bg-forest-50/50 transition-colors list-none">
                  <span>{f.q}</span>
                  <svg class="flex-none w-5 h-5 text-forest-600 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </summary>
                <div class="px-6 pb-5 text-ink-700 leading-relaxed text-sm">
                  {f.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="py-16 bg-forest-900 text-cream-100 mt-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl text-cream-100 mb-4">Another question?</h2>
      <p class="text-cream-200/80 mb-8">We reply quickly, without any fluff.</p>
      <a href="/en/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-cream-50 text-forest-900 font-medium hover:bg-cream-100 transition-colors">
        Write to us
      </a>
    </div>
  </section>
</Layout>
