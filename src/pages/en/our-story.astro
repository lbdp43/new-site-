---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { site } from '../../data/site';

// ─── Schema.org ───────────────────────────────────────────────────────
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: `Our story — ${site.name}`,
    url: `${site.url}/en/our-story`,
    inLanguage: 'en-US',
    description:
      "The story of La Brasserie des Plantes, founded in 2021 by Étienne and Guillaume in Saint-Didier-en-Velay, Haute-Loire. Craft organic liqueurs, World's Best Digestif 2025.",
    about: { '@id': `${site.url}#localbusiness` },
    mainEntity: [
      { '@id': `${site.url}#etienne` },
      { '@id': `${site.url}#guillaume` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': `${site.url}#etienne`,
    name: 'Étienne',
    jobTitle: 'Co-founder, craft distiller',
    description:
      "Co-founder of La Brasserie des Plantes. Trained in plant biotechnology in Toulouse, he composes the recipes, selects the plants and oversees the entire production.",
    worksFor: { '@id': `${site.url}#localbusiness` },
    knowsAbout: [
      'Plant biotechnology',
      'Maceration techniques',
      'Craft liqueur blending',
      'Haute-Loire botany',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': `${site.url}#guillaume`,
    name: 'Guillaume',
    jobTitle: 'Co-founder, pairings and uses',
    description:
      "Co-founder of La Brasserie des Plantes. A former restaurateur in Saint-Étienne, he designs the pairings, the brand voice and the on-trade partnerships.",
    worksFor: { '@id': `${site.url}#localbusiness` },
    knowsAbout: [
      'Mixology',
      'Food-and-liqueur pairings',
      'Hospitality',
      'On-trade development',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/en/` },
      { '@type': 'ListItem', position: 2, name: 'Our story', item: `${site.url}/en/our-story` },
    ],
  },
];

const productsWithMedals = [
  {
    product: "L'Herbe des Druides",
    slug: 'herbe-des-druides',
    tagline: 'Verbena · wild thyme · caraway',
    note: 'Our most-medalled liqueur — 3× Gold in Lyon, Silver in Paris, Silver in London.',
    medals: [
      { year: '2023', tier: 'gold', competition: 'Concours International de Lyon' },
      { year: '2024', tier: 'gold', competition: 'Concours International de Lyon' },
      { year: '2024', tier: 'silver', competition: 'Concours Général Agricole — Paris' },
      { year: '2025', tier: 'silver', competition: 'World Drinks Awards — London' },
      { year: '2026', tier: 'gold', competition: 'Concours International de Lyon' },
    ],
  },
  {
    product: "Le Cerf'Gent",
    slug: 'cerf-gent',
    tagline: 'Bitter aperitif · gentian · cinchona',
    note: "Our bitter aperitif, built on yellow gentian and cinchona — awarded Gold at France's Concours Général Agricole on its very first entry.",
    medals: [
      { year: '2025', tier: 'gold', competition: 'Concours Général Agricole — Paris' },
    ],
  },
  {
    product: "L'Essence des Alpes",
    slug: 'essence-des-alpes',
    tagline: 'Génépi · spruce tips · hyssop',
    note: "Our Alpine tribute to génépi, spruce tips and hyssop — awarded Silver at the Concours International de Lyon.",
    medals: [
      { year: '2026', tier: 'silver', competition: 'Concours International de Lyon' },
    ],
  },
];

const innovationAward = {
  year: '2023',
  title: 'Artinov Haute-Loire Award',
  subtitle: "Chamber of Crafts — Craft innovation",
  what: 'For our tap dispenser (in-house invention for pro bar service).',
};

const tierStyles: Record<string, { bg: string; text: string; border: string }> = {
  gold: { bg: 'bg-gold-500/15', text: 'text-gold-700', border: 'border-gold-500/40' },
  silver: { bg: 'bg-ink-200/40', text: 'text-ink-600', border: 'border-ink-300/60' },
};

const galleryPhotos = [
  { src: '/images/stories/service-verre.webp', alt: "Serving L'Alchimie Végétale in a tulip glass — tasting moment", aspect: 'aspect-[3/2]', objectPos: '' },
  { src: '/images/stories/salon-origine-auvergne.webp', alt: 'Guillaume at the Origine Auvergne trade show — La Brasserie des Plantes stand', aspect: 'aspect-[3/2]', objectPos: '' },
  { src: '/images/gallery/saint-etienne.webp', alt: "Li'Cœur with Étienne and Guillaume — tasting rendez-vous", aspect: 'aspect-square', objectPos: '' },
  { src: '/images/stories/atelier-1.webp', alt: 'Étienne bottling a batch in the workshop', aspect: 'aspect-[3/2]', objectPos: '' },
  { src: '/images/gallery/atelier-04.webp', alt: "L'Alchimie Végétale — World's Best Digestif 2025 story", aspect: 'aspect-[3/4]', objectPos: 'object-[center_70%]' },
  { src: '/images/stories/atelier-2.webp', alt: 'Hand-bottling close-up — green liqueur', aspect: 'aspect-[3/2]', objectPos: '' },
  { src: '/images/gallery/evenement-02.webp', alt: "Étienne in a meadow of wild flowers — among the plants that go into our liqueurs", aspect: 'aspect-[3/4]', objectPos: '' },
  { src: '/images/gallery/production-01.webp', alt: 'Our Christmas market stand — all the bottles under fairy lights', aspect: 'aspect-square', objectPos: '' },
  { src: '/images/gallery/evenement-01.webp', alt: 'Guillaume tasting with a customer — Concours International de Lyon stand', aspect: 'aspect-[3/4]', objectPos: '' },
  { src: '/images/gallery/evenement-05.webp', alt: 'Public event — meeting and tasting', aspect: 'aspect-square', objectPos: '' },
];
---
<Layout
  lang="en"
  title="Our story — La Brasserie des Plantes, Haute-Loire"
  description="Two childhood friends, a shared passion for the plants of Auvergne. La Brasserie des Plantes, from Saint-Didier-en-Velay, France — founded in 2021, seven international medals, World's Best Digestif 2025."
  schema={schema}
>
  <PageHeader
    kicker="Our story"
    title="Two friends,<br /><em class='not-italic font-normal text-forest-600' style='font-family: var(--font-script);'>one terroir</em>"
    subtitle="From Saint-Didier-en-Velay, France, we bring back the forgotten plants of Haute-Loire, as liqueurs and infusions. A village project that eventually carried off the title of World's Best Digestif."
    breadcrumb={[{ label: 'Home', href: '/en/' }, { label: 'Our story' }]}
  />

  <!-- Hero banner video : Étienne and Guillaume, making of -->
  <section class="relative w-full bg-forest-950 overflow-hidden">
    <div class="relative aspect-[21/9] md:aspect-[21/8] w-full">
      <video
        autoplay
        muted
        playsinline
        preload="metadata"
        poster="/videos/duo-making-of-poster.jpg"
        aria-label="Étienne and Guillaume, co-founders, in the La Brasserie des Plantes workshop"
        class="absolute inset-0 w-full h-full object-cover object-top"
      >
        <source src="/videos/duo-making-of.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-b from-forest-950/70 via-forest-950/30 to-forest-950/80"></div>
      <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6 gap-3 md:gap-5">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cream-50/15 border border-cream-100/30 text-cream-100 text-[10px] md:text-xs font-medium tracking-[0.25em] uppercase backdrop-blur-sm">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="4"/></svg>
          In Haute-Loire · Since 2021
        </div>
        <p class="text-cream-50 font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl leading-[1.05] drop-shadow-lg max-w-3xl">
          <em class="not-italic font-normal" style="font-family: var(--font-script);">
            We've known each other<br class="hidden sm:inline" /> for over twenty years.
          </em>
        </p>
        <p class="text-cream-100/85 text-sm md:text-lg leading-relaxed max-w-xl">
          Two childhood friends. One terroir. Ten international distinctions, and liqueurs made four-handed.
        </p>
      </div>
    </div>
  </section>

  <!-- Key figures -->
  <section class="py-14 border-y border-forest-100/60 bg-cream-100/40">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <div class="font-display text-4xl md:text-5xl text-forest-800">2021</div>
        <div class="text-xs uppercase tracking-wider text-ink-500 mt-2">Year founded</div>
      </div>
      <div>
        <div class="font-display text-4xl md:text-5xl text-forest-800">18</div>
        <div class="text-xs uppercase tracking-wider text-ink-500 mt-2">References in range</div>
      </div>
      <div>
        <div class="font-display text-4xl md:text-5xl text-forest-800">10</div>
        <div class="text-xs uppercase tracking-wider text-ink-500 mt-2">International distinctions</div>
      </div>
      <div>
        <div class="inline-flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full bg-gold-500/15 text-gold-600">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="7"/>
            <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
          </svg>
        </div>
        <div class="text-xs uppercase tracking-wider text-ink-500 mt-2">World's Best Digestif 2025</div>
      </div>
    </div>
  </section>

  <!-- Narrative — the early days -->
  <section class="py-20 bg-cream-50">
    <div class="max-w-3xl mx-auto px-6">
      <div class="prose prose-lg max-w-none text-ink-700 space-y-6 leading-relaxed">
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">The early days</div>
        <h2 class="font-display text-3xl md:text-4xl text-forest-900 mb-6 leading-tight">
          A childhood friendship<br />
          <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">turned project</em>
        </h2>
        <p>
          It all started in the school playground, in Saint-Didier-en-Velay.
          Étienne and Guillaume grew up together in this Velay village,
          perched on the foothills of the Massif Central, on the border of
          Haute-Loire and Loire. Each took their road — Étienne studied plant
          biotechnology in Toulouse, Guillaume cut his teeth in restaurants
          and opened a bar-restaurant in Saint-Étienne.
        </p>
        <p>
          But the Haute-Loire called them back. Its forests, its highland
          pastures, its plants. A knowledge waiting to be brought back to
          light — that of grandmothers who prepared lemon balm for the cold,
          macerated gentian for the stomach, perfumed their liqueurs with
          hyssop or southernwood. In 2021 they decided to combine their
          expertise: scientific rigour on one side, the sensitivity of
          service and taste on the other. La Brasserie des Plantes was born
          — craft, from Auvergne, uncompromising.
        </p>
      </div>
    </div>
  </section>

  <!-- Crowdfunding — Ulule -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-xl">
          <img
            src="/images/stories/duo-bouteille-nature.webp"
            alt="Étienne and Guillaume celebrating a bottle of La Brasserie des Plantes in the Haute-Loire fields"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">The launch</div>
        <h2 class="font-display text-3xl md:text-4xl text-forest-900 mb-6 leading-tight">
          Launched by the people<br />
          <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">who believed first</em>
        </h2>
        <div class="space-y-5 text-lg text-ink-700 leading-relaxed">
          <p>
            Étienne had just moved back to Haute-Loire; Guillaume had just
            <strong class="font-medium text-forest-800">sold his shares
            in the bar-restaurant to his business partner</strong> in
            Saint-Étienne. And
            <strong class="font-medium text-forest-800">we launched the whole
            thing ourselves, just the two of us, in our workshop</strong> —
            no team, no long contact list, just two childhood friends and the
            urge to bring the region's forgotten plants back to life.
          </p>
          <p>
            To actually get the project off the ground, we ran
            <strong class="font-medium text-forest-800">a crowdfunding campaign
            on Ulule</strong>. Friends from Saint-Étienne and Saint-Didier,
            curious visitors met at Velay farmers' markets, strangers who simply
            liked the pitch — each pre-ordered their first bottles or chipped
            in a few euros so we could get going.
            <strong class="font-medium text-forest-800">It's thanks to those
            people, too</strong>, that we were able to build the company.
          </p>
          <p>
            What we make is
            <strong class="font-medium text-forest-800">living heritage</strong>
            — it's meant to be shared. And we complement each other in what we do.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Forgotten plants -->
  <section class="py-20 bg-cream-50">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">The terroir</div>
        <h2 class="font-display text-3xl md:text-4xl text-forest-900 mb-6 leading-tight">
          A tribute to<br />
          <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">forgotten plants</em>
        </h2>
        <div class="space-y-5 text-lg text-ink-700 leading-relaxed">
          <p>
            Our approach boils down to one idea: give back their place to
            plants our grandmothers knew well. Lemon verbena, wild thyme
            (serpolet), caraway, lemon balm, hyssop, southernwood, yellow
            gentian, génépi, elderflower, dandelion, nettle — every liqueur
            tells its own little bouquet.
          </p>
          <p>
            Some recipes are simple, signatures of a terroir: <em>L'Herbe
            des Druides</em> uses only three plants (verbena, wild thyme,
            caraway). Others are complex blends: <em>L'Alchimie Végétale</em>
            combines <strong class="font-medium text-forest-800">27 plants,
            roots, barks and spices</strong> on its own. Across the entire
            range, we work with about <strong class="font-medium text-forest-800">forty
            botanical ingredients</strong> — aromatic, medicinal, sometimes
            bitter, always steeped in history.
          </p>
          <p>
            <a href="/en/our-plants" class="text-forest-700 font-medium hover:text-forest-900 underline decoration-forest-300 underline-offset-4">
              See every plant we work with and which liqueurs they go into →
            </a>
          </p>
        </div>
      </div>
      <div class="order-1 md:order-2">
        <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-xl">
          <img
            src="/images/stories/plantes.webp"
            alt="Aromatic and medicinal plants harvested in Haute-Loire for our craft liqueurs"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Craft -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-xl">
          <img
            src="/images/stories/etienne-degustation.webp"
            alt="Étienne checks a batch through a tasting tube in the Saint-Didier-en-Velay workshop"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">The craft</div>
        <h2 class="font-display text-3xl md:text-4xl text-forest-900 mb-6 leading-tight">
          Compose, blend,<br />
          <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">let time do the rest</em>
        </h2>
        <div class="space-y-5 text-lg text-ink-700 leading-relaxed">
          <p>
            Our plants come from <strong class="font-medium text-forest-800">foragers
            and market gardeners</strong> we pick one by one — met, questioned,
            visited. Sometimes close to the workshop, sometimes further away
            when the plant requires it (Alpine génépi, citrus, cinchona bark).
          </p>
          <p>
            No added flavouring, no preservative: craft, patience and time do
            the rest. Each bottle is filled, corked and labelled by hand —
            four hands, to be precise.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Distinctions -->
  <section class="py-20 bg-gradient-to-b from-cream-50 to-gold-500/10 border-y border-gold-500/30">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14 max-w-3xl mx-auto">
        <div class="text-xs uppercase tracking-[0.25em] text-gold-600 font-medium mb-3">Recognition</div>
        <h2 class="font-display text-3xl md:text-5xl text-forest-900 mb-6 leading-tight">
          Seven distinctions<br />
          <em class="not-italic text-gold-600 font-normal" style="font-family: var(--font-script);">in four years</em>
        </h2>
        <div class="space-y-4 text-lg text-ink-700 leading-relaxed">
          <p>
            Recognition that reaches far beyond our Velay valleys. Each of these
            medals rewards long, patient, often invisible work — three to four
            years of formulation for a finished recipe.
          </p>
          <p>
            Three liqueurs have been distinguished so far:
            <strong class="font-medium text-forest-800">L'Herbe des Druides</strong>,
            our most-medalled liqueur with <strong class="font-medium text-forest-800">three
            Gold medals at the Concours International de Lyon</strong>, Silver at
            France's Concours Général Agricole and Silver at the World Drinks
            Awards in London; <strong class="font-medium text-forest-800">Le Cerf'Gent</strong>,
            our bitter aperitif, <strong class="font-medium text-forest-800">Gold in Paris
            in 2025</strong>; and <strong class="font-medium text-forest-800">L'Essence
            des Alpes</strong>, <strong class="font-medium text-forest-800">Silver at the
            Concours International de Lyon in 2026</strong>. Without mentioning
            <em>L'Alchimie Végétale</em>, crowned World's Best Digestif.
          </p>
        </div>
      </div>

      <!-- Flagship WDA -->
      <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <div class="aspect-[16/10] rounded-3xl overflow-hidden shadow-2xl">
            <img
              src="/images/stories/world-drinks-awards-2025.webp"
              alt="L'Alchimie Végétale — World's Best Digestif 2025 at the World Drinks Awards"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gold-500/20 border border-gold-500/50 text-gold-700 text-xs font-medium tracking-[0.15em] uppercase mb-4">
            ★ World title
          </div>
          <h3 class="font-display text-2xl md:text-3xl text-forest-900 mb-4 leading-tight">
            World's Best Digestif 2025
          </h3>
          <div class="space-y-4 text-ink-700 leading-relaxed">
            <p>
              In April 2025, our flagship — <em>L'Alchimie Végétale</em>,
              50 % vol., 27 plants — was crowned <strong class="text-gold-700">World's
              Best Digestif</strong> at the World Drinks Awards in London,
              across all digestif categories.
            </p>
            <p>
              Behind this award stand three years of formulations, setbacks,
              restarts — and the conviction that craft has its place in a
              world that moves too fast.
            </p>
          </div>
          <div class="mt-6">
            <a href="/en/shop/alchimie-vegetale" class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-forest-800 hover:bg-forest-900 text-cream-100 font-medium transition-colors">
              Discover L'Alchimie Végétale
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Medals by product -->
      <div class="grid md:grid-cols-3 gap-6">
        {productsWithMedals.map((p) => (
          <article class="p-6 rounded-2xl bg-white border border-forest-100/60 hover:shadow-md transition-shadow flex flex-col">
            <div class="mb-4">
              <h3 class="font-display text-2xl text-forest-900 leading-tight mb-1">
                <a href={`/en/shop/${p.slug}`} class="hover:text-forest-700 transition-colors">
                  {p.product}
                </a>
              </h3>
              <div class="text-xs uppercase tracking-[0.2em] text-gold-600 font-medium">
                {p.tagline}
              </div>
            </div>
            {p.note && (
              <p class="text-sm text-ink-600 italic leading-relaxed mb-4">{p.note}</p>
            )}
            <ul class="space-y-2.5 flex-1">
              {p.medals.map((m) => {
                const t = tierStyles[m.tier];
                return (
                  <li class="flex items-start gap-3">
                    <span class={`flex-none mt-0.5 inline-flex items-center gap-1 px-2.5 py-1 rounded-full ${t.bg} ${t.text} text-[10px] font-medium tracking-wide uppercase`}>
                      {m.tier === 'gold' ? 'Gold' : 'Silver'} {m.year}
                    </span>
                    <span class="text-sm text-ink-700 leading-snug">{m.competition}</span>
                  </li>
                );
              })}
            </ul>
            <a href={`/en/shop/${p.slug}`} class="mt-5 pt-4 border-t border-forest-100/60 text-sm text-forest-700 font-medium hover:text-forest-900 inline-flex items-center gap-1.5">
              View the product
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </article>
        ))}
      </div>

      <!-- Innovation award -->
      <div class="mt-8 p-6 rounded-2xl bg-forest-50/60 border border-forest-200/60 flex flex-col sm:flex-row gap-5 items-start">
        <div class="flex-none inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-forest-500/15 text-forest-700">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 7h7l-5.5 4.5 2 7-6.5-4.5-6.5 4.5 2-7L2 9h7z"/></svg>
        </div>
        <div class="flex-1">
          <div class="text-xs uppercase tracking-[0.2em] text-forest-700 font-medium mb-1">Innovation award · {innovationAward.year}</div>
          <h3 class="font-display text-xl text-forest-900 leading-tight mb-1">{innovationAward.title}</h3>
          <div class="text-sm text-ink-500 mb-2">{innovationAward.subtitle}</div>
          <p class="text-sm text-ink-700 leading-relaxed">{innovationAward.what}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team — alternating layout -->
  <section class="py-24 bg-forest-50/40">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">The team</div>
        <h2 class="font-display text-4xl md:text-5xl text-forest-900 leading-tight">The hands behind the bottles</h2>
        <p class="text-ink-600 mt-4 leading-relaxed">
          Two founders, two complementary views. Everything you taste in
          the bottle has passed through one and through the other.
        </p>
      </div>

      <!-- Étienne : photo left, text right -->
      <div class="grid md:grid-cols-2 gap-12 items-center mb-20">
        <div>
          <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-xl">
            <img
              src="/images/team/portrait-etienne.webp"
              alt="Portrait of Étienne, co-founder of La Brasserie des Plantes, plant biotechnologist"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div>
          <div class="text-xs uppercase tracking-[0.25em] text-gold-600 font-medium mb-3">Co-founder</div>
          <h3 class="font-display text-4xl md:text-5xl text-forest-900 mb-4 leading-tight">Étienne</h3>
          <div class="text-sm text-forest-700 font-medium mb-5 tracking-wide">
            Plant biotechnologist · Production
          </div>
          <div class="space-y-4 text-lg text-ink-700 leading-relaxed">
            <p>
              Trained in plant biotechnology in Toulouse, Étienne is the
              nose of the house — the one who translates botany into flavour.
              He composes the recipes, picks the plants, tunes the maceration
              times.
            </p>
            <p>
              His signature: slow, ancient-school blending, by stages. It
              took him four years to stabilise <em>L'Alchimie Végétale</em>,
              the 27-plant recipe that ended up winning the world title
              in 2025.
            </p>
          </div>
        </div>
      </div>

      <!-- Guillaume : text left, photo right -->
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1">
          <div class="text-xs uppercase tracking-[0.25em] text-gold-600 font-medium mb-3">Co-founder</div>
          <h3 class="font-display text-4xl md:text-5xl text-forest-900 mb-4 leading-tight">Guillaume</h3>
          <div class="text-sm text-forest-700 font-medium mb-5 tracking-wide">
            Pairings and uses · On-trade development
          </div>
          <div class="space-y-4 text-lg text-ink-700 leading-relaxed">
            <p>
              A former restaurateur in Saint-Étienne — bar, menu, evening
              service — Guillaume thinks about moments, pairings, uses. He
              designs the cocktail recipes, the food-and-liqueur accords and
              the brand voice.
            </p>
            <p>
              He is also the one who travels across Auvergne-Rhône-Alpes to
              meet independent wine merchants, restaurants and corporate
              buyers. If a customer writes us on a Wednesday night, chances
              are Guillaume will answer.
            </p>
          </div>
        </div>
        <div class="order-1 md:order-2">
          <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-xl">
            <img
              src="/images/team/portrait-guillaume.webp"
              alt="Portrait of Guillaume, co-founder of La Brasserie des Plantes, former restaurateur"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Gallery — varied photos -->
  <section class="py-20 bg-cream-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">In pictures</div>
        <h2 class="font-display text-3xl md:text-4xl text-forest-900 leading-tight mb-4">
          Daily life<br class="sm:hidden" />
          <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">at the workshop</em>
        </h2>
        <p class="text-ink-600 leading-relaxed">
          Workshop, markets, trade shows, tastings — a few moments caught
          on our village-sized adventure.
        </p>
      </div>
      <div class="columns-2 md:columns-3 gap-4 [column-fill:_balance]">
        {galleryPhotos.map((photo) => (
          <div class="mb-4 break-inside-avoid overflow-hidden rounded-2xl shadow-sm hover:shadow-lg transition-shadow">
            <img
              src={photo.src}
              alt={photo.alt}
              class:list={[photo.aspect, 'w-full object-cover', photo.objectPos]}
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl text-forest-900 mb-6">
        Come and meet us.
      </h2>
      <p class="text-lg text-ink-700 mb-8 leading-relaxed">
        Our workshop is open in Saint-Didier-en-Velay, Wednesday to Saturday.
        We also run mixology workshops — another way to discover our liqueurs.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/en/workshops" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-forest-800 hover:bg-forest-900 text-cream-100 font-medium transition-colors">
          Our workshops
        </a>
        <a href="/en/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-forest-700/40 hover:border-forest-700 text-forest-900 font-medium transition-colors">
          Write to us
        </a>
      </div>
    </div>
  </section>
</Layout>
