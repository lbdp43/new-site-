---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { plants } from '../../data/plants';
import { plantsEn, familyLabelsEn } from '../../data/plants.en';
import { site } from '../../data/site';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Our plants', item: `${site.url}/en/our-plants` },
  ],
};

// ItemList schema — each plant is a DefinedTerm for AI search + semantic SEO
const plantsListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Plants used at La Brasserie des Plantes',
  description: 'Aromatic and medicinal plants, roots and spices used in our craft liqueurs.',
  numberOfItems: plants.length,
  inLanguage: 'en-US',
  itemListElement: plants.map((p, i) => {
    const en = plantsEn[p.name];
    return {
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'DefinedTerm',
        name: p.name,
        ...(p.latin && { alternateName: p.latin }),
        description: en?.description ?? p.description,
        inDefinedTermSet: `${site.url}/en/our-plants`,
      },
    };
  }),
};

const schema = [breadcrumbSchema, plantsListSchema];
---
<Layout
  lang="en"
  title="Our plants | Verbena, lemon balm, caraway, hyssop — La Brasserie des Plantes"
  description="Discover the plants in our liqueurs: verbena, lemon balm, caraway, hyssop, southernwood, mint, gentian… 27 botanicals from Auvergne, organically grown."
  schema={schema}
>
  <PageHeader
    kicker="Botany"
    title="The plants of<br /><em class='not-italic font-normal text-forest-600' style='font-family: var(--font-script);'>our mountains</em>"
    subtitle="Verbena, lemon balm, caraway, lemon thyme, hyssop, southernwood… More than 27 plants, roots, barks and spices go into our liqueurs. All organically grown, harvested close to Haute-Loire."
    breadcrumb={[{ label: 'Home', href: '/en/' }, { label: 'Our plants' }]}
  />

  <section class="pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="aspect-[5/2] rounded-3xl overflow-hidden shadow-xl mb-16">
        <img
          src="/images/stories/paysage-plantes.webp"
          alt="Botanical landscape in Haute-Loire — medicinal plants used by La Brasserie des Plantes"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>

      <div class="max-w-3xl mx-auto text-lg text-ink-700 leading-relaxed space-y-6 mb-20">
        <p>
          A liqueur is a landscape in a bottle. That is why we only work with
          plants whose origin we know: our own parcels, or those of neighbouring
          producers we choose one by one. Organic farming is non-negotiable.
        </p>
        <p>
          Below are twelve of the plants most often featured in our blends —
          each with its story, its season, and the liqueurs it composes.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {plants.map((plant) => {
          const en = plantsEn[plant.name];
          return (
            <article class="p-7 rounded-2xl bg-cream-50 border border-forest-100/60 hover:border-forest-300 hover:shadow-lg transition-all">
              <div class="flex items-start justify-between mb-3 gap-3">
                <div>
                  <h2 class="font-display text-2xl text-forest-900 leading-tight">{plant.name}</h2>
                  {plant.latin && (
                    <div class="text-xs italic text-ink-500 mt-1">{plant.latin}</div>
                  )}
                </div>
                <span class="text-[10px] uppercase tracking-[0.15em] text-forest-600 font-medium px-2 py-1 rounded-full bg-forest-50 whitespace-nowrap">
                  {familyLabelsEn[plant.family]}
                </span>
              </div>
              <p class="text-sm text-ink-700 leading-relaxed mb-4">{en?.description ?? plant.description}</p>
              <div class="pt-3 border-t border-forest-100/80 space-y-2">
                <div class="text-xs">
                  <span class="text-ink-500 uppercase tracking-wide">Used in</span>
                  <div class="text-forest-800 font-medium mt-0.5">{en?.usedIn ?? plant.usedIn}</div>
                </div>
                {(en?.season ?? plant.season) && (
                  <div class="text-xs">
                    <span class="text-ink-500 uppercase tracking-wide">Season</span>
                    <div class="text-ink-700 mt-0.5">{en?.season ?? plant.season}</div>
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-900 text-cream-100">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl mb-6">
        And the other fifteen?
      </h2>
      <p class="text-cream-200/80 leading-relaxed text-lg mb-8">
        Some are our little secrets — rare accords, blended for a single
        liqueur. The best way to discover them: taste.
      </p>
      <a href="/en/shop" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-cream-50 hover:bg-cream-100 text-forest-900 font-medium transition-colors">
        Explore the shop
      </a>
    </div>
  </section>
</Layout>
