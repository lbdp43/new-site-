---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { plants } from '../../data/plants';
import { plantsEn, familyLabelsEn } from '../../data/plants.en';
import { site } from '../../data/site';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Our plants', item: `${site.url}/en/our-plants` },
  ],
};

const plantsListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Plants and botanicals used at La Brasserie des Plantes',
  description:
    'Aromatic herbs, roots, barks, flowers, citrus, spices and fruits used in our craft liqueurs. Much of what we work with — the rest is an assembly secret.',
  numberOfItems: plants.length,
  inLanguage: 'en-US',
  itemListElement: plants.map((p, i) => {
    const en = plantsEn[p.name];
    return {
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'DefinedTerm',
        name: p.name,
        ...(p.latin && { alternateName: p.latin }),
        description: en?.description ?? p.description,
        inDefinedTermSet: `${site.url}/en/our-plants`,
      },
    };
  }),
};

const schema = [breadcrumbSchema, plantsListSchema];

const familyOrder = ['aromatique', 'fleur', 'racine', 'ecorce', 'agrume', 'epice', 'fruit', 'autre'] as const;
const sortedPlants = [...plants].sort((a, b) => {
  const fa = familyOrder.indexOf(a.family as typeof familyOrder[number]);
  const fb = familyOrder.indexOf(b.family as typeof familyOrder[number]);
  if (fa !== fb) return fa - fb;
  return a.name.localeCompare(b.name, 'fr');
});

---
<Layout
  lang="en"
  title="Our plants — around forty botanicals | La Brasserie des Plantes"
  description="Verbena, lemon balm, wild thyme, caraway, hyssop, gentian, génépi, elderflower, dragon fruit, almond… about forty plants, roots, barks, flowers, citrus, spices and fruits in our craft liqueurs from Haute-Loire, France."
  schema={schema}
>
  <PageHeader
    kicker="Botany"
    title="The plants behind<br /><em class='not-italic font-normal text-forest-600' style='font-family: var(--font-script);'>our liqueurs</em>"
    subtitle="Verbena, wild thyme, caraway, lemon balm, hyssop, gentian, génépi, elderflower, nettle, hemp, almond, dragon fruit… around forty botanical ingredients, many harvested a few kilometres from our workshop."
    breadcrumb={[{ label: 'Home', href: '/en/' }, { label: 'Our plants' }]}
  />

  <section class="pb-24">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Verbena video -->
      <div class="aspect-[5/2] rounded-3xl overflow-hidden shadow-xl mb-16 bg-forest-50">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/videos/plante-verveine-poster.jpg"
          aria-label="Étienne, co-founder, preparing fresh verbena — signature plant of La Brasserie des Plantes"
          class="w-full h-full object-cover"
        >
          <source src="/videos/plante-verveine.mp4" type="video/mp4" />
        </video>
      </div>

      <!-- Intro -->
      <div class="max-w-3xl mx-auto text-lg text-ink-700 leading-relaxed space-y-6 mb-16">
        <p>
          A liqueur is a landscape in a bottle. Some of our recipes rest on
          three plants — <em>L'Herbe des Druides</em>: verbena, wild thyme,
          caraway, and that's it. Some are accord trios: <em>Le Zéleste</em>
          brings together three citrus zests (yellow lemon, lime, orange);
          <em>Le Menthor</em> a trio of mints (peppermint, spearmint,
          Korean mint). And then the grand blends — <em>L'Alchimie
          Végétale</em>, <strong class="font-medium text-forest-800">27 plants, roots, barks and spices</strong>,
          crowned World's Best Digestif in 2025.
        </p>
        <p>
          Across the entire range, we work with
          <strong class="font-medium text-forest-800">around forty botanical
          ingredients</strong> — aromatics, roots, barks, flowers, citrus,
          spices, fruits. Some are grown or foraged a few kilometres from the
          workshop; others come from further afield when the plant demands it.
          Known origin every time, producer picked one by one. And of course
          <em>La Pralicoquine</em> with its caramelised almonds — because a
          gourmand liqueur has its place too.
        </p>
      </div>

      <!-- Plants grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPlants.map((plant) => {
          const en = plantsEn[plant.name];
          return (
            <article class="p-7 rounded-2xl bg-cream-50 border border-forest-100/60 hover:border-forest-300 hover:shadow-lg transition-all">
              <div class="flex items-start justify-between mb-3 gap-3">
                <div class="min-w-0">
                  <h2 class="font-display text-2xl text-forest-900 leading-tight">{plant.name}</h2>
                  {plant.latin && (
                    <div class="text-xs italic text-ink-500 mt-1">{plant.latin}</div>
                  )}
                </div>
                <span class="text-[10px] uppercase tracking-[0.15em] text-forest-600 font-medium px-2 py-1 rounded-full bg-forest-50 whitespace-nowrap">
                  {familyLabelsEn[plant.family]}
                </span>
              </div>
              {en?.role && (
                <div class="text-xs font-medium text-gold-700 mb-3 tracking-wide">
                  {en.role}
                </div>
              )}
              <p class="text-sm text-ink-700 leading-relaxed mb-4">{en?.description ?? plant.description}</p>
              <div class="pt-3 border-t border-forest-100/80 space-y-2">
                <div class="text-xs">
                  <span class="text-ink-500 uppercase tracking-wide">In our liqueurs</span>
                  <div class="text-forest-800 font-medium mt-0.5 leading-snug">{en?.usedIn ?? plant.usedIn}</div>
                </div>
                {(en?.season ?? plant.season) && (
                  <div class="text-xs">
                    <span class="text-ink-500 uppercase tracking-wide">Season</span>
                    <div class="text-ink-700 mt-0.5">{en?.season ?? plant.season}</div>
                  </div>
                )}
                {plant.signature && (
                  <div class="mt-3 inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-gold-500/15 text-gold-700 text-[10px] font-medium tracking-wide uppercase">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
                    Signature plant
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>

      <!-- Closing — we don't tell everything -->
      <div class="mt-12 max-w-3xl mx-auto text-center">
        <p class="text-base md:text-lg text-ink-600 italic leading-relaxed">
          … and a few more we keep to ourselves. Assembly secrets are part of
          the craft too.
        </p>
      </div>
    </div>
  </section>

  <!-- Our approach -->
  <section class="py-20 bg-cream-50">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">Our approach</div>
      <h2 class="font-display text-3xl md:text-4xl text-forest-900 mb-6 leading-tight">
        Terroir first,<br />
        <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">living heritage next</em>
      </h2>
      <div class="space-y-5 text-lg text-ink-700 leading-relaxed">
        <p>
          We never write a recipe without knowing where the plants come from.
          We work with <a href="/en/journal/producteurs-partenaires-bio-velay" class="text-forest-700 font-medium underline decoration-forest-300 underline-offset-4 hover:text-forest-900">foragers
          and market gardeners</a> we pick one by one: every plant has a
          grower, every grower is met.
        </p>
        <p>
          We try to source as close to home as possible — a good share of our
          plants come from Haute-Loire and neighbouring departments. Not
          always: some demand a different terroir (Alpine génépi, for
          instance), others come from further afield depending on the season
          and the quality of the moment (citrus, liquorice, cinchona bark).
          We'd rather be honest about that than promise something we
          couldn't keep for every batch.
        </p>
        <p>
          Our rule is plants first: <strong class="font-medium text-forest-800">no
          added flavouring, no preservative</strong>. The colours you see in our
          bottles always come from an ingredient that's actually drunk — vegetal
          charcoal for the deep black of Gorgeon des Machurés, cochineal for
          the natural pink of Pralicoquine, macerated red fruits for the Flèche
          Ardente, the plants' own chlorophyll for the green of Herbe des
          Druides.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-forest-900 text-cream-100">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl mb-6">
        And what's next?
      </h2>
      <p class="text-cream-200/80 leading-relaxed text-lg mb-8 max-w-xl mx-auto">
        Our list grows every season — limited editions, special cuvées,
        collaborations with new growers. The best way to discover what's
        happening in our tanks: taste.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/en/shop" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-cream-50 hover:bg-cream-100 text-forest-900 font-medium transition-colors">
          Explore the shop
        </a>
        <a href="/en/workshops" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-cream-100/40 hover:border-cream-100/70 text-cream-100 font-medium transition-colors">
          Tasting workshop
        </a>
      </div>
    </div>
  </section>
</Layout>
