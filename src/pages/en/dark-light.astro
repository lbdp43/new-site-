---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';
import { products } from '../../data/products';
import { GlowCard } from '../../components/ui/spotlight-card';

const cbdProducts = products.filter((p) => p.range === 'lumiere-obscure');

// Tasting notes for each CBD liqueur (head / heart / base)
const tastingNotes: Record<string, { head: string; heart: string; base: string }> = {
  'menthe-cbd-ortie': {
    head: 'Mentholated attack, fresh and green.',
    heart: "At the heart, the note of nettle appears — green and lightly spiced.",
    base: "At the back of the palate, the CBD: herbaceous, with a subtle reminder of green hay.",
  },
  'verveine-cbd-aurone': {
    head: 'Lemony verbena attack, fresh and bright.',
    heart: "At the heart, the signature of CBD — herbaceous, lightly buttered.",
    base: "At the back of the palate, complex southernwood with a delicate spicy lift.",
  },
  'absinthe-cbd-citron': {
    head: "Herbaceous, lightly buttered attack, carried by the hemp.",
    heart: "At the heart, fresh and tense lemon peel.",
    base: "At the back of the palate, wormwood — lightly spiced and mentholated.",
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Dark Light', item: `${site.url}/en/dark-light` },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Lumière Obscure — CBD Liqueurs',
  description:
    "La Brasserie des Plantes' CBD range. THC-free hemp, paired with mint, verbena or wormwood. A different approach to botanical relaxation.",
  url: `${site.url}/en/dark-light`,
  inLanguage: 'en-US',
};

const faq = [
  {
    q: 'Are Lumière Obscure liqueurs psychoactive?',
    a: "No. Our liqueurs contain CBD (cannabidiol), a non-psychotropic molecule legal in France. THC content stays below the legal threshold of 0.1% (French decree of 30 December 2021). You will feel the alcohol, not the THC.",
  },
  {
    q: 'What is the CBD and THC content?',
    a: 'THC: strictly less than 0.1% (French legal threshold). CBD: varies by recipe, at an aromatic dose (a few mg per glass), far below the therapeutic doses studied in laboratories. We claim no medical effect.',
  },
  {
    q: 'Can I drive after drinking them?',
    a: 'French drink-driving rules apply (0.5 g/L blood limit). CBD being non-psychotropic does not affect fitness to drive, but the alcohol in the spirit (21 to 37% vol. depending on the reference) does.',
  },
  {
    q: 'At what temperature should I serve them?',
    a: 'Always at 3°C — either very cold, or frozen after 20 minutes in the freezer. Cold rounds out the hemp and highlights the companion plant (mint, verbena or wormwood). At room temperature, the CBD dominates.',
  },
  {
    q: 'Can I give them as gifts? Are they legal?',
    a: 'Yes, without restriction: these are classic flavoured liqueurs, compliant with French and European regulations. They can be shipped via La Poste or Chronopost in metropolitan France like any alcoholic beverage.',
  },
  {
    q: 'Is it suitable to drink during pregnancy?',
    a: 'No. Our liqueurs contain alcohol (21 to 37% vol.), not recommended during pregnancy or breastfeeding, like any spirit. The presence of CBD adds extra caution: effects of CBD on the foetus are still being studied.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'en-US',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---
<Layout
  lang="en"
  title="Dark Light | CBD Liqueurs — Hemp & plants — La Brasserie des Plantes"
  description="Lumière Obscure — the CBD liqueur range (THC-free hemp) from La Brasserie des Plantes. Mint, verbena, wormwood. Ad augusta per angusta."
  schema={[breadcrumb, collectionSchema, faqSchema]}
>
  <!-- HERO NIGHT -->
  <section class="relative min-h-[100vh] w-full overflow-hidden bg-black text-[color:var(--color-moon-300)]">
    <div class="absolute inset-0 bg-gradient-to-b from-[color:var(--color-night-900)] via-[color:var(--color-night-800)] to-[color:var(--color-night-700)]"></div>
    <div class="absolute inset-0 starfield" aria-hidden="true"></div>
    <div class="absolute top-14 right-8 md:top-24 md:right-28 w-44 h-44 md:w-64 md:h-64 rounded-full bg-[color:var(--color-moon-300)] shadow-[0_0_140px_50px_rgba(233,226,196,0.35)] animate-moon-glow"></div>

    <svg class="absolute bottom-0 left-0 w-full h-64 md:h-80 text-black/80" viewBox="0 0 1440 320" preserveAspectRatio="none" aria-hidden="true">
      <path fill="currentColor" d="M0,224 L40,213 L80,224 L120,197 L160,213 L200,186 L240,208 L280,181 L320,203 L360,176 L400,197 L440,165 L480,186 L520,154 L560,176 L600,144 L640,165 L680,133 L720,154 L760,133 L800,154 L840,128 L880,149 L920,123 L960,144 L1000,117 L1040,138 L1080,112 L1120,133 L1160,101 L1200,122 L1240,96 L1280,117 L1320,101 L1360,122 L1400,112 L1440,133 L1440,320 L0,320 Z"/>
    </svg>

    <div class="relative z-10 flex flex-col items-center justify-center text-center px-6 py-24 md:py-36 min-h-[100vh]">
      <svg class="w-20 h-20 md:w-28 md:h-28 text-[color:var(--color-moon-300)] mb-8 owl-glow" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M40 8c-10 0-18 6-20 14-2 9 2 20 10 26 4 3 7 6 10 10 3-4 6-7 10-10 8-6 12-17 10-26-2-8-10-14-20-14z"/>
        <path d="M25 28c0 7 4 13 10 15M55 28c0 7-4 13-10 15"/>
        <circle cx="29" cy="32" r="4.5" fill="currentColor" opacity=".85"/>
        <circle cx="51" cy="32" r="4.5" fill="currentColor" opacity=".85"/>
        <circle cx="29" cy="32" r="1.6" fill="var(--color-night-900)"/>
        <circle cx="51" cy="32" r="1.6" fill="var(--color-night-900)"/>
        <path d="M40 40 L37 46 L43 46 Z" fill="currentColor" opacity=".9"/>
        <path d="M20 46 c-4 6 -2 14 6 18"/>
        <path d="M60 46 c4 6 2 14 -6 18"/>
        <path d="M32 56c3-1 5-1 8 0s5 1 8 0"/>
      </svg>

      <span style="font-family: var(--font-script);" class="text-[color:var(--color-moon-400)] text-3xl md:text-5xl mb-6 italic">Ad augusta per angusta</span>

      <h1 class="font-display text-6xl md:text-8xl lg:text-9xl leading-[1.02] mb-8 max-w-5xl text-[color:var(--color-moon-300)] tracking-tight">
        Lumière <em class="not-italic font-normal text-[color:var(--color-moon-400)]" style="font-family: var(--font-script);">Obscure</em>
      </h1>

      <p class="text-lg md:text-xl text-[color:var(--color-night-100)] max-w-2xl leading-relaxed mb-4 italic">
        "Let yourself be carried by the barn owl that will take you into
        the distant lands of your rational mind."
      </p>
      <p class="text-base md:text-lg text-[color:var(--color-night-100)]/80 max-w-2xl leading-relaxed mb-12">
        This craft concoction will awaken your psychic faculties.<br />
        These liqueurs are made by "La Brasserie des Plantes".
      </p>

      <a
        href="#range"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full border border-[color:var(--color-moon-400)]/60 hover:border-[color:var(--color-moon-300)] hover:bg-[color:var(--color-moon-400)]/10 text-[color:var(--color-moon-300)] font-medium transition-all backdrop-blur-sm"
      >
        Enter the night
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
      </a>
    </div>
  </section>

  <!-- PHILOSOPHY -->
  <section class="py-24 md:py-32 bg-[color:var(--color-night-900)] text-[color:var(--color-moon-300)] relative overflow-hidden border-y border-[color:var(--color-moon-400)]/10">
    <div class="absolute inset-0 starfield opacity-30" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <div class="text-[10px] md:text-xs uppercase tracking-[0.4em] text-[color:var(--color-moon-400)] font-medium mb-6">The approach</div>
      <h2 class="font-display text-4xl md:text-6xl leading-tight mb-10 text-[color:var(--color-moon-300)]">
        Three liqueurs,<br />
        <em class="not-italic text-[color:var(--color-moon-400)] font-normal" style="font-family: var(--font-script);">an invitation to the night.</em>
      </h2>
      <div class="space-y-6 text-lg md:text-xl leading-relaxed text-[color:var(--color-night-100)]">
        <p>
          Hemp — rich in CBD, THC-free — is a plant of great aromatic finesse.
          Herbaceous, lightly buttered, with a hint of green hay: it lays a
          particular vegetal foundation that we wanted to pair with three of
          our signatures — spearmint, verbena, wormwood.
        </p>
        <p>
          The night, the moon, the barn owl. <em>Ad augusta per angusta</em> —
          "to the heights, through narrow paths". A promise of elevation,
          of awakening, at the hour when the senses sharpen.
        </p>
      </div>
      <div class="mt-12 inline-flex items-center gap-3 px-6 py-3 rounded-full border border-[color:var(--color-moon-400)]/40 text-[11px] uppercase tracking-[0.25em]">
        <span class="w-2 h-2 rounded-full bg-[color:var(--color-moon-400)] animate-pulse"></span>
        CBD &lt; 0.1% · THC-free · Best served at 3°C
      </div>
    </div>
  </section>

  <!-- RANGE -->
  <section id="range" class="py-24 md:py-32 bg-gradient-to-b from-[color:var(--color-night-900)] to-black text-[color:var(--color-moon-300)]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-20 max-w-3xl mx-auto">
        <div class="text-[10px] md:text-xs uppercase tracking-[0.4em] text-[color:var(--color-moon-400)] font-medium mb-6">Three bottles, three journeys</div>
        <h2 class="font-display text-4xl md:text-6xl leading-tight text-[color:var(--color-moon-300)]">
          The<br />
          <em class="not-italic text-[color:var(--color-moon-400)] font-normal" style="font-family: var(--font-script);">Lumière Obscure</em> range
        </h2>
      </div>

      <div class="space-y-24 md:space-y-32">
        {cbdProducts.map((p, i) => {
          const t = tastingNotes[p.slug];
          return (
            <article class={`grid md:grid-cols-2 gap-12 md:gap-20 items-center ${i % 2 === 1 ? 'md:[&>div:first-child]:order-2' : ''}`}>
              <div class="relative">
                <GlowCard
                  client:visible
                  glowColor="gold"
                  customSize
                  padding="none"
                  className="aspect-[4/5] rounded-3xl overflow-hidden bg-gradient-to-br from-[color:var(--color-night-700)] via-[color:var(--color-night-800)] to-[color:var(--color-night-900)] w-full !aspect-[4/5]"
                >
                  <img
                    src={p.image}
                    alt={`${p.name} — craft CBD liqueur`}
                    class="absolute inset-0 w-full h-full object-contain p-12 md:p-16 drop-shadow-[0_0_30px_rgba(217,203,151,0.25)]"
                    loading="lazy"
                  />
                  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-56 h-56 rounded-full bg-[color:var(--color-moon-400)]/12 blur-3xl pointer-events-none"></div>
                  <span class="absolute top-5 right-5 z-10 text-xs font-medium bg-[color:var(--color-moon-400)]/15 text-[color:var(--color-moon-300)] px-3 py-1.5 rounded-full border border-[color:var(--color-moon-400)]/40 backdrop-blur-sm">
                    {p.alcohol}% vol.
                  </span>
                </GlowCard>
              </div>

              <div>
                <div class="text-[10px] uppercase tracking-[0.4em] text-[color:var(--color-moon-400)] font-medium mb-4">{`Bottle ${String(i + 1).padStart(2, '0')}`}</div>
                <h3 class="font-display text-4xl md:text-5xl text-[color:var(--color-moon-300)] leading-tight mb-4">{p.name}</h3>
                <p class="text-lg italic text-[color:var(--color-night-100)] mb-8 leading-relaxed">
                  {p.tagline}
                </p>

                {t && (
                  <div class="space-y-5 border-l-2 border-[color:var(--color-moon-400)]/40 pl-6 mb-8">
                    <div>
                      <div class="text-[10px] uppercase tracking-[0.3em] text-[color:var(--color-moon-400)] font-medium mb-2">Attack</div>
                      <p class="text-[color:var(--color-night-100)] leading-relaxed">{t.head}</p>
                    </div>
                    <div>
                      <div class="text-[10px] uppercase tracking-[0.3em] text-[color:var(--color-moon-400)] font-medium mb-2">Heart</div>
                      <p class="text-[color:var(--color-night-100)] leading-relaxed">{t.heart}</p>
                    </div>
                    <div>
                      <div class="text-[10px] uppercase tracking-[0.3em] text-[color:var(--color-moon-400)] font-medium mb-2">Back of palate</div>
                      <p class="text-[color:var(--color-night-100)] leading-relaxed">{t.base}</p>
                    </div>
                  </div>
                )}

                {p.composition && (
                  <div class="flex flex-wrap gap-2 mb-8">
                    {p.composition.map((c) => (
                      <span class="px-3 py-1.5 rounded-full text-xs bg-[color:var(--color-night-800)] border border-[color:var(--color-moon-400)]/20 text-[color:var(--color-night-100)]">
                        {c}
                      </span>
                    ))}
                  </div>
                )}

                <div class="flex flex-wrap gap-3">
                  <a
                    href={`/en/shop/${p.slug}`}
                    class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[color:var(--color-moon-400)] hover:bg-[color:var(--color-moon-300)] text-[color:var(--color-night-900)] font-medium transition-colors"
                  >
                    Discover this bottle
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                  <span class="inline-flex items-center gap-2 px-4 py-3 text-xs uppercase tracking-[0.2em] text-[color:var(--color-night-100)]">
                    Aperitif · Digestif · 3°C
                  </span>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 md:py-32 bg-[color:var(--color-night-800)] text-[color:var(--color-moon-300)] border-t border-[color:var(--color-moon-400)]/10">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-14">
        <div class="text-[10px] md:text-xs uppercase tracking-[0.35em] text-[color:var(--color-moon-400)] font-medium mb-4">
          Frequently Asked Questions
        </div>
        <h2 class="font-display text-4xl md:text-5xl leading-tight text-[color:var(--color-moon-300)]">
          What people<br />
          <em class="not-italic font-normal text-[color:var(--color-moon-400)]" style="font-family: var(--font-script);">ask us most</em>
        </h2>
      </div>
      <div class="space-y-3">
        {faq.map((item, i) => (
          <details
            class="group rounded-xl bg-[color:var(--color-night-900)]/80 border border-[color:var(--color-moon-400)]/15 overflow-hidden transition-colors hover:border-[color:var(--color-moon-400)]/40"
            {...(i === 0 ? { open: true } : {})}
          >
            <summary class="list-none cursor-pointer flex items-start justify-between gap-4 px-6 py-5 font-display text-lg md:text-xl text-[color:var(--color-moon-300)] select-none">
              <span>{item.q}</span>
              <svg class="w-5 h-5 flex-none mt-1.5 transition-transform duration-300 group-open:rotate-180 text-[color:var(--color-moon-400)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="px-6 pb-6 text-[color:var(--color-night-100)] leading-relaxed text-sm md:text-base">
              {item.a}
            </div>
          </details>
        ))}
      </div>
      <p class="mt-8 text-center text-xs text-[color:var(--color-night-100)]/70">
        A question not covered here? <a href="/en/contact" class="underline hover:text-[color:var(--color-moon-300)]">Write to us</a> — we complete this FAQ with your questions.
      </p>
    </div>
  </section>

  <!-- FINAL QUOTE -->
  <section class="py-24 md:py-32 bg-black text-[color:var(--color-moon-300)] border-t border-[color:var(--color-moon-400)]/15 relative overflow-hidden">
    <div class="absolute inset-0 starfield opacity-20" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <svg class="w-12 h-12 mx-auto mb-8 text-[color:var(--color-moon-400)]/70" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z" opacity=".7"/></svg>
      <p class="font-display italic text-2xl md:text-4xl leading-relaxed text-[color:var(--color-moon-300)] mb-6">
        "Ad augusta per angusta"
      </p>
      <p class="text-[color:var(--color-night-100)] text-lg">
        To the heights, through narrow paths.
      </p>
    </div>
  </section>
</Layout>

<style>
  .starfield {
    background-image:
      radial-gradient(1px 1px at 12% 18%, rgba(233,226,196,0.9), transparent 2px),
      radial-gradient(1.2px 1.2px at 24% 62%, rgba(233,226,196,0.8), transparent 2px),
      radial-gradient(1px 1px at 36% 28%, rgba(233,226,196,0.7), transparent 2px),
      radial-gradient(1.5px 1.5px at 48% 82%, rgba(233,226,196,0.9), transparent 2px),
      radial-gradient(1px 1px at 58% 14%, rgba(233,226,196,0.7), transparent 2px),
      radial-gradient(1.1px 1.1px at 68% 48%, rgba(233,226,196,0.8), transparent 2px),
      radial-gradient(1px 1px at 78% 8%, rgba(233,226,196,0.6), transparent 2px),
      radial-gradient(1.4px 1.4px at 85% 72%, rgba(233,226,196,0.9), transparent 2px),
      radial-gradient(1px 1px at 92% 36%, rgba(233,226,196,0.7), transparent 2px),
      radial-gradient(1.2px 1.2px at 6% 88%, rgba(233,226,196,0.8), transparent 2px),
      radial-gradient(1px 1px at 52% 45%, rgba(233,226,196,0.6), transparent 2px);
    background-size: 100% 100%;
    animation: twinkle 7s ease-in-out infinite alternate;
  }
  @keyframes twinkle {
    0% { opacity: 0.55; }
    100% { opacity: 1; }
  }

  @keyframes moon-glow {
    0%, 100% { box-shadow: 0 0 140px 50px rgba(233,226,196,0.30); }
    50%      { box-shadow: 0 0 180px 70px rgba(233,226,196,0.50); }
  }
  .animate-moon-glow { animation: moon-glow 7s ease-in-out infinite; }

  @keyframes owl-pulse {
    0%, 100% { transform: translateY(0); filter: drop-shadow(0 0 14px rgba(233,226,196,.28)); }
    50%      { transform: translateY(-5px); filter: drop-shadow(0 0 28px rgba(233,226,196,.55)); }
  }
  .owl-glow { animation: owl-pulse 4.5s ease-in-out infinite; }
</style>
