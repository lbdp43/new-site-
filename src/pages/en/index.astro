---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import InstagramFeed from '../../components/InstagramFeed.astro';
import GoogleReviewsEmbed from '../../components/GoogleReviewsEmbed.astro';
import ProductCarousel from '../../components/ProductCarousel.astro';
import { site } from '../../data/site';
import { featuredProducts, products } from '../../data/products';
import { localizedPath } from '../../i18n/utils';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
  logo: new URL('/logo.webp', site.url).toString(),
  email: site.email,
  telephone: site.phone,
  foundingDate: site.founded,
  founders: site.founders.map((f) => ({ '@type': 'Person', name: f })),
  sameAs: [site.social.instagram, site.social.facebook],
  award: `${site.award.title} ${site.award.year} — ${site.award.issuer}`,
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${site.url}#localbusiness`,
  name: site.name,
  alternateName: site.shortName,
  description: site.defaultDescription,
  image: [
    new URL('/og-default.jpg', site.url).toString(),
    new URL('/images/brand/logo-complet-fond-blanc.webp', site.url).toString(),
  ],
  logo: new URL('/images/brand/logo-complet-fond-blanc.webp', site.url).toString(),
  url: site.url,
  telephone: site.phone,
  email: site.email,
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Credit Card, Apple Pay, Google Pay, PayPal, SEPA',
  foundingDate: site.founded,
  founders: site.founders.map((f) => ({ '@type': 'Person', name: f })),
  award: `${site.award.title} ${site.award.year} — ${site.award.issuer}`,
  sameAs: [site.social.instagram, site.social.facebook, site.googleBusiness.url],
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    postalCode: site.address.postalCode,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  hasMap: site.googleBusiness.url,
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'Google Place ID',
    value: site.googleBusiness.placeId,
  },
  openingHours: site.hours,
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Wednesday', 'Friday', 'Saturday'],
      opens: '09:00',
      closes: '18:30',
    },
  ],
  areaServed: [
    { '@type': 'Country', name: 'France' },
    { '@type': 'Country', name: 'Belgium' },
    { '@type': 'Country', name: 'Switzerland' },
    { '@type': 'Country', name: 'Luxembourg' },
  ],
  vatID: site.siret,
  taxID: site.siret,
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  inLanguage: 'en-US',
  publisher: { '@id': `${site.url}#localbusiness` },
};

const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: 'Inside our workshop — La Brasserie des Plantes',
  description:
    'A tour of our plant-drying room, composition room and bottling floor at our workshop in Saint-Didier-en-Velay, Haute-Loire (France).',
  thumbnailUrl: new URL('/videos/lbdp-pro-poster.jpg', site.url).toString(),
  contentUrl: new URL('/videos/lbdp-pro.mp4', site.url).toString(),
  uploadDate: '2025-04-18',
  duration: 'PT1M32S',
  inLanguage: 'en-US',
  publisher: { '@id': `${site.url}#localbusiness` },
};

const schema = [organizationSchema, localBusinessSchema, websiteSchema, videoSchema];
---
<Layout
  lang="en"
  title="La Brasserie des Plantes — Craft liqueurs, Haute-Loire"
  description="Organic craft liqueurs from Auvergne, France. L'Alchimie Végétale: World's Best Digestif 2025 (World Drinks Awards). Made in Haute-Loire."
  schema={schema}
  hasHero={true}
>
  <!-- HERO VIDEO fullscreen — same pattern as /professionnels -->
  <section class="relative min-h-[100dvh] w-full overflow-hidden bg-forest-950">
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/videos/lbdp-pro-poster.jpg"
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="/videos/lbdp-pro.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-forest-950/70 via-forest-950/40 to-forest-950/80"></div>

    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6 text-cream-100 py-20 min-h-[100dvh]">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-500/20 border border-gold-500/50 text-gold-400 text-xs font-medium tracking-[0.2em] uppercase mb-6 backdrop-blur-sm">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
        World's Best Digestif 2025
      </div>
      <img
        src="/images/brand/logo-mark.webp"
        alt="La Brasserie des Plantes — emblem"
        width="527"
        height="600"
        class="h-24 md:h-32 lg:h-36 w-auto mb-6 drop-shadow-[0_6px_24px_rgba(0,0,0,0.45)]"
        loading="eager"
        decoding="async"
      />
      <h1 class="font-display leading-[1.05] mb-6">
        <em class="not-italic text-cream-50 font-normal block text-5xl sm:text-6xl md:text-7xl lg:text-8xl sm:whitespace-nowrap leading-[1.1]" style="font-family: var(--font-script);">La Brasserie des Plantes</em>
        <span class="text-gold-400 block text-3xl sm:text-4xl md:text-6xl lg:text-7xl mt-3 leading-tight">Craft, Terroir<br />Passion</span>
      </h1>
      <p class="text-lg md:text-xl text-cream-100/90 max-w-2xl leading-relaxed mb-10">
        From Saint-Didier-en-Velay, we craft liqueurs and infusions from the
        forgotten plants of Auvergne. L'Alchimie Végétale was named
        <strong class="text-gold-300 font-medium">World's Best Digestif 2025</strong>
        at the World Drinks Awards in London.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={localizedPath('/boutique', 'en')} class="inline-flex items-center gap-2 px-7 py-4 rounded-full bg-cream-50 text-forest-900 hover:bg-cream-100 font-medium transition-all shadow-xl">
          Visit the shop
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
        </a>
        <a href={localizedPath('/notre-histoire', 'en')} class="inline-flex items-center gap-2 px-7 py-4 rounded-full border border-cream-100/50 hover:bg-cream-100/10 text-cream-100 font-medium transition-colors backdrop-blur-sm">
          Our story
        </a>
      </div>
    </div>
  </section>

  <!-- PRODUCT CAROUSEL — quick discovery after the hero -->
  <ProductCarousel
    items={products.filter((p) => p.range !== 'accessoire')}
    kicker="Our full range"
    heading="Eighteen bottles, four collections"
    subtitle="Browse all our liqueurs, from the signature Brasserie range to the CBD Lumière Obscure line."
  />

  <!-- DIY BOX — sober editorial teaser (cream on cream) -->
  <section class="py-20 md:py-28 bg-cream-50 relative overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-forest-200 to-transparent" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-6 grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-20 items-center">
      <div>
        <div class="text-[10px] uppercase tracking-[0.35em] text-gold-600 font-medium mb-5">
          Custom gift box
        </div>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.05] text-forest-900 mb-6">
          Build<br />
          <em class="not-italic font-normal text-forest-600" style="font-family: var(--font-script);">your own box</em>
        </h2>
        <p class="text-ink-700 text-base md:text-lg leading-relaxed mb-10 max-w-md">
          Three liqueurs of your choice from our range. Our bottles stack
          naturally — a unique gift, ready to give.
        </p>
        <div class="flex flex-wrap gap-3 items-center">
          <a
            href="/en/build-your-gift-box"
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-forest-900 hover:bg-forest-800 text-cream-50 text-sm font-medium transition-colors group"
          >
            Build my box
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <a
            href="/en/shop#accessoire"
            class="inline-flex items-center gap-1.5 px-5 py-3.5 text-forest-800 hover:text-forest-900 text-sm font-medium underline decoration-gold-500 decoration-1 underline-offset-4 hover:decoration-2 transition-all"
          >
            See ready-made boxes
          </a>
        </div>
      </div>

      <div class="relative flex items-center justify-center">
        <div class="relative" style="width: 120px;">
          <!-- Top (z=3) -->
          <img
            src="/images/products/sizes/alchimie-vegetale-20cl-stack.webp"
            alt="L'Alchimie Végétale — stackable 20cl format"
            class="relative block mx-auto w-full h-auto"
            style="filter: drop-shadow(0 8px 14px rgba(10, 107, 67, 0.22)); z-index: 3;"
            loading="lazy"
          />
          <!-- Middle (z=2) -->
          <img
            src="/images/products/sizes/nectar-ostara-20cl-stack.webp"
            alt="Le Nectar d'Ostara — stackable 20cl format"
            class="relative block mx-auto w-full h-auto -mt-[27%]"
            style="filter: drop-shadow(0 8px 14px rgba(10, 107, 67, 0.22)); z-index: 2;"
            loading="lazy"
          />
          <!-- Bottom (z=1) -->
          <img
            src="/images/products/sizes/cerf-gent-20cl-stack.webp"
            alt="Le Cerf'Gent — stackable 20cl format"
            class="relative block mx-auto w-full h-auto -mt-[27%]"
            style="filter: drop-shadow(0 8px 14px rgba(10, 107, 67, 0.22)); z-index: 1;"
            loading="lazy"
          />
          <div
            class="mx-auto mt-1.5 h-2.5 rounded-full pointer-events-none"
            style="width: 85%; background: radial-gradient(ellipse, rgba(10, 107, 67, 0.28), transparent 65%);"
            aria-hidden="true"
          ></div>
        </div>
      </div>
    </div>
  </section>

  <!-- STORY -->
  <section class="py-24 bg-cream-50">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="gold-divider mb-8">
        <span class="font-display italic text-xs uppercase tracking-[0.3em] text-gold-600">Our craft</span>
      </div>
      <h2 class="font-display text-4xl md:text-5xl text-forest-900 mb-8 leading-tight">
        Forgotten plants,<br />patiently assembled.
      </h2>
      <div class="space-y-6 text-lg text-ink-700 leading-relaxed">
        <p>
          La Brasserie des Plantes was born in {site.founded} in a small village
          of the <strong class="font-medium text-forest-800">Haute-Loire</strong> region, in Saint-Didier-en-Velay.
          Two childhood friends — Étienne and Guillaume — brought together by
          a simple idea: to revive the medicinal and aromatic plants our
          grandmothers once prepared, and invite them into contemporary mixology.
        </p>
        <p>
          Étienne, a plant biotechnologist trained in Toulouse, selects,
          composes and runs production. Guillaume, a former restaurateur,
          imagines the pairings and uses. Together they work with about
          <strong class="font-medium text-forest-800">forty plants, roots, barks,
          flowers and spices</strong> — verbena, wild thyme, gentian, génépi,
          hyssop, elderflower… — all organically certified, harvested by
          foragers and market gardeners we pick one by one.
        </p>
        <p>
          In 2025, their flagship <em>L'Alchimie Végétale</em> won the title
          of <strong class="font-medium text-gold-600">World's Best Digestif</strong>
          at the World Drinks Awards — international recognition
          for a discreet terroir, confirmed by the palate of the world's finest juries.
        </p>
      </div>
      <div class="mt-10 flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm">
        <a href={localizedPath('/notre-histoire', 'en')} class="inline-flex items-center gap-1.5 text-forest-700 hover:text-forest-900 font-medium border-b border-forest-300 hover:border-forest-700 pb-0.5 transition-colors">
          Our story
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href={localizedPath('/nos-plantes', 'en')} class="inline-flex items-center gap-1.5 text-forest-700 hover:text-forest-900 font-medium border-b border-forest-300 hover:border-forest-700 pb-0.5 transition-colors">
          All our plants
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href={localizedPath('/lumiere-obscure', 'en')} class="inline-flex items-center gap-1.5 text-forest-700 hover:text-forest-900 font-medium border-b border-forest-300 hover:border-forest-700 pb-0.5 transition-colors">
          CBD range — Lumière Obscure
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href={localizedPath('/ateliers', 'en')} class="inline-flex items-center gap-1.5 text-forest-700 hover:text-forest-900 font-medium border-b border-forest-300 hover:border-forest-700 pb-0.5 transition-colors">
          Book a workshop
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- LONG-FORM VIDEO — same as the trade page -->
  <section class="relative py-0 bg-forest-950 overflow-hidden">
    <div class="relative w-full aspect-[21/9] md:aspect-[21/8] max-h-[85vh]">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/videos/lbdp-intro-poster.jpg"
        class="absolute inset-0 w-full h-full object-cover"
      >
        <source src="/videos/lbdp-intro.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-b from-forest-950/65 via-forest-950/25 to-forest-950/80"></div>
      <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6 text-cream-100">
        <span style="font-family: var(--font-script);" class="text-gold-400 text-3xl md:text-4xl mb-3">— Inside our workshop —</span>
        <h2 class="font-display text-4xl md:text-6xl leading-tight max-w-4xl mb-4 text-cream-100">
          Each bottle, a story<br /><em class="not-italic text-gold-400 font-normal" style="font-family: var(--font-script);">made by hand</em>
        </h2>
        <p class="text-cream-100/85 text-base md:text-lg max-w-2xl leading-relaxed">
          Harvest, composition, blending, bottling — everything happens
          in Saint-Didier-en-Velay, between our four hands.
        </p>
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="py-24 bg-gradient-to-b from-forest-50/50 to-cream-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
        <div>
          <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">Selection</div>
          <h2 class="font-display text-4xl md:text-5xl text-forest-900 leading-tight">Six bottles to discover</h2>
        </div>
        <a href={localizedPath('/boutique', 'en')} class="inline-flex items-center gap-2 text-forest-700 hover:text-forest-900 font-medium">
          See all products
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
        {featuredProducts.map((p) => <ProductCard product={p} />)}
      </div>
    </div>
  </section>

  <!-- COCKTAILS -->
  <section class="py-24 bg-cream-100/60">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">Mixology</div>
        <h2 class="font-display text-4xl md:text-5xl text-forest-900 mb-6 leading-tight">
          Our liqueurs<br />in cocktails
        </h2>
        <p class="text-lg text-ink-700 leading-relaxed mb-8">
          Five recipes crafted in-house — from the Spritz Efflorescent to
          the Black Mule, by way of the Philtre d'Éros. Each cocktail
          showcases one of our liqueurs.
        </p>
        <a href={localizedPath('/cocktails', 'en')} class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-forest-700/40 hover:border-forest-700 text-forest-900 font-medium transition-colors">
          Discover the recipes
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <a href={`${localizedPath('/cocktails', 'en')}#spritz-efflorescent`} class="group aspect-square rounded-2xl overflow-hidden relative bg-forest-50 hover:shadow-xl transition-shadow">
          <img src="/images/cocktails/spritz-efflorescent.webp" alt="Le Spritz Efflorescent cocktail" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest-900/80 via-forest-900/20 to-transparent"></div>
          <h3 class="absolute bottom-4 left-4 right-4 font-display text-lg text-cream-50 leading-tight">Spritz Efflorescent</h3>
        </a>
        <a href={`${localizedPath('/cocktails', 'en')}#verveine-printaniere`} class="group aspect-square rounded-2xl overflow-hidden relative mt-8 bg-forest-50 hover:shadow-xl transition-shadow">
          <img src="/images/cocktails/verveine-printaniere.webp" alt="La Verveine Printanière cocktail" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest-900/80 via-forest-900/20 to-transparent"></div>
          <h3 class="absolute bottom-4 left-4 right-4 font-display text-lg text-cream-50 leading-tight">Verveine Printanière</h3>
        </a>
        <a href={`${localizedPath('/cocktails', 'en')}#philtre-eros`} class="group aspect-square rounded-2xl overflow-hidden relative bg-forest-50 hover:shadow-xl transition-shadow">
          <img src="/images/cocktails/philtre-eros.webp" alt="Le Philtre d'Éros cocktail" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest-900/80 via-forest-900/20 to-transparent"></div>
          <h3 class="absolute bottom-4 left-4 right-4 font-display text-lg text-cream-50 leading-tight">Philtre d'Éros</h3>
        </a>
        <a href={`${localizedPath('/cocktails', 'en')}#black-mule`} class="group aspect-square rounded-2xl overflow-hidden relative mt-8 bg-forest-50 hover:shadow-xl transition-shadow">
          <img src="/images/cocktails/black-mule.webp" alt="Le Black Mule cocktail" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest-900/80 via-forest-900/20 to-transparent"></div>
          <h3 class="absolute bottom-4 left-4 right-4 font-display text-lg text-cream-50 leading-tight">Black Mule</h3>
        </a>
      </div>
    </div>
  </section>

  <!-- GOOGLE REVIEWS — live via Featurable when widgetId is set, internal fallback otherwise -->
  <GoogleReviewsEmbed />

  <!-- INSTAGRAM -->
  <InstagramFeed variant="light" />

  <!-- FINAL CTA -->
  <section class="py-24 bg-gradient-to-br from-forest-800 via-forest-900 to-forest-950 text-cream-100 relative overflow-hidden">
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <span style="font-family: var(--font-script);" class="text-gold-400 text-2xl">— At your table —</span>
      <h2 class="font-display text-4xl md:text-5xl mt-4 mb-6 leading-tight text-cream-100">
        Bring a botanical pause<br />to your evenings.
      </h2>
      <p class="text-cream-200/80 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
        Individual bottles, discovery boxes, limited editions — free shipping
        above €65, dispatched within 2 to 3 business days across France.
      </p>
      <a href={localizedPath('/boutique', 'en')} class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-cream-50 hover:bg-cream-100 text-forest-900 font-medium transition-all hover:shadow-2xl">
        Explore the shop
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</Layout>
