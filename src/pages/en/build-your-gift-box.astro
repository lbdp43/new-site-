---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CoffretBuilder, { type CoffretProduct } from '../../components/coffret/CoffretBuilder';
import { products } from '../../data/products';
import { site } from '../../data/site';

// Same filter as FR: 20cl stackable bottles only (no accessories, no limited
// editions — those don't come in 20cl format).
const eligibleProducts: CoffretProduct[] = products
  .filter(
    (p) =>
      p.range !== 'accessoire' &&
      p.range !== 'edition-limitee' &&
      p.wcId !== undefined
  )
  .map((p) => ({
    slug: p.slug,
    name: p.name,
    range: p.range,
    priceMin: p.priceMin,
    image: p.image,
    // Pre-cropped stack image (see scripts/crop-stack-images.mjs).
    stackImage: p.sizeImages?.[20]
      ? p.sizeImages[20].replace('-20cl.webp', '-20cl-stack.webp')
      : undefined,
    alcohol: p.alcohol,
    tagline: p.tagline,
    wcId: p.wcId as number,
    defaultSize: p.sizeImages?.[20]
      ? 20
      : p.sizes && p.sizes.length > 0
        ? parseInt(p.sizes[0])
        : undefined,
    wcSizeAttribute: p.wcSizeAttribute,
  }));

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Build your gift box', item: `${site.url}/en/build-your-gift-box` },
  ],
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Custom gift box — 3 bottles of your choice',
  description: "Build your own gift box: 3 craft liqueurs of your choice from La Brasserie des Plantes' range of 18 bottles. Stackable bottles, free shipping above €65.",
  image: new URL('/images/products/sizes/alchimie-vegetale-20cl-stack.webp', site.url).toString(),
  brand: { '@type': 'Brand', name: site.name },
  inLanguage: 'en-US',
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'EUR',
    lowPrice: '48',
    highPrice: '210',
    availability: 'https://schema.org/InStock',
    offerCount: eligibleProducts.length,
  },
};

const schema = [breadcrumb, productSchema];
---
<Layout
  lang="en"
  title="Build your gift box | 3 bottles of your choice — La Brasserie des Plantes"
  description="Create your own gift box: choose any 3 craft liqueurs from our range of 18 bottles. Stackable bottles, ready to give. Free shipping above €65."
  schema={schema}
>
  <PageHeader
    kicker="Custom gift box"
    title="Build<br /><em class='not-italic font-normal text-forest-600' style='font-family: var(--font-script);'>your own box</em>"
    subtitle="Three bottles of your choice from our full range. Our bottles stack naturally — a unique gift, ready to give or to keep."
    breadcrumb={[{ label: 'Home', href: '/en/' }, { label: 'Build your gift box' }]}
  />

  <section class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Explanation — 3 steps -->
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 rounded-2xl bg-cream-50 border border-forest-100/60">
          <div class="w-10 h-10 rounded-full bg-forest-100 text-forest-700 flex items-center justify-center mb-3 font-display text-lg">1</div>
          <h3 class="font-display text-lg text-forest-900 mb-1">Stack your bottles</h3>
          <p class="text-sm text-ink-700 leading-relaxed">3 or more, your choice. Click any bottle — digestifs, aperitifs, CBD infusions, limited editions.</p>
        </div>
        <div class="p-6 rounded-2xl bg-cream-50 border border-forest-100/60">
          <div class="w-10 h-10 rounded-full bg-forest-100 text-forest-700 flex items-center justify-center mb-3 font-display text-lg">2</div>
          <h3 class="font-display text-lg text-forest-900 mb-1">Stackable 20 cl format</h3>
          <p class="text-sm text-ink-700 leading-relaxed">Our patented format that stacks naturally — prepared in our workshop in Saint-Didier-en-Velay.</p>
        </div>
        <div class="p-6 rounded-2xl bg-cream-50 border border-forest-100/60">
          <div class="w-10 h-10 rounded-full bg-forest-100 text-forest-700 flex items-center justify-center mb-3 font-display text-lg">3</div>
          <h3 class="font-display text-lg text-forest-900 mb-1">Fast shipping</h3>
          <p class="text-sm text-ink-700 leading-relaxed">Free shipping above €65, dispatched within 2 to 3 business days across France.</p>
        </div>
      </div>

      <!-- Builder (stack + grid + suggested trios included) -->
      <CoffretBuilder products={eligibleProducts} size={3} lang="en" client:load />
    </div>
  </section>
</Layout>
