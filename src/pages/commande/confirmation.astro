---
import Layout from '../../layouts/Layout.astro';

const url = new URL(Astro.request.url);
const order = url.searchParams.get('order') ?? '';
const orderKey = url.searchParams.get('key') ?? '';
---

<Layout
  title="Commande confirmée"
  description="Merci pour votre commande — La Brasserie des Plantes"
  noindex
>
  <section class="bg-cream-50 min-h-[60vh] py-20">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-forest-800 text-cream-50 mb-6">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </div>

      <div class="text-xs uppercase tracking-[0.25em] text-gold-600 font-medium mb-3">
        Commande confirmée
      </div>

      <h1 class="font-display text-4xl md:text-5xl text-forest-900 mb-5">
        Merci pour votre commande
      </h1>

      {order && (
        <p class="text-ink-700 mb-3">
          Numéro de commande : <span class="font-medium text-forest-900">#{order}</span>
        </p>
      )}

      <p class="text-ink-700 max-w-xl mx-auto mb-10 leading-relaxed">
        Un e-mail de confirmation vient de vous être envoyé avec le récapitulatif
        de votre commande. Nous préparons votre colis et vous recevrez le suivi
        dès son expédition (sous 2 à 3 jours ouvrés).
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/boutique"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-forest-800 hover:bg-forest-900 text-cream-100 font-medium"
        >
          Continuer mes achats
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-forest-700/40 hover:border-forest-700 text-forest-900 font-medium"
        >
          Une question ?
        </a>
      </div>

      <div class="mt-16 pt-10 border-t border-forest-100 text-sm text-ink-500">
        <p>L'abus d'alcool est dangereux pour la santé — à consommer avec modération.</p>
      </div>
    </div>
  </section>
</Layout>
