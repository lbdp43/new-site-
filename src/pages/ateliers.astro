---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { site } from '../data/site';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Ateliers', item: `${site.url}/ateliers` },
  ],
};

// Service schema (plutôt qu'Event — pas de date fixe requise, récurrent)
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: "Atelier dégustation & mixologie — La Brasserie des Plantes",
  description:
    "Découverte des liqueurs artisanales, initiation à la mixologie, dégustation commentée par les fondateurs. 2h en petit comité, à Saint-Didier-en-Velay.",
  provider: { '@id': `${site.url}#localbusiness` },
  areaServed: {
    '@type': 'Place',
    name: site.address.region,
  },
  serviceType: 'Atelier mixologie & dégustation',
  offers: {
    '@type': 'Offer',
    url: 'https://www.wecandoo.fr/artisan/la-brasserie-des-plantes',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'EUR',
  },
};
---
<Layout
  title="Ateliers dégustation & mixologie | La Brasserie des Plantes"
  description="Venez découvrir l'univers des liqueurs artisanales à Saint-Didier-en-Velay. Ateliers de mixologie en petit comité, dégustation commentée, visite de l'atelier."
  schema={[breadcrumb, serviceSchema]}
>
  <PageHeader
    kicker="Ateliers"
    title="Vivre<br /><em class='not-italic font-normal text-forest-600' style='font-family: var(--font-script);'>la Brasserie</em>"
    subtitle="Deux heures dans notre atelier, à découvrir nos plantes, goûter nos liqueurs et créer vos propres cocktails sous l'œil des fondateurs."
    breadcrumb={[{ label: 'Accueil', href: '/' }, { label: 'Ateliers' }]}
  />

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="aspect-[5/2] rounded-3xl overflow-hidden shadow-xl mb-16">
        <img
          src="/images/stories/atelier-1.jpg"
          alt="Atelier dégustation à la Brasserie des Plantes, Saint-Didier-en-Velay"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-16">
        <div class="p-8 rounded-2xl bg-cream-50 border border-forest-100/60">
          <div class="w-12 h-12 rounded-full bg-forest-100 text-forest-700 flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="font-display text-xl text-forest-900 mb-2">2 heures</h3>
          <p class="text-sm text-ink-700 leading-relaxed">
            Un temps long, une pause dans la journée — le rythme de l'artisanat.
          </p>
        </div>
        <div class="p-8 rounded-2xl bg-cream-50 border border-forest-100/60">
          <div class="w-12 h-12 rounded-full bg-forest-100 text-forest-700 flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="font-display text-xl text-forest-900 mb-2">Petit comité</h3>
          <p class="text-sm text-ink-700 leading-relaxed">
            6 à 10 personnes maximum, pour que chacun puisse échanger et
            expérimenter.
          </p>
        </div>
        <div class="p-8 rounded-2xl bg-cream-50 border border-forest-100/60">
          <div class="w-12 h-12 rounded-full bg-forest-100 text-forest-700 flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <h3 class="font-display text-xl text-forest-900 mb-2">Avec les fondateurs</h3>
          <p class="text-sm text-ink-700 leading-relaxed">
            Étienne, Guillaume ou Bastien animent personnellement chaque atelier.
          </p>
        </div>
      </div>

      <div class="max-w-3xl mx-auto prose prose-lg text-ink-700 leading-relaxed space-y-6">
        <h2 class="font-display text-3xl md:text-4xl text-forest-900 mb-4">Le programme</h2>
        <p>
          Vous êtes accueillis à l'atelier avec un apéritif maison — un spritz
          au Nectar d'Ostara, le plus souvent. S'ensuit une présentation
          des plantes que nous utilisons, dans l'ordre des saisons, avec les
          histoires qui vont avec : pourquoi le carvi, pourquoi l'hysope, ce
          que nous cherchons chez une mélisse.
        </p>
        <p>
          Vous dégustez ensuite quatre de nos liqueurs phares, pures et en
          cocktail. Puis, place au shaker : chacun compose sa création, guidé
          par nos conseils. Vous repartez avec vos recettes et quelques idées
          pour vos propres soirées.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-900 text-cream-100">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-4xl mb-6">Réserver un atelier</h2>
      <p class="text-cream-200/80 text-lg mb-10 leading-relaxed">
        Nos ateliers sont proposés via <strong>Wecandoo</strong>, notre
        partenaire expériences. Réservation en quelques clics, cadeau possible.
      </p>
      <a
        href="https://www.wecandoo.fr/artisan/la-brasserie-des-plantes"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-cream-50 hover:bg-cream-100 text-forest-900 font-medium transition-colors"
      >
        Voir les dates et réserver
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </section>
</Layout>
