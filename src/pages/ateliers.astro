---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
import reviewsData from '../data/wecandoo-reviews.json';

/**
 * Page Ateliers — reprend les 2 ateliers Wecandoo :
 *   1. Réalisez votre liqueur artisanale (75 € · 2h · 2-6 pers · 20 avis)
 *   2. Dégustez des liqueurs d'exception (17 € · 1h30 · 2-7 pers · 3 avis)
 *
 * Toutes les données (descriptions, déroulés, prix, photos) et les avis
 * clients proviennent des pages Wecandoo officielles — fetchés et
 * intégrés localement pour que l'atelier reste découvrable depuis notre
 * site même sans connaissance préalable de Wecandoo.
 */

const WECANDOO_LIQUEUR = 'https://wecandoo.fr/atelier/saint-etienne-etienne-guillaume-liqueurs';
const WECANDOO_VISITE = 'https://wecandoo.fr/atelier/saint-etienne-etienne-guillaume-liqueurs-visite';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Ateliers', item: `${site.url}/ateliers` },
  ],
};

// Schema Event pour les 2 ateliers — aide à l'indexation "ateliers near me"
const workshopsSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: 'Réalisez votre liqueur artisanale',
    description: "Initiez-vous à la production de spiritueux et fabriquez votre propre liqueur artisanale avec Étienne, artisan liquoriste.",
    location: {
      '@type': 'Place',
      name: 'La Brasserie des Plantes',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '18 Grand Place',
        addressLocality: 'Saint-Didier-en-Velay',
        postalCode: '43140',
        addressRegion: 'Haute-Loire',
        addressCountry: 'FR',
      },
    },
    offers: {
      '@type': 'Offer',
      price: '75',
      priceCurrency: 'EUR',
      url: WECANDOO_LIQUEUR,
      availability: 'https://schema.org/InStock',
    },
    duration: 'PT2H',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    organizer: { '@type': 'Organization', name: site.name, url: site.url },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: "Dégustez des liqueurs d'exception",
    description: "Découvrez les secrets de la macération et dégustez six liqueurs exceptionnelles avec Étienne.",
    location: {
      '@type': 'Place',
      name: 'La Brasserie des Plantes',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '18 Grand Place',
        addressLocality: 'Saint-Didier-en-Velay',
        postalCode: '43140',
        addressRegion: 'Haute-Loire',
        addressCountry: 'FR',
      },
    },
    offers: {
      '@type': 'Offer',
      price: '17',
      priceCurrency: 'EUR',
      url: WECANDOO_VISITE,
      availability: 'https://schema.org/InStock',
    },
    duration: 'PT1H30M',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    organizer: { '@type': 'Organization', name: site.name, url: site.url },
  },
];

const workshops = [
  {
    id: 'liqueur',
    kicker: 'Atelier pratique',
    title: 'Réalisez votre liqueur artisanale',
    subtitle: "Initiez-vous à la production de spiritueux et fabriquez votre liqueur avec Étienne, artisan liquoriste.",
    price: 75,
    duration: '2 h',
    participants: '2 à 6 personnes',
    ageMin: 18,
    language: 'Français',
    includes: [
      '2 h de découverte avec Étienne',
      'Des connaissances en fabrication de liqueur',
      'Votre liqueur artisanale (50 cl) à emporter',
    ],
    steps: [
      "Visite du lieu de macération où vous allez travailler.",
      "Dégustation des 6 liqueurs de la gamme Brasserie des Plantes.",
      "Choix de vos arômes et saveurs parmi une belle sélection de plantes — Étienne vous guide pour le dosage.",
      "Création de votre liqueur dans un bocal type Parfait de 1 L (vous repartez avec 50 cl).",
      "Transmission de toutes les instructions pour l'améliorer chez vous : temps de repos, dosage en sucre, mise en bouteille.",
    ],
    image: '/images/ateliers/liqueur-2.jpg',
    gallery: ['/images/ateliers/liqueur-1.jpg', '/images/ateliers/liqueur-3.jpg', '/images/ateliers/liqueur-4.jpg', '/images/ateliers/liqueur-5.jpg'],
    bookingUrl: WECANDOO_LIQUEUR,
  },
  {
    id: 'visite',
    kicker: 'Visite & dégustation',
    title: "Dégustez des liqueurs d'exception",
    subtitle: "Découvrez les secrets de la macération et dégustez six liqueurs exceptionnelles avec Étienne — 1 h 30 dans les coulisses de la maison.",
    price: 17,
    duration: '1 h 30',
    participants: '2 à 7 personnes',
    ageMin: 18,
    language: 'Français',
    includes: [
      '1 h 30 de découverte avec Étienne',
      'Des connaissances en fabrication de liqueur',
      'Une savoureuse dégustation de 6 liqueurs',
    ],
    steps: [
      "Accueil en boutique : présentation par Étienne, introduction aux plantes et à la création des liqueurs.",
      "Dégustation des 6 liqueurs de la gamme — différents arômes et caractères.",
      "Passage en laboratoire : les cuves, le procédé de macération expliqué dans le détail.",
      "Questions-réponses autour de la conservation et de la mise en bouteille.",
    ],
    image: '/images/ateliers/visite-1.jpg',
    gallery: ['/images/ateliers/visite-2.jpg', '/images/ateliers/visite-3.jpg', '/images/ateliers/visite-4.jpg', '/images/ateliers/visite-5.jpg'],
    flipped: true, // image à droite, texte à gauche (alternance visuelle)
    bookingUrl: WECANDOO_VISITE,
  },
];

// Fusion avis des 2 ateliers pour un mur social unique, triés date desc.
type Review = { name: string; date: string; content: string; workshop: string };
const allReviews: Review[] = [
  ...reviewsData.liqueur.map((r) => ({ ...r, workshop: 'Atelier liqueur' })),
  ...reviewsData.visite.map((r) => ({ ...r, workshop: 'Visite & dégustation' })),
].sort((a, b) => b.date.localeCompare(a.date));

// Format date FR courte
const fmtDate = (iso: string) => {
  if (!iso) return '';
  try {
    return new Date(iso).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
  } catch {
    return iso.slice(0, 7);
  }
};
---
<Layout
  title="Ateliers & dégustations liqueurs — La Brasserie des Plantes"
  description="Deux ateliers en Haute-Loire avec Étienne : fabriquez votre liqueur (2h, 75 €) ou visite-dégustation de six liqueurs (1h30, 17 €). 23 avis clients."
  schema={[breadcrumb, ...workshopsSchema]}
>
  <!-- HERO — vidéo YouTube Wecandoo en fond (3H8FSvDwjnM) + contenu sur overlay
       doux pour garder la vidéo bien visible. -->
  <section class="relative min-h-[70vh] md:min-h-[80vh] overflow-hidden bg-forest-950 flex items-end">
    <!-- YouTube bg, responsive via wrapper 16:9 recouvrant toute la section -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <iframe
        src="https://www.youtube.com/embed/3H8FSvDwjnM?autoplay=1&mute=1&loop=1&playlist=3H8FSvDwjnM&controls=0&modestbranding=1&rel=0&showinfo=0&iv_load_policy=3&playsinline=1"
        title="Atelier La Brasserie des Plantes — vidéo Wecandoo"
        allow="autoplay; encrypted-media; picture-in-picture"
        allowfullscreen
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 min-w-full min-h-full"
        style="width: 177.78vh; height: 56.25vw; border: 0;"
      ></iframe>
    </div>
    <!-- Ombrage 2 couches : une teinte globale qui unifie + un dégradé plus
         marqué côté texte (en bas-gauche) pour que la typo blanche ressorte
         sans complètement cacher la vidéo. -->
    <div class="absolute inset-0 bg-forest-950/35 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-tr from-forest-950/85 via-forest-950/50 to-transparent pointer-events-none"></div>

    <div class="relative z-10 w-full max-w-6xl mx-auto px-6 py-16 md:py-24 text-cream-50">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gold-500/30 border border-gold-500/60 text-gold-300 text-xs font-medium tracking-[0.2em] uppercase mb-6 backdrop-blur-sm">
        Ateliers & dégustations
      </div>
      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl leading-[1.05] mb-6 max-w-3xl text-cream-50" style="text-shadow: 0 3px 28px rgba(0,0,0,0.75), 0 1px 2px rgba(0,0,0,0.5);">
        Venez créer votre liqueur,<br />
        <em class="not-italic text-gold-300 font-normal" style="font-family: var(--font-script); text-shadow: 0 3px 28px rgba(0,0,0,0.75), 0 1px 2px rgba(0,0,0,0.5);">ou simplement déguster.</em>
      </h1>
      <p class="text-lg md:text-xl text-cream-50 max-w-2xl leading-relaxed mb-8" style="text-shadow: 0 2px 16px rgba(0,0,0,0.8), 0 1px 2px rgba(0,0,0,0.5);">
        Étienne ouvre l'atelier de Saint-Didier-en-Velay aux curieux. Deux
        formats : un atelier pratique de 2&nbsp;h pour fabriquer votre propre
        liqueur (75&nbsp;€), et une visite-dégustation de 1&nbsp;h&nbsp;30
        pour découvrir les coulisses de la maison (17&nbsp;€).
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="#workshops" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-cream-50 text-forest-900 hover:bg-cream-100 font-medium transition-colors">
          Nos deux ateliers
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <a href={WECANDOO_LIQUEUR} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-cream-100/50 hover:bg-cream-100/10 text-cream-100 font-medium transition-colors backdrop-blur-sm">
          Voir dates et réserver
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- LES DEUX ATELIERS -->
  <section id="workshops" class="py-20 md:py-24 bg-cream-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14 max-w-3xl mx-auto">
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">
          Deux formats
        </div>
        <h2 class="font-display text-4xl md:text-5xl text-forest-900 leading-tight mb-5">
          L'atelier, ou la dégustation
        </h2>
        <p class="text-lg text-ink-700 leading-relaxed">
          Selon le temps et l'envie : fabriquez votre propre liqueur (format
          long, main à la pâte) ou venez plutôt pour une visite commentée
          suivie d'une dégustation des six liqueurs maison.
        </p>
      </div>

      <div class="space-y-10">
        {workshops.map((w) => (
          <article id={w.id} class="bg-white rounded-3xl overflow-hidden border border-forest-100/60 shadow-sm">
            <div class="grid lg:grid-cols-2">
              <!-- Image principale (ordre alterné selon w.flipped) -->
              <div class={`aspect-[4/3] lg:aspect-auto lg:min-h-[400px] relative overflow-hidden bg-forest-950 ${w.flipped ? 'lg:order-2' : ''}`}>
                <img
                  src={w.image}
                  alt={w.title}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="lazy"
                />
                <div class="absolute top-4 left-4 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-forest-900/80 backdrop-blur-sm text-cream-100 text-xs font-medium tracking-wider uppercase">
                  {w.kicker}
                </div>
                <div class="absolute bottom-4 right-4 inline-flex items-center gap-1 px-3 py-1.5 rounded-full bg-gold-500 text-cream-50 text-sm font-bold">
                  {w.price} €
                </div>
              </div>

              <!-- Contenu (ordre alterné selon w.flipped) -->
              <div class={`p-7 md:p-10 flex flex-col ${w.flipped ? 'lg:order-1' : ''}`}>
                <h3 class="font-display text-3xl md:text-4xl text-forest-900 leading-tight mb-3">
                  {w.title}
                </h3>
                <p class="text-ink-700 leading-relaxed mb-6">{w.subtitle}</p>

                <!-- Stats rapides -->
                <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6 pb-6 border-b border-forest-100">
                  <div>
                    <dt class="text-[10px] uppercase tracking-wider text-ink-500 mb-0.5">Durée</dt>
                    <dd class="font-display text-base text-forest-900">{w.duration}</dd>
                  </div>
                  <div>
                    <dt class="text-[10px] uppercase tracking-wider text-ink-500 mb-0.5">Groupe</dt>
                    <dd class="font-display text-base text-forest-900">{w.participants}</dd>
                  </div>
                  <div>
                    <dt class="text-[10px] uppercase tracking-wider text-ink-500 mb-0.5">Âge min</dt>
                    <dd class="font-display text-base text-forest-900">{w.ageMin} ans</dd>
                  </div>
                  <div>
                    <dt class="text-[10px] uppercase tracking-wider text-ink-500 mb-0.5">Langue</dt>
                    <dd class="font-display text-base text-forest-900">{w.language}</dd>
                  </div>
                </dl>

                <!-- Ce qui est inclus -->
                <div class="mb-6">
                  <div class="text-[11px] uppercase tracking-wider text-gold-600 font-medium mb-3">Inclus dans votre place</div>
                  <ul class="space-y-2 text-sm text-ink-700">
                    {w.includes.map((inc) => (
                      <li class="flex items-start gap-2.5">
                        <svg class="w-4 h-4 text-gold-600 flex-none mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                        <span>{inc}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- Déroulé -->
                <details class="mb-6 group">
                  <summary class="list-none cursor-pointer flex items-center justify-between gap-4 text-sm font-medium text-forest-800 py-2 border-y border-forest-100">
                    <span>Le déroulé, étape par étape</span>
                    <svg class="w-4 h-4 text-forest-600 transition-transform duration-300 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <ol class="mt-4 space-y-3">
                    {w.steps.map((step, idx) => (
                      <li class="flex gap-3 text-sm text-ink-700">
                        <span class="flex-none w-6 h-6 rounded-full bg-forest-800 text-cream-100 text-xs flex items-center justify-center font-medium">{idx + 1}</span>
                        <span class="pt-0.5 leading-relaxed">{step}</span>
                      </li>
                    ))}
                  </ol>
                </details>

                <!-- CTA -->
                <div class="mt-auto flex flex-wrap gap-3">
                  <a href={w.bookingUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-forest-800 hover:bg-forest-900 text-cream-100 font-medium transition-colors">
                    Voir dates et réserver
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                  </a>
                </div>
              </div>
            </div>

            <!-- Galerie photos mini (3-4 vignettes) -->
            {w.gallery && w.gallery.length > 0 && (
              <div class="grid grid-cols-2 md:grid-cols-4 gap-1 bg-forest-100/40">
                {w.gallery.map((src) => (
                  <div class="aspect-[4/3] overflow-hidden">
                    <img src={src} alt="" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
                  </div>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- LIEU — adresse + accès -->
  <section class="py-20 bg-white border-y border-forest-100/60">
    <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">
          Où ça se passe
        </div>
        <h2 class="font-display text-3xl md:text-4xl text-forest-900 leading-tight mb-5">
          18 Grand Place,<br /><em class="not-italic font-normal text-forest-600" style="font-family: var(--font-script);">Saint-Didier-en-Velay</em>
        </h2>
        <p class="text-ink-700 leading-relaxed mb-6">
          Notre atelier est installé dans une ancienne boulangerie, au cœur
          du village. La brasserie est à <strong>30 minutes de Saint-Étienne</strong>
          en voiture, environ 1 h 15 de Lyon.
        </p>
        <div class="space-y-2 text-sm text-ink-700 mb-6">
          <div><strong class="text-forest-800">Adresse</strong> : 18 Grand Place, 43140 Saint-Didier-en-Velay, Haute-Loire</div>
          <div><strong class="text-forest-800">Accès</strong> : en voiture uniquement (pas de gare sur la commune)</div>
          <div><strong class="text-forest-800">Parking</strong> : Place du village, gratuit</div>
        </div>
        <a
          href="https://www.google.com/maps/search/?api=1&query=18+Grand+Place+43140+Saint-Didier-en-Velay"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-forest-700/40 hover:border-forest-700 text-forest-900 text-sm font-medium transition-colors"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Voir sur Google Maps
        </a>
      </div>
      <div class="aspect-square rounded-2xl overflow-hidden bg-forest-950">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/videos/boutique-sortie-poster.jpg"
          aria-label="Sortie de la boutique de La Brasserie des Plantes à Saint-Didier-en-Velay"
          class="w-full h-full object-cover"
        >
          <source src="/videos/boutique-sortie.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </section>

  <!-- ARTISAN -->
  <section class="py-20 bg-cream-50">
    <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-[320px_1fr] gap-10 items-center">
      <div class="aspect-square rounded-2xl overflow-hidden max-w-[320px] mx-auto w-full">
        <img src="/images/ateliers/artisans.jpg" alt="Étienne, artisan liquoriste de la Brasserie des Plantes" loading="lazy" class="w-full h-full object-cover" />
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">
          Votre hôte
        </div>
        <h2 class="font-display text-3xl md:text-4xl text-forest-900 leading-tight mb-5">
          <em class="not-italic font-normal text-forest-600" style="font-family: var(--font-script);">Étienne</em>,<br />
          artisan liquoriste
        </h2>
        <div class="text-ink-700 leading-relaxed space-y-4 text-base">
          <p>
            Originaire de Saint-Didier-en-Velay, Étienne connaît son coin
            comme sa poche. Ingénieur en biotechnologie végétale de
            formation, il a monté La Brasserie des Plantes pour produire
            des liqueurs macérées à base de plantes d'Auvergne.
          </p>
          <p>
            Son atelier est installé dans une ancienne boulangerie, au cœur
            du village. Précis, organisé, passionné — il a à cœur de
            partager son savoir-faire : culture des plantes, arômes,
            processus de macération, mise en bouteille.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- AVIS CLIENTS — scraped depuis les 23 commentaires Wecandoo -->
  <section class="py-20 md:py-24 bg-white border-y border-forest-100/60">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12 max-w-3xl mx-auto">
        <div class="text-xs uppercase tracking-[0.25em] text-gold-600 font-medium mb-3">
          {allReviews.length} avis clients vérifiés
        </div>
        <h2 class="font-display text-4xl md:text-5xl text-forest-900 leading-tight mb-5">
          Ce qu'en disent nos<br />participants
        </h2>
        <p class="text-ink-700 leading-relaxed">
          Tous les avis ci-dessous proviennent de participants réels ayant
          réservé via Wecandoo. Publiés sous leur nom, avec la date de
          visite.
        </p>
      </div>

      <!-- Grid masonry d'avis — colonnes responsives -->
      <div class="columns-1 md:columns-2 lg:columns-3 gap-5 space-y-5">
        {allReviews.map((r) => (
          <figure class="break-inside-avoid p-6 rounded-2xl bg-cream-50 border border-forest-100/60 text-center">
            <svg class="w-6 h-6 mx-auto mb-3 text-gold-500/60" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg>
            <blockquote class="text-sm md:text-[15px] text-ink-700 leading-relaxed italic">
              {r.content}
            </blockquote>
            <figcaption class="mt-4 pt-4 border-t border-forest-100 text-xs">
              <div class="font-medium text-forest-900 not-italic">{r.name}</div>
              <div class="text-ink-500 italic mt-0.5">
                {r.workshop} · <time class="not-italic">{fmtDate(r.date)}</time>
              </div>
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="mt-12 text-center text-xs text-ink-500">
        Source : avis publiés sur les fiches Wecandoo de nos deux ateliers.
      </div>
    </div>
  </section>

  <!-- PRIVATISATION / EVJF-EVG / ENTREPRISE -->
  <section class="py-20 bg-cream-50">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">
        Groupes, EVJF / EVG, entreprises
      </div>
      <h2 class="font-display text-3xl md:text-4xl text-forest-900 leading-tight mb-5">
        Privatiser l'atelier pour votre groupe
      </h2>
      <p class="text-lg text-ink-700 leading-relaxed mb-8 max-w-2xl mx-auto">
        Enterrement de vie de jeune fille, de jeune garçon, séminaire
