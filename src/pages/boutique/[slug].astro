---
import { getEntry, getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { Awards } from '@/components/ui/award';
import ReviewsSection from '../../components/ReviewsSection.astro';
import AddToCartButton from '../../components/cart/AddToCartButton';
import { products, ranges } from '../../data/products';
import { cocktails } from '../../data/cocktails';
import { site } from '../../data/site';
import { reviewsByProduct, aggregateRating } from '../../data/reviews';
import { getSchemaAvailability, isOutOfStock, isOnBackorder, getSizePrices } from '../../lib/wc-live';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const rangeInfo = ranges[product.range];

// Rendu Markdown du body de la fiche (description longue) via le pipeline
// natif Astro — même processeur que le blog. Permet aux liens [text](/url),
// au gras, aux H2/H3 et aux listes du body markdown d'être convertis en
// HTML cliquable / formaté plutôt qu'affichés en raw text.
const productEntry = await getEntry('products', product.slug);
const { Content: ProductDescription } = productEntry
  ? await render(productEntry)
  : { Content: null };

// Articles de blog qui mentionnent ce produit (lien `/boutique/<slug>` dans
// le body). Construit au build : on lit toutes les entrées blog une fois,
// on filtre par occurrence du lien dans le body brut.
const productLinkRegex = new RegExp(`/boutique/${product.slug}(?:[)#?]|$)`);
const allBlogPosts = await getCollection('blog');
const relatedPosts = allBlogPosts
  .filter((p) => productLinkRegex.test(p.body ?? ''))
  .sort((a, b) => {
    const dateA = (a.data.updated ?? a.data.date).getTime();
    const dateB = (b.data.updated ?? b.data.date).getTime();
    return dateB - dateA;
  })
  .slice(0, 6);

// Prix par contenance (synchronisés depuis les variations WC au prebuild).
// Les pills reçoivent leur prix en data-attribute ; le JS met à jour le prix
// affiché au clic. Si aucun prix variation n'est disponible, on retombe sur
// le range priceMin – priceMax comme avant.
const sizePrices = getSizePrices(product.wcId);
const hasSizePrices = Object.keys(sizePrices).length > 0;

// Prix initial affiché : 70cl si dispo, sinon la plus petite contenance avec
// un prix, sinon le range. Le script sélectionne la pill correspondante à
// l'init (par défaut la pill "70" si présente).
const formatPrice = (p: number) => {
  return Number.isInteger(p) ? `${p} €` : `${p.toFixed(2).replace('.', ',')} €`;
};
const formatPricePerLiter = (price: number, cl: number) => {
  if (!cl || cl <= 0) return '';
  const perLiter = (price * 100) / cl;
  return `(${perLiter.toFixed(2).replace('.', ',')} €/L)`;
};
const initialCl = hasSizePrices
  ? (sizePrices[70] !== undefined ? 70 : Math.min(...Object.keys(sizePrices).map(Number)))
  : null;
const initialPrice = initialCl != null ? sizePrices[initialCl] : null;
const initialPriceLabel =
  initialPrice != null
    ? formatPrice(initialPrice)
    : product.priceMin === product.priceMax
      ? `${product.priceMin} €`
      : `${product.priceMin} – ${product.priceMax} €`;
const initialPerLiterLabel =
  initialPrice != null && initialCl != null ? formatPricePerLiter(initialPrice, initialCl) : '';

// Suggestions : 3 autres produits de la même gamme
const related = products
  .filter((p) => p.range === product.range && p.slug !== product.slug)
  .slice(0, 3);

// Cocktails qui utilisent ce produit (liaison cocktails → fiche produit)
const relatedCocktails = cocktails.filter((c) => c.liqueurProductSlug === product.slug);

// Schema Product avec AggregateOffer sur les variantes de contenance
const priceLabel =
  product.priceMin === product.priceMax
    ? `${product.priceMin}`
    : `${product.priceMin}–${product.priceMax}`;

// Nettoyage Markdown → texte brut pour la description du schema Product.
// Le body markdown du fichier .md contient des **gras**, [liens](/url),
// ## titres, etc. Google les affiche tels quels dans le Knowledge Graph
// si on les laisse, ce qui dégrade l'UX SERP. On strip → string plate
// limitée à 5000 chars (limite raisonnable pour Product.description).
const plainDescription = (product.description ?? '')
  .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // [text](/url) → text
  .replace(/#{1,6}\s+/g, '')                  // # H1 / ## H2 / etc.
  .replace(/\*{1,3}([^*]+)\*{1,3}/g, '$1')   // *italic* / **bold** / ***
  .replace(/\n+/g, ' ')                       // newlines → space
  .replace(/\s+/g, ' ')                       // collapse whitespace
  .trim()
  .slice(0, 5000);

// Avis produit + aggregate
const productReviews = reviewsByProduct(product.slug);
const productAgg = aggregateRating(productReviews);

// Premier janvier de l'année prochaine — valeur neutre pour priceValidUntil
// (requise par Google pour les Offer rich results), sans surpromesse éditoriale.
const priceValidUntil = `${new Date().getUTCFullYear() + 1}-12-31`;
const productUrl = `${site.url}/boutique/${product.slug}`;
const productImages = [
  new URL(product.image, site.url).toString(),
  ...(product.image2 ? [new URL(product.image2, site.url).toString()] : []),
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: plainDescription || product.tagline,
  image: productImages,
  brand: { '@type': 'Brand', name: site.name },
  // category SEO si renseigné (ex "Liqueur de verveine artisanale"),
  // sinon fallback sur le nom de la gamme.
  category: product.seoCategory || rangeInfo.name,
  sku: String(product.wcId),
  mpn: String(product.wcId),
  inLanguage: 'fr-FR',
  ...(product.awards && product.awards.length
    ? { award: product.awards.join(' · ') }
    : {}),
  offers:
    product.priceMin === product.priceMax
      ? {
          '@type': 'Offer',
          price: product.priceMin,
          priceCurrency: 'EUR',
          availability: getSchemaAvailability(product.wcId),
          url: productUrl,
          priceValidUntil,
          seller: { '@id': `${site.url}#localbusiness` },
        }
      : {
          '@type': 'AggregateOffer',
          lowPrice: product.priceMin,
          highPrice: product.priceMax,
          priceCurrency: 'EUR',
          offerCount: product.sizes?.length || 1,
          availability: getSchemaAvailability(product.wcId),
          url: productUrl,
          priceValidUntil,
          seller: { '@id': `${site.url}#localbusiness` },
        },
  // AggregateRating / Review schema retiré : uniquement de vrais avis Google
  // alimenteront ces rich-snippets (via Featurable), pour éviter tout risque
  // de sanction SEO lié à des avis internes non vérifiables.
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Boutique', item: `${site.url}/boutique` },
    { '@type': 'ListItem', position: 3, name: rangeInfo.name, item: `${site.url}/boutique#${product.range}` },
    { '@type': 'ListItem', position: 4, name: product.name, item: `${site.url}/boutique/${product.slug}` },
  ],
};

// Coupe la description sur la frontière d'un mot (≤155 chars) pour éviter
// les descriptions tronquées en plein milieu d'un mot qui font mauvais effet
// dans les SERP et sur les partages sociaux.
const truncate = (s: string, max = 155) => {
  if (s.length <= max) return s;
  const cut = s.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > 100 ? cut.slice(0, lastSpace) : cut).trimEnd() + '…';
};
// On préfixe la meta description avec la catégorie SEO si dispo
// (ex : "Liqueur de verveine artisanale — L'Herbe des Druides…")
// pour densifier le mot-clé en SERP.
const metaDescriptionRaw = product.description
  ? `${product.seoCategory ? product.seoCategory + ' — ' : ''}${product.description}`
  : `${product.seoCategory ? product.seoCategory + ' — ' : ''}${product.name} — ${product.alcohol}° — ${product.tagline || ''} La Brasserie des Plantes, Haute-Loire.`;
const metaDescription = truncate(metaDescriptionRaw, 158);

// Parseur simple des distinctions pour les convertir en badges médailles.
// Le niveau (or / argent / bronze) détermine la couleur métallique du badge.
type AwardLevel = 'gold' | 'silver' | 'bronze' | 'platinum';
type ParsedAward = {
  level: AwardLevel;
  title: string;
  issuer: string;
};
const parseAward = (raw: string): ParsedAward => {
  const lower = raw.toLowerCase();
  let level: AwardLevel = 'gold';
  // "Meilleur Digestif du Monde" reste en or — pas de variant platine distinct
  if (lower.includes('argent') || lower.includes('silver')) level = 'silver';
  else if (lower.includes('bronze')) level = 'bronze';
  else if (lower.includes('platine') || lower.includes('platinum')) level = 'platinum';
  // tout le reste (or / gold / meilleur du monde / médaille) → gold

  // Sépare le titre de l'émetteur : "Médaille d'Or — Concours de Lyon"
  const parts = raw.split(/\s[—–-]\s/);
  const title = (parts[0] || raw).trim();
  const issuer = (parts[1] || 'Distinction').trim();
  return { level, title, issuer };
};
const parsedAwards = (product.awards || []).map(parseAward);
---
<Layout
  title={product.seoCategory
    ? `${product.seoCategory} — ${product.name}${product.alcohol ? ' ' + product.alcohol + '°' : ''} | La Brasserie des Plantes`
    : `${product.name}${product.alcohol ? ' ' + product.alcohol + '°' : ''} | La Brasserie des Plantes`}
  description={metaDescription}
  ogImage={product.image}
  ogType="product"
  schema={[productSchema, breadcrumbSchema]}
>
  <!-- Fil d'Ariane -->
  <div class="bg-cream-50 py-5 border-b border-forest-100/60">
    <div class="max-w-7xl mx-auto px-6 text-xs text-ink-500">
      <a href="/" class="hover:text-forest-700">Accueil</a>
      <span class="mx-2">/</span>
      <a href="/boutique" class="hover:text-forest-700">Boutique</a>
      <span class="mx-2">/</span>
      <a href={`/boutique#${product.range}`} class="hover:text-forest-700">{rangeInfo.name}</a>
      <span class="mx-2">/</span>
      <span class="text-forest-700">{product.name}</span>
    </div>
  </div>

  <!-- En-tête produit -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12">
      <!-- Galerie images -->
      <div>
        <div
          id="product-gallery"
          class="aspect-[4/5] rounded-2xl bg-white border border-forest-100/50 relative overflow-hidden shadow-cream-lg group"
          data-has-second={product.image2 ? 'true' : 'false'}
        >
          <!-- Slides — packshot principal (change selon le format) + vue d'ambiance -->
          <img
            id="main-slide"
            data-slide="0"
            src={product.sizeImages?.[70] || product.image}
            alt={product.seoCategory
              ? `${product.seoCategory} — ${product.name}, ${product.alcohol}° — Bouteille La Brasserie des Plantes (Haute-Loire)`
              : `${product.name} — liqueur artisanale aux plantes oubliées`}
            class="gallery-slide absolute inset-0 w-full h-full object-contain p-10 transition-opacity duration-500 ease-in-out opacity-100"
            fetchpriority="high"
          />
          {product.image2 && (
            <img
              data-slide="1"
              src={product.image2}
              alt={`${product.name} — vue secondaire`}
              class="gallery-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ease-in-out opacity-0"
              loading="lazy"
            />
          )}

          {/* Flèches de navigation */}
          {product.image2 && (
            <>
              <button
                type="button"
                id="gallery-prev"
                aria-label="Vue précédente"
                class="absolute left-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-cream-50/90 hover:bg-cream-50 text-forest-800 flex items-center justify-center shadow-md opacity-0 group-hover:opacity-100 transition-opacity"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button
                type="button"
                id="gallery-next"
                aria-label="Vue suivante"
                class="absolute right-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-cream-50/90 hover:bg-cream-50 text-forest-800 flex items-center justify-center shadow-md opacity-0 group-hover:opacity-100 transition-opacity"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </button>

              {/* Dots */}
              <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10 flex gap-2">
                <button type="button" class="gallery-dot w-2.5 h-2.5 rounded-full bg-forest-800 transition-all" data-index="0" aria-label="Vue 1"></button>
                <button type="button" class="gallery-dot w-2.5 h-2.5 rounded-full bg-forest-800/30 transition-all" data-index="1" aria-label="Vue 2"></button>
              </div>
            </>
          )}

          {product.highlight && (
            <span class="absolute top-5 left-5 z-10 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-gold-500 text-cream-50 text-[11px] font-medium tracking-wide uppercase shadow-sm">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
              {product.highlight}
            </span>
          )}
          {product.alcohol > 0 && (
            <span class="absolute top-5 right-5 z-10 text-sm font-medium text-cream-50 bg-forest-800/90 px-3 py-1.5 rounded-full">
              {product.alcohol}°
            </span>
          )}

          {/* Tag format sélectionné en bas à gauche — caché tant qu'aucune taille choisie */}
          {product.sizes && product.sizes.length > 1 && (
            <span
              id="current-size-tag"
              class="absolute bottom-4 left-4 z-10 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-forest-800/90 text-cream-50 text-[11px] font-medium tracking-wide uppercase opacity-0 transition-opacity duration-300"
            >
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              <span id="current-size-label">Format</span>
            </span>
          )}
        </div>

        {product.image2 && (
          <div class="mt-4 grid grid-cols-4 gap-3">
            <button
              type="button"
              data-index="0"
              class="thumb aspect-square rounded-lg border-2 border-forest-600 bg-white overflow-hidden transition-colors"
              aria-label={`${product.name} — vue packshot`}
            >
              <img
                src={product.image}
                alt={`${product.name} — vue packshot`}
                class="w-full h-full object-contain p-2"
                loading="lazy"
              />
            </button>
            <button
              type="button"
              data-index="1"
              class="thumb aspect-square rounded-lg border-2 border-forest-100 hover:border-forest-400 bg-cream-100 overflow-hidden transition-colors"
              aria-label={`${product.name} — vue d'ambiance`}
            >
              <img
                src={product.image2}
                alt={`${product.name} — vue d'ambiance, mise en situation`}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </button>
          </div>
        )}
      </div>

      <!-- Info produit -->
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">
          {product.seoCategory ?? rangeInfo.name}
        </div>
        <h1 class="font-display text-4xl md:text-5xl text-forest-900 leading-tight mb-4">
          {product.name}
        </h1>
        {product.tagline && (
          <p class="text-lg italic text-ink-700 mb-6 leading-relaxed">
            {product.tagline}
          </p>
        )}

        <!-- Badges info-clés -->
        <div class="flex flex-wrap gap-2 mb-8">
          {product.alcohol > 0 && (
            <span class="text-xs px-3 py-1.5 rounded-full bg-forest-100 text-forest-800 font-medium">
              {product.alcohol}% vol.
            </span>
          )}
          <span class="text-xs px-3 py-1.5 rounded-full bg-forest-100 text-forest-800 font-medium">
            {product.usage}
          </span>
          <span class="text-xs px-3 py-1.5 rounded-full bg-cream-200 text-ink-700 font-medium">
            Artisanat Haute-Loire
          </span>
        </div>

        <!-- Prix (mise à jour JS selon le format sélectionné) -->
        <div class="mb-8 pb-8 border-b border-forest-100">
          <div class="flex items-baseline gap-3 flex-wrap">
            <div id="price-main" class="text-3xl font-display text-forest-900">
              {initialPriceLabel}
            </div>
            <div id="price-per-liter" class="text-sm text-ink-500 italic">
              {initialPerLiterLabel}
            </div>
          </div>
          {product.sizes && product.sizes.length > 1 && (
            <div id="price-subtitle" class="text-sm text-ink-500 mt-1">
              {hasSizePrices ? 'Prix pour le format sélectionné — cliquez une autre contenance pour mettre à jour' : `Selon contenance — ${product.sizes.length} formats disponibles`}
            </div>
          )}
          {isOutOfStock(product.wcId) && (
            <div class="mt-3 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-50 border border-amber-200 text-amber-800 text-xs font-medium">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
              Rupture temporaire — prochaine mise en cuve bientôt
            </div>
          )}
          {isOnBackorder(product.wcId) && (
            <div class="mt-3 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-forest-50 border border-forest-200 text-forest-800 text-xs font-medium">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Sur commande — expédition dans 10 à 14 jours
            </div>
          )}
        </div>

        <!-- Contenances -->
        {product.sizes && product.sizes.length > 1 && (
          <div class="mb-8">
            <div class="text-xs uppercase tracking-wider text-forest-600 font-medium mb-3">
              Contenance — {product.sizes.length} formats disponibles
            </div>
            <div class="flex flex-wrap gap-2" id="size-selector">
              {product.sizes.map((s, i) => {
                // Extrait la capacité en cl pour le ratio d'échelle visuelle
                const cl = parseInt(s.replace(/[^0-9]/g, ''), 10) || 70;
                const sizeImage = product.sizeImages?.[cl];
                const sizePrice = sizePrices[cl];
                return (
                  <button
                    type="button"
                    data-size={s}
                    data-size-index={i}
                    data-size-cl={cl}
                    data-size-image={sizeImage}
                    data-size-price={sizePrice}
                    class={`size-pill px-4 py-2 rounded-lg border text-sm font-medium transition-all ${
                      s.includes('70')
                        ? 'border-forest-700 bg-forest-800 text-cream-100 shadow-sm'
                        : 'border-forest-200 text-ink-700 hover:border-forest-500 hover:bg-forest-50'
                    }`}
                  >
                    {s}
                  </button>
                );
              })}
            </div>
          </div>
        )}

        <!-- Ajouter au panier → WooCommerce Store API via île React -->
        <div class="mb-5">
          <AddToCartButton
            client:load
            wcId={product.wcId}
            sizeAttribute={product.wcSizeAttribute}
            productName={product.name}
          />
        </div>

        <!-- CTA Coffret DIY — visible sur chaque fiche produit, pré-sélectionne la bouteille courante -->
        {product.sizeImages?.[20] && (
          <a
            href={`/composer-mon-coffret?preselect=${product.slug}`}
            class="group flex items-center gap-4 mb-8 p-4 rounded-2xl bg-gradient-to-r from-forest-50 to-cream-50 border border-forest-200/70 hover:border-gold-500/70 hover:shadow-md transition-all"
          >
            <!-- Vraie photo empilable 20cl (déjà sur le site) -->
            <div class="flex-none w-14 h-14 rounded-xl overflow-hidden bg-white border border-forest-200/60">
              <img
                src={product.sizeImages[20]}
                alt={`${product.name} — format empilable 20cl`}
                class="w-full h-full object-contain p-1.5"
                loading="lazy"
              />
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-xs uppercase tracking-wider text-gold-600 font-medium mb-0.5">Idée cadeau</div>
              <div class="font-display text-base text-forest-900 leading-tight">
                L'ajouter dans un coffret de 3 bouteilles
              </div>
              <div class="text-xs text-ink-500 mt-0.5">Format 20cl empilable · préparé en atelier</div>
            </div>
            <svg class="flex-none w-5 h-5 text-forest-700 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        )}

        <!-- Trust signals -->
        <div class="grid grid-cols-3 gap-3 pt-6 border-t border-forest-100 text-xs text-ink-500">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-forest-600 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Livraison 48-72h
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-forest-600 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Dès 65 € : offerte
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-forest-600 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Paiement sécurisé
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bandeau horizontal Notes de dégustation / Composition / Conseil — placé
       juste après le hero pour combler le vide à gauche sous la photo tout en
       gardant l'info à portée de scroll. 3 colonnes sur desktop, stack sur mobile. -->
  {(product.tasting || (product.composition && product.composition.length > 0) || product.serving) && (
    <section class="py-10 bg-cream-50 border-y border-forest-100/60">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-6 md:gap-10">
          {product.tasting && (
            <div class="md:pr-6 md:border-r md:border-forest-100/70">
              <div class="text-xs uppercase tracking-[0.2em] text-forest-700 font-medium mb-3">
                Notes de dégustation
              </div>
              <dl class="space-y-2.5">
                {product.tasting.nose && (
                  <div class="flex gap-3 text-sm">
                    <dt class="flex-none w-14 text-[11px] uppercase tracking-wide text-forest-600 font-medium pt-0.5">Nez</dt>
                    <dd class="text-ink-700 leading-relaxed">{product.tasting.nose}</dd>
                  </div>
                )}
                {product.tasting.palate && (
                  <div class="flex gap-3 text-sm">
                    <dt class="flex-none w-14 text-[11px] uppercase tracking-wide text-forest-600 font-medium pt-0.5">Bouche</dt>
                    <dd class="text-ink-700 leading-relaxed">{product.tasting.palate}</dd>
                  </div>
                )}
                {product.tasting.finish && (
                  <div class="flex gap-3 text-sm">
                    <dt class="flex-none w-14 text-[11px] uppercase tracking-wide text-forest-600 font-medium pt-0.5">Finale</dt>
                    <dd class="text-ink-700 leading-relaxed">{product.tasting.finish}</dd>
                  </div>
                )}
              </dl>
            </div>
          )}
          {product.composition && product.composition.length > 0 && (
            <div class="md:px-6 md:border-r md:border-forest-100/70">
              <div class="text-xs uppercase tracking-[0.2em] text-forest-700 font-medium mb-3">
                Composition
              </div>
              <ul class="text-sm text-ink-700 leading-relaxed space-y-1.5">
                {product.composition.map((c) => (
                  <li class="flex items-start gap-3">
                    <span class="flex-none w-1.5 h-1.5 rounded-full bg-gold-500 mt-2" aria-hidden="true"></span>
                    <span>{c}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {product.serving && (
            <div class="md:pl-6">
              <div class="text-xs uppercase tracking-[0.2em] text-forest-700 font-medium mb-3">
                Conseil de dégustation
              </div>
              <p class="text-sm text-ink-700 italic leading-relaxed">"{product.serving}"</p>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Description -->
  {ProductDescription && (
    <section class="py-16 bg-white border-y border-forest-100/60">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-display text-3xl text-forest-900 mb-6">À propos</h2>
        <div class="prose prose-lg max-w-none
                    prose-headings:font-display prose-headings:text-forest-900
                    prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:tracking-tight
                    prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                    prose-p:text-ink-700 prose-p:leading-relaxed
                    prose-a:text-forest-700 prose-a:font-medium prose-a:underline prose-a:decoration-forest-300 prose-a:underline-offset-4
                    hover:prose-a:decoration-forest-700
                    prose-strong:text-forest-900 prose-strong:font-medium
                    prose-em:text-forest-800
                    prose-ul:my-4 prose-ol:my-4 prose-li:my-1
                    prose-hr:border-forest-200 prose-hr:my-10">
          <ProductDescription />
        </div>
      </div>
    </section>
  )}

  <!-- Articles qui parlent de ce produit (maillage interne) -->
  {relatedPosts.length > 0 && (
    <section class="py-16 bg-cream-50/50">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">
          Dans notre actualité
        </div>
        <h2 class="font-display text-3xl text-forest-900 mb-8">Articles qui parlent de {product.name}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col rounded-2xl overflow-hidden bg-white border border-forest-100/60 hover:shadow-cream-lg transition-all"
            >
              {post.data.cover && (
                <div class="aspect-[16/10] overflow-hidden">
                  <img
                    src={post.data.cover}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-5 flex flex-col gap-2 flex-1">
                <div class="text-[11px] uppercase tracking-[0.2em] text-forest-600 font-medium">
                  {post.data.category}
                </div>
                <h3 class="font-display text-lg text-forest-900 leading-tight group-hover:text-forest-700 transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-sm text-ink-500 leading-relaxed line-clamp-3 mt-1">
                  {post.data.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}


  <!-- Distinctions — badges animés -->
  {parsedAwards.length > 0 && (
    <section class="py-14 bg-gradient-to-b from-cream-50 via-gold-500/5 to-cream-50 border-y border-gold-500/25 overflow-hidden">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <div class="text-xs uppercase tracking-[0.3em] text-gold-600 font-medium mb-3">Distinctions</div>
        <h2 class="font-display text-2xl md:text-3xl text-forest-900 mb-10 leading-tight">
          Ce flacon a été primé
        </h2>
        <div class="flex flex-wrap justify-center gap-2 md:gap-3 max-w-2xl mx-auto">
          {parsedAwards.map((a) => (
            <Awards
              client:visible
              variant="award"
              level={a.level}
              title={a.title}
              subtitle={a.issuer}
              recipient={product.name}
              className="w-[calc(50%-0.25rem)] sm:w-[150px] min-h-[156px]"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Cocktails -->
  {relatedCocktails.length > 0 && (
    <section class="py-16 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="font-display text-3xl text-forest-900 mb-8">En cocktail</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedCocktails.map((c) => (
            <a href={`/cocktails#${c.slug}`} class="group flex flex-col rounded-2xl overflow-hidden bg-white border border-forest-100/60 hover:shadow-cream-lg transition-all">
              <div class="aspect-square overflow-hidden">
                <img src={c.image} alt={c.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-5">
                <h3 class="font-display text-xl text-forest-900 mb-1 leading-tight">{c.name}</h3>
                <p class="text-sm text-ink-500 italic">{c.description.split('.')[0]}.</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Avis clients pour ce produit -->
  {productReviews.length > 0 && (
    <ReviewsSection
      items={productReviews}
      kicker={`Avis — ${product.name}`}
      heading="Ce qu'ils en disent"
      theme="light"
    />
  )}

  <!-- Vu récemment — alimenté côté client via localStorage. Caché par défaut,
       révélé par JS si on a au moins 1 produit consulté avant celui-ci.
       Reproduit la fonctionnalité "VU RÉCEMMENT" du site WP legacy. -->
  <section
    id="recently-viewed"
    class="py-14 bg-cream-50 border-t border-forest-100/60 hidden"
  >
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-baseline justify-between mb-6 gap-4 flex-wrap">
        <div>
          <div class="text-[10px] md:text-xs uppercase tracking-[0.3em] text-forest-600 font-medium mb-2">
            Votre sillage
          </div>
          <h2 class="font-display text-2xl md:text-3xl text-forest-900 leading-tight">
            Vu récemment
          </h2>
        </div>
        <button
          type="button"
          id="recently-viewed-clear"
          class="text-xs text-ink-500 hover:text-forest-700 underline decoration-dotted underline-offset-4"
        >
          Effacer l'historique
        </button>
      </div>
      <div
        id="recently-viewed-list"
        class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4"
      ></div>
    </div>
  </section>

  <!-- Produits similaires -->
  {related.length > 0 && (
    <section class="py-16 border-t border-forest-100/60">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="font-display text-3xl text-forest-900 mb-8">
          Autres {rangeInfo.name.toLowerCase()}
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {related.map((p) => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}

  <!-- Données produit sérialisées pour l'historique "Vu récemment" côté client -->
  <script
    id="lbdp-current-product"
    type="application/json"
    set:html={JSON.stringify({
      slug: product.slug,
      name: product.name,
      image: product.image,
      priceMin: product.priceMin,
      priceMax: product.priceMax,
      range: rangeInfo.name,
    })}
  ></script>
</Layout>

<script>
  (() => {
    const gallery = document.getElementById('product-gallery');
    if (!gallery) return;

    const slides = Array.from(gallery.querySelectorAll<HTMLElement>('.gallery-slide'));
    const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-dot'));
    const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>('.thumb'));
    const prev = document.getElementById('gallery-prev');
    const next = document.getElementById('gallery-next');
    const sizePills = Array.from(document.querySelectorAll<HTMLButtonElement>('.size-pill'));

    let current = 0;

    const show = (idx: number) => {
      if (slides.length < 2) return;
      const i = ((idx % slides.length) + slides.length) % slides.length;
      slides.forEach((el, k) => {
        el.style.opacity = k === i ? '1' : '0';
      });
      dots.forEach((d, k) => {
        d.classList.toggle('bg-forest-800', k === i);
        d.classList.toggle('bg-forest-800/30', k !== i);
        d.classList.toggle('w-6', k === i);
        d.classList.toggle('w-2.5', k !== i);
      });
      thumbs.forEach((t, k) => {
        t.classList.toggle('border-forest-600', k === i);
        t.classList.toggle('border-forest-100', k !== i);
      });
      current = i;
    };

    const pulseActive = () => {
      const active = slides[current];
      if (!active) return;
      active.style.transform = 'scale(1.04)';
      setTimeout(() => { active.style.transform = 'scale(1)'; }, 320);
    };

    prev?.addEventListener('click', () => show(current - 1));
    next?.addEventListener('click', () => show(current + 1));
    dots.forEach((d) => d.addEventListener('click', () => show(Number(d.dataset.index || 0))));
    thumbs.forEach((t) => t.addEventListener('click', () => show(Number(t.dataset.index || 0))));

    // Flèches clavier
    document.addEventListener('keydown', (e) => {
      if (slides.length < 2) return;
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });

    // Swipe tactile
    let touchStartX = 0;
    gallery.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    gallery.addEventListener('touchend', (e: TouchEvent) => {
      if (slides.length < 2) return;
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) show(dx < 0 ? current + 1 : current - 1);
    });

    // Sélecteur de taille — change la vraie photo selon le format sélectionné
    // (comme sur le site officiel) + fallback en échelle CSS si pas d'image.
    const sizeTag = document.getElementById('current-size-tag');
    const sizeLabel = document.getElementById('current-size-label');
    const mainSlide = document.getElementById('main-slide') as HTMLImageElement | null;
    const firstSlide = slides[0];

    const scaleForCl = (cl: number): number => {
      if (cl <= 20) return 0.78;
      if (cl <= 50) return 0.93;
      if (cl <= 70) return 1.0;
      if (cl <= 100) return 1.1;
      return 1.22;
    };

    // Crossfade doux vers une nouvelle image (précharge avant d'animer)
    const crossfadeMainTo = (newSrc: string) => {
      if (!mainSlide) return;
      if (mainSlide.getAttribute('src') === newSrc) return;
      const preload = new Image();
      preload.onload = () => {
        mainSlide.style.opacity = '0';
        window.setTimeout(() => {
          mainSlide.src = newSrc;
          mainSlide.style.opacity = '1';
        }, 200);
      };
      preload.src = newSrc;
    };

    // Formate un prix EUR : entier sans décimale, sinon X,XX
    const fmtPrice = (p: number): string =>
      Number.isInteger(p) ? `${p} €` : `${p.toFixed(2).replace('.', ',')} €`;

    const fmtPerLiter = (price: number, cl: number): string => {
      if (!cl || cl <= 0 || !Number.isFinite(price)) return '';
      const perLiter = (price * 100) / cl;
      return `(${perLiter.toFixed(2).replace('.', ',')} €/L)`;
    };

    const priceMainEl = document.getElementById('price-main');
    const pricePerLiterEl = document.getElementById('price-per-liter');

    const applySize = (pill: HTMLButtonElement) => {
      const cl = Number(pill.dataset.sizeCl || 70);
      const label = pill.dataset.size || '';
      const sizeImage = pill.dataset.sizeImage;
      const priceAttr = pill.dataset.sizePrice;

      if (sizeImage) {
        // Vraie photo par taille disponible : on change l'image et on
        // réinitialise l'échelle (la photo communique déjà le format).
        crossfadeMainTo(sizeImage);
        if (firstSlide) firstSlide.style.transform = 'scale(1)';
      } else {
        // Fallback : on simule le format par une mise à l'échelle CSS
        const scale = scaleForCl(cl);
        if (firstSlide) {
          firstSlide.style.transformOrigin = 'center bottom';
          firstSlide.style.transform = `scale(${scale})`;
        }
      }

      if (sizeTag) sizeTag.style.opacity = '1';
      if (sizeLabel) sizeLabel.textContent = label;

      // Mise à jour du prix affiché + prix au litre
      if (priceAttr && priceMainEl) {
        const price = Number(priceAttr);
        if (Number.isFinite(price) && price > 0) {
          priceMainEl.textContent = fmtPrice(price);
          if (pricePerLiterEl) pricePerLiterEl.textContent = fmtPerLiter(price, cl);
        }
      }
    };

    sizePills.forEach((pill) => {
      pill.addEventListener('click', () => {
        sizePills.forEach((p) => {
          p.classList.remove('border-forest-700', 'bg-forest-800', 'text-cream-100', 'shadow-sm');
          p.classList.add('border-forest-200', 'text-ink-700', 'hover:border-forest-500', 'hover:bg-forest-50');
        });
        pill.classList.remove('border-forest-200', 'text-ink-700', 'hover:border-forest-500', 'hover:bg-forest-50');
        pill.classList.add('border-forest-700', 'bg-forest-800', 'text-cream-100', 'shadow-sm');
        applySize(pill as HTMLButtonElement);
        // Revenir sur la vue packshot si la vue d'ambiance est visible
        if (slides.length > 1) show(0);
      });
    });

    // Init : transitions + taille par défaut (70cl si présent, sinon premier)
    slides.forEach((el) => {
      el.style.transition = 'opacity 500ms ease-in-out, transform 380ms cubic-bezier(0.16, 1, 0.3, 1)';
    });
    const defaultPill =
      sizePills.find((p) => (p.dataset.size || '').includes('70')) || sizePills[0];
    if (defaultPill) {
      // État actif visuel sur la pill 70cl sans déclencher le crossfade
      sizePills.forEach((p) => {
        p.classList.remove('border-forest-700', 'bg-forest-800', 'text-cream-100', 'shadow-sm');
        p.classList.add('border-forest-200', 'text-ink-700', 'hover:border-forest-500', 'hover:bg-forest-50');
      });
      defaultPill.classList.remove('border-forest-200', 'text-ink-700', 'hover:border-forest-500', 'hover:bg-forest-50');
      defaultPill.classList.add('border-forest-700', 'bg-forest-800', 'text-cream-100', 'shadow-sm');
      if (sizeTag && defaultPill.dataset.size) {
        sizeTag.style.opacity = '1';
        if (sizeLabel) sizeLabel.textContent = defaultPill.dataset.size;
      }
    }
  })();

  // ─── "Vu récemment" — historique client-side en localStorage ────────────
  //
  // Pattern simple sans île React : on enregistre les 8 derniers produits
  // visités (slug + infos cache). À l'affichage d'une fiche, on montre les 6
  // autres (hors produit courant) dans une grille sous les produits similaires.
  // Clé de stockage versionnée pour pouvoir faire évoluer le format sans
  // polluer les visiteurs récurrents (bump → "v2", "v3"…).
  (() => {
    const STORAGE_KEY = 'lbdp-recently-viewed-v1';
    const MAX_ENTRIES = 8;
    const MAX_DISPLAY = 6;

    const dataEl = document.getElementById('lbdp-current-product');
    if (!dataEl || !dataEl.textContent) return;

    type Entry = {
      slug: string;
      name: string;
      image: string;
      priceMin: number;
      priceMax: number;
      range: string;
      viewedAt: number;
    };

    let current: Omit<Entry, 'viewedAt'>;
    try {
      current = JSON.parse(dataEl.textContent);
    } catch {
      return;
    }

    const read = (): Entry[] => {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed.filter((e) => e && typeof e.slug === 'string') : [];
      } catch {
        return [];
      }
    };

    const write = (list: Entry[]) => {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
      } catch {
        // quotaExceeded ou stockage désactivé (Safari privé) → on abandonne
      }
    };

    const escapeHtml = (s: string) =>
      s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));

    const render = (list: Entry[]) => {
      const section = document.getElementById('recently-viewed');
      const container = document.getElementById('recently-viewed-list');
      if (!section || !container) return;

      const toShow = list.filter((e) => e.slug !== current.slug).slice(0, MAX_DISPLAY);
      if (toShow.length === 0) {
        section.classList.add('hidden');
        return;
      }

      container.innerHTML = toShow.map((p) => `
        <a
          href="/boutique/${encodeURIComponent(p.slug)}"
          class="group block"
        >
          <div class="aspect-[4/5] bg-white rounded-xl overflow-hidden border border-forest-100/60 relative shadow-sm">
            <img
              src="${escapeHtml(p.image)}"
              alt="${escapeHtml(p.name)}"
              loading="lazy"
              class="w-full h-full object-contain p-4 transition-transform duration-300 group-hover:scale-105"
            />
          </div>
          <div class="mt-3">
            <div class="text-[10px] uppercase tracking-wider text-forest-600/70 font-medium mb-0.5">${escapeHtml(p.range)}</div>
            <div class="font-display text-sm text-forest-900 leading-tight line-clamp-2 mb-0.5">${escapeHtml(p.name)}</div>
            <div class="text-xs text-gold-600 font-medium">
              ${p.priceMin === p.priceMax ? `${p.priceMin} €` : `dès ${p.priceMin} €`}
            </div>
          </div>
        </a>
      `).join('');

      section.classList.remove('hidden');
    };

    // 1) Lit la liste et affiche (sans le produit courant)
    const existing = read();
    render(existing);

    // 2) Met à jour la liste : retire toute entrée existante du produit
    //    courant, ajoute une entrée fraîche en tête, tronque à MAX_ENTRIES.
    const updated: Entry[] = [
      { ...current, viewedAt: Date.now() },
      ...existing.filter((e) => e.slug !== current.slug),
    ].slice(0, MAX_ENTRIES);
    write(updated);

    // 3) Bouton "effacer l'historique"
    document.getElementById('recently-viewed-clear')?.addEventListener('click', () => {
      write([]);
      const section = document.getElementById('recently-viewed');
      section?.classList.add('hidden');
    });
  })();
</script>
