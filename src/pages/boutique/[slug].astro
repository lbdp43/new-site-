---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { AwardBadge, type AwardType } from '../../components/ui/award-badge';
import ReviewsSection from '../../components/ReviewsSection.astro';
import AddToCartButton from '../../components/cart/AddToCartButton';
import { products, ranges } from '../../data/products';
import { cocktails } from '../../data/cocktails';
import { site } from '../../data/site';
import { reviewsByProduct, aggregateRating } from '../../data/reviews';
import { getSchemaAvailability, isOutOfStock, isOnBackorder } from '../../lib/wc-live';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const rangeInfo = ranges[product.range];

// Suggestions : 3 autres produits de la même gamme
const related = products
  .filter((p) => p.range === product.range && p.slug !== product.slug)
  .slice(0, 3);

// Cocktails qui utilisent ce produit (liaison cocktails → fiche produit)
const relatedCocktails = cocktails.filter((c) => c.liqueurProductSlug === product.slug);

// Schema Product avec AggregateOffer sur les variantes de contenance
const priceLabel =
  product.priceMin === product.priceMax
    ? `${product.priceMin}`
    : `${product.priceMin}–${product.priceMax}`;

// Avis produit + aggregate
const productReviews = reviewsByProduct(product.slug);
const productAgg = aggregateRating(productReviews);

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description || product.tagline,
  image: new URL(product.image, site.url).toString(),
  brand: { '@type': 'Brand', name: site.name },
  category: rangeInfo.name,
  offers:
    product.priceMin === product.priceMax
      ? {
          '@type': 'Offer',
          price: product.priceMin,
          priceCurrency: 'EUR',
          availability: getSchemaAvailability(product.wcId),
          url: `${site.url}/boutique/${product.slug}`,
        }
      : {
          '@type': 'AggregateOffer',
          lowPrice: product.priceMin,
          highPrice: product.priceMax,
          priceCurrency: 'EUR',
          offerCount: product.sizes?.length || 1,
          availability: getSchemaAvailability(product.wcId),
        },
  // AggregateRating / Review schema retiré : uniquement de vrais avis Google
  // alimenteront ces rich-snippets (via Featurable), pour éviter tout risque
  // de sanction SEO lié à des avis internes non vérifiables.
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Boutique', item: `${site.url}/boutique` },
    { '@type': 'ListItem', position: 3, name: rangeInfo.name, item: `${site.url}/boutique#${product.range}` },
    { '@type': 'ListItem', position: 4, name: product.name, item: `${site.url}/boutique/${product.slug}` },
  ],
};

// Coupe la description sur la frontière d'un mot (≤155 chars) pour éviter
// les descriptions tronquées en plein milieu d'un mot qui font mauvais effet
// dans les SERP et sur les partages sociaux.
const truncate = (s: string, max = 155) => {
  if (s.length <= max) return s;
  const cut = s.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > 100 ? cut.slice(0, lastSpace) : cut).trimEnd() + '…';
};
const metaDescription = product.description
  ? truncate(product.description, 155)
  : `${product.name} — ${product.alcohol}° — ${product.tagline || ''} La Brasserie des Plantes, Haute-Loire.`;

// Parseur simple des distinctions pour les convertir en badges animés
type ParsedAward = {
  type: AwardType;
  title: string;
  issuer: string;
};
const parseAward = (raw: string): ParsedAward => {
  const lower = raw.toLowerCase();
  let type: AwardType = 'gold';
  if (lower.includes('meilleur') && lower.includes('monde')) type = 'world-best';
  else if (lower.includes('argent') || lower.includes('silver')) type = 'silver';
  else if (lower.includes('bronze')) type = 'bronze';
  else if (lower.includes('or') || lower.includes('gold')) type = 'gold';

  // Sépare le titre de l'émetteur : "Médaille d'Or — Concours de Lyon"
  const parts = raw.split(/\s[—–-]\s/);
  const title = (parts[0] || raw).trim();
  const issuer = (parts[1] || 'Distinction').trim();
  return { type, title, issuer };
};
const parsedAwards = (product.awards || []).map(parseAward);
---
<Layout
  title={`${product.name} ${product.alcohol ? product.alcohol + '°' : ''} | ${rangeInfo.name} — La Brasserie des Plantes`}
  description={metaDescription}
  ogImage={product.image}
  ogType="product"
  schema={[productSchema, breadcrumbSchema]}
>
  <!-- Fil d'Ariane -->
  <div class="bg-cream-50 py-5 border-b border-forest-100/60">
    <div class="max-w-7xl mx-auto px-6 text-xs text-ink-500">
      <a href="/" class="hover:text-forest-700">Accueil</a>
      <span class="mx-2">/</span>
      <a href="/boutique" class="hover:text-forest-700">Boutique</a>
      <span class="mx-2">/</span>
      <a href={`/boutique#${product.range}`} class="hover:text-forest-700">{rangeInfo.name}</a>
      <span class="mx-2">/</span>
      <span class="text-forest-700">{product.name}</span>
    </div>
  </div>

  <!-- En-tête produit -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12">
      <!-- Galerie images -->
      <div>
        <div
          id="product-gallery"
          class="aspect-[4/5] rounded-2xl bg-white border border-forest-100/50 relative overflow-hidden shadow-cream-lg group"
          data-has-second={product.image2 ? 'true' : 'false'}
        >
          <!-- Slides — packshot principal (change selon le format) + vue d'ambiance -->
          <img
            id="main-slide"
            data-slide="0"
            src={product.sizeImages?.[70] || product.image}
            alt={`${product.name} — liqueur artisanale aux plantes de Haute-Loire`}
            class="gallery-slide absolute inset-0 w-full h-full object-contain p-10 transition-opacity duration-500 ease-in-out opacity-100"
            fetchpriority="high"
          />
          {product.image2 && (
            <img
              data-slide="1"
              src={product.image2}
              alt={`${product.name} — vue secondaire`}
              class="gallery-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ease-in-out opacity-0"
              loading="lazy"
            />
          )}

          {/* Flèches de navigation */}
          {product.image2 && (
            <>
              <button
                type="button"
                id="gallery-prev"
                aria-label="Vue précédente"
                class="absolute left-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-cream-50/90 hover:bg-cream-50 text-forest-800 flex items-center justify-center shadow-md opacity-0 group-hover:opacity-100 transition-opacity"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button
                type="button"
                id="gallery-next"
                aria-label="Vue suivante"
                class="absolute right-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-cream-50/90 hover:bg-cream-50 text-forest-800 flex items-center justify-center shadow-md opacity-0 group-hover:opacity-100 transition-opacity"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </button>

              {/* Dots */}
              <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10 flex gap-2">
                <button type="button" class="gallery-dot w-2.5 h-2.5 rounded-full bg-forest-800 transition-all" data-index="0" aria-label="Vue 1"></button>
                <button type="button" class="gallery-dot w-2.5 h-2.5 rounded-full bg-forest-800/30 transition-all" data-index="1" aria-label="Vue 2"></button>
              </div>
            </>
          )}

          {product.highlight && (
            <span class="absolute top-5 left-5 z-10 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-gold-500 text-cream-50 text-[11px] font-medium tracking-wide uppercase shadow-sm">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
              {product.highlight}
            </span>
          )}
          {product.alcohol > 0 && (
            <span class="absolute top-5 right-5 z-10 text-sm font-medium text-cream-50 bg-forest-800/90 px-3 py-1.5 rounded-full">
              {product.alcohol}°
            </span>
          )}

          {/* Tag format sélectionné en bas à gauche — caché tant qu'aucune taille choisie */}
          {product.sizes && product.sizes.length > 1 && (
            <span
              id="current-size-tag"
              class="absolute bottom-4 left-4 z-10 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-forest-800/90 text-cream-50 text-[11px] font-medium tracking-wide uppercase opacity-0 transition-opacity duration-300"
            >
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              <span id="current-size-label">Format</span>
            </span>
          )}
        </div>

        {product.image2 && (
          <div class="mt-4 grid grid-cols-4 gap-3">
            <button
              type="button"
              data-index="0"
              class="thumb aspect-square rounded-lg border-2 border-forest-600 bg-white overflow-hidden transition-colors"
              aria-label={`${product.name} — vue packshot`}
            >
              <img
                src={product.image}
                alt={`${product.name} — vue packshot`}
                class="w-full h-full object-contain p-2"
                loading="lazy"
              />
            </button>
            <button
              type="button"
              data-index="1"
              class="thumb aspect-square rounded-lg border-2 border-forest-100 hover:border-forest-400 bg-cream-100 overflow-hidden transition-colors"
              aria-label={`${product.name} — vue d'ambiance`}
            >
              <img
                src={product.image2}
                alt={`${product.name} — vue d'ambiance, mise en situation`}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </button>
          </div>
        )}
      </div>

      <!-- Info produit -->
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">
          {rangeInfo.name}
        </div>
        <h1 class="font-display text-4xl md:text-5xl text-forest-900 leading-tight mb-4">
          {product.name}
        </h1>
        {product.tagline && (
          <p class="text-lg italic text-ink-700 mb-6 leading-relaxed">
            {product.tagline}
          </p>
        )}

        <!-- Badges info-clés -->
        <div class="flex flex-wrap gap-2 mb-8">
          {product.alcohol > 0 && (
            <span class="text-xs px-3 py-1.5 rounded-full bg-forest-100 text-forest-800 font-medium">
              {product.alcohol}% vol.
            </span>
          )}
          <span class="text-xs px-3 py-1.5 rounded-full bg-forest-100 text-forest-800 font-medium">
            {product.usage}
          </span>
          <span class="text-xs px-3 py-1.5 rounded-full bg-cream-200 text-ink-700 font-medium">
            Artisanat Haute-Loire
          </span>
        </div>

        <!-- Prix -->
        <div class="mb-8 pb-8 border-b border-forest-100">
          <div class="text-3xl font-display text-forest-900 mb-1">
            {product.priceMin === product.priceMax ? `${product.priceMin} €` : `${product.priceMin} – ${product.priceMax} €`}
          </div>
          {product.sizes && product.sizes.length > 1 && (
            <div class="text-sm text-ink-500">Selon contenance — {product.sizes.length} formats</div>
          )}
          {isOutOfStock(product.wcId) && (
            <div class="mt-3 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-50 border border-amber-200 text-amber-800 text-xs font-medium">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
              Rupture temporaire — prochaine mise en cuve bientôt
            </div>
          )}
          {isOnBackorder(product.wcId) && (
            <div class="mt-3 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-forest-50 border border-forest-200 text-forest-800 text-xs font-medium">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Sur commande — expédition dans 10 à 14 jours
            </div>
          )}
        </div>

        <!-- Contenances -->
        {product.sizes && product.sizes.length > 1 && (
          <div class="mb-8">
            <div class="text-xs uppercase tracking-wider text-forest-600 font-medium mb-3">
              Contenance — {product.sizes.length} formats disponibles
            </div>
            <div class="flex flex-wrap gap-2" id="size-selector">
              {product.sizes.map((s, i) => {
                // Extrait la capacité en cl pour le ratio d'échelle visuelle
                const cl = parseInt(s.replace(/[^0-9]/g, ''), 10) || 70;
                const sizeImage = product.sizeImages?.[cl];
                return (
                  <button
                    type="button"
                    data-size={s}
                    data-size-index={i}
                    data-size-cl={cl}
                    data-size-image={sizeImage}
                    class={`size-pill px-4 py-2 rounded-lg border text-sm font-medium transition-all ${
                      s.includes('70')
                        ? 'border-forest-700 bg-forest-800 text-cream-100 shadow-sm'
                        : 'border-forest-200 text-ink-700 hover:border-forest-500 hover:bg-forest-50'
                    }`}
                  >
                    {s}
                  </button>
                );
              })}
            </div>
          </div>
        )}

        <!-- Ajouter au panier → WooCommerce Store API via île React -->
        <div class="mb-5">
          <AddToCartButton
            client:load
            wcId={product.wcId}
            sizeAttribute={product.wcSizeAttribute}
            productName={product.name}
          />
        </div>

        <!-- CTA Coffret DIY — visible sur chaque fiche produit, pré-sélectionne la bouteille courante -->
        {product.sizeImages?.[20] && (
          <a
            href={`/composer-mon-coffret?preselect=${product.slug}`}
            class="group flex items-center gap-4 mb-8 p-4 rounded-2xl bg-gradient-to-r from-forest-50 to-cream-50 border border-forest-200/70 hover:border-gold-500/70 hover:shadow-md transition-all"
          >
            <!-- Vraie photo empilable 20cl (déjà sur le site) -->
            <div class="flex-none w-14 h-14 rounded-xl overflow-hidden bg-white border border-forest-200/60">
              <img
                src={product.sizeImages[20]}
                alt={`${product.name} — format empilable 20cl`}
                class="w-full h-full object-contain p-1.5"
                loading="lazy"
              />
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-xs uppercase tracking-wider text-gold-600 font-medium mb-0.5">Idée cadeau</div>
              <div class="font-display text-base text-forest-900 leading-tight">
                L'ajouter dans un coffret de 3 bouteilles
              </div>
              <div class="text-xs text-ink-500 mt-0.5">Format 20cl empilable · préparé en atelier</div>
            </div>
            <svg class="flex-none w-5 h-5 text-forest-700 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        )}

        <!-- Trust signals -->
        <div class="grid grid-cols-3 gap-3 pt-6 border-t border-forest-100 text-xs text-ink-500">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-forest-600 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Livraison 48-72h
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-forest-600 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Dès 65 € : offerte
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-forest-600 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Paiement sécurisé
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Description -->
  {product.description && (
    <section class="py-16 bg-white border-y border-forest-100/60">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-display text-3xl text-forest-900 mb-6">À propos</h2>
        <div class="text-lg text-ink-700 leading-relaxed">{product.description}</div>
      </div>
    </section>
  )}

  <!-- Composition + Dégustation -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-10">
      {product.composition && product.composition.length > 0 && (
        <div>
          <h2 class="font-display text-2xl text-forest-900 mb-5">Composition</h2>
          <ul class="space-y-3">
            {product.composition.map((c) => (
              <li class="flex items-start gap-3 text-ink-700">
                <svg class="w-5 h-5 mt-0.5 text-forest-500 flex-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c0 5-4 8-4 13h8c0-5-4-8-4-13z"/></svg>
                <span>{c}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {product.tasting && (
        <div>
          <h2 class="font-display text-2xl text-forest-900 mb-5">Profil sensoriel</h2>
          <dl class="space-y-4">
            {product.tasting.nose && (
              <div>
                <dt class="text-xs uppercase tracking-wider text-forest-600 font-medium mb-1">Nez</dt>
                <dd class="text-ink-700 leading-relaxed">{product.tasting.nose}</dd>
              </div>
            )}
            {product.tasting.palate && (
              <div>
                <dt class="text-xs uppercase tracking-wider text-forest-600 font-medium mb-1">Bouche</dt>
                <dd class="text-ink-700 leading-relaxed">{product.tasting.palate}</dd>
              </div>
            )}
            {product.tasting.finish && (
              <div>
                <dt class="text-xs uppercase tracking-wider text-forest-600 font-medium mb-1">Finale</dt>
                <dd class="text-ink-700 leading-relaxed">{product.tasting.finish}</dd>
              </div>
            )}
          </dl>
        </div>
      )}
    </div>
  </section>

  <!-- Distinctions — badges animés -->
  {parsedAwards.length > 0 && (
    <section class="py-14 bg-gradient-to-b from-cream-50 via-gold-500/5 to-cream-50 border-y border-gold-500/25 overflow-hidden">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <div class="text-xs uppercase tracking-[0.3em] text-gold-600 font-medium mb-3">Distinctions</div>
        <h2 class="font-display text-2xl md:text-3xl text-forest-900 mb-10 leading-tight">
          Ce flacon a été primé
        </h2>
        <div class="flex flex-wrap items-center justify-center gap-6 md:gap-8">
          {parsedAwards.map((a) => (
            <AwardBadge
              client:visible
              type={a.type}
              title={a.title}
              issuer={a.issuer}
              product={product.name}
              size="md"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Conseil de service -->
  {product.serving && (
    <section class="py-12 bg-forest-900 text-cream-100">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-xs uppercase tracking-[0.25em] text-cream-300/70 font-medium mb-3">Conseil de service</div>
        <p class="font-display text-2xl md:text-3xl leading-relaxed">
          "{product.serving}"
        </p>
      </div>
    </section>
  )}

  <!-- Cocktails -->
  {relatedCocktails.length > 0 && (
    <section class="py-16 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="font-display text-3xl text-forest-900 mb-8">En cocktail</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedCocktails.map((c) => (
            <a href={`/cocktails#${c.slug}`} class="group flex flex-col rounded-2xl overflow-hidden bg-white border border-forest-100/60 hover:shadow-cream-lg transition-all">
              <div class="aspect-square overflow-hidden">
                <img src={c.image} alt={c.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-5">
                <h3 class="font-display text-xl text-forest-900 mb-1 leading-tight">{c.name}</h3>
                <p class="text-sm text-ink-500 italic">{c.description.split('.')[0]}.</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Avis clients pour ce produit -->
  {productReviews.length > 0 && (
    <ReviewsSection
      items={productReviews}
      kicker={`Avis — ${product.name}`}
      heading="Ce qu'ils en disent"
      theme="light"
    />
  )}

  <!-- Produits similaires -->
  {related.length > 0 && (
    <section class="py-16 border-t border-forest-100/60">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="font-display text-3xl text-forest-900 mb-8">
          Autres {rangeInfo.name.toLowerCase()}
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {related.map((p) => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</Layout>

<script>
  (() => {
    const gallery = document.getElementById('product-gallery');
    if (!gallery) return;

    const slides = Array.from(gallery.querySelectorAll<HTMLElement>('.gallery-slide'));
    const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-dot'));
    const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>('.thumb'));
    const prev = document.getElementById('gallery-prev');
    const next = document.getElementById('gallery-next');
    const sizePills = Array.from(document.querySelectorAll<HTMLButtonElement>('.size-pill'));

    let current = 0;

    const show = (idx: number) => {
      if (slides.length < 2) return;
      const i = ((idx % slides.length) + slides.length) % slides.length;
      slides.forEach((el, k) => {
        el.style.opacity = k === i ? '1' : '0';
      });
      dots.forEach((d, k) => {
        d.classList.toggle('bg-forest-800', k === i);
        d.classList.toggle('bg-forest-800/30', k !== i);
        d.classList.toggle('w-6', k === i);
        d.classList.toggle('w-2.5', k !== i);
      });
      thumbs.forEach((t, k) => {
        t.classList.toggle('border-forest-600', k === i);
        t.classList.toggle('border-forest-100', k !== i);
      });
      current = i;
    };

    const pulseActive = () => {
      const active = slides[current];
      if (!active) return;
      active.style.transform = 'scale(1.04)';
      setTimeout(() => { active.style.transform = 'scale(1)'; }, 320);
    };

    prev?.addEventListener('click', () => show(current - 1));
    next?.addEventListener('click', () => show(current + 1));
    dots.forEach((d) => d.addEventListener('click', () => show(Number(d.dataset.index || 0))));
    thumbs.forEach((t) => t.addEventListener('click', () => show(Number(t.dataset.index || 0))));

    // Flèches clavier
    document.addEventListener('keydown', (e) => {
      if (slides.length < 2) return;
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });

    // Swipe tactile
    let touchStartX = 0;
    gallery.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    gallery.addEventListener('touchend', (e: TouchEvent) => {
      if (slides.length < 2) return;
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) show(dx < 0 ? current + 1 : current - 1);
    });

    // Sélecteur de taille — change la vraie photo selon le format sélectionné
    // (comme sur le site officiel) + fallback en échelle CSS si pas d'image.
    const sizeTag = document.getElementById('current-size-tag');
    const sizeLabel = document.getElementById('current-size-label');
    const mainSlide = document.getElementById('main-slide') as HTMLImageElement | null;
    const firstSlide = slides[0];

    const scaleForCl = (cl: number): number => {
      if (cl <= 20) return 0.78;
      if (cl <= 50) return 0.93;
      if (cl <= 70) return 1.0;
      if (cl <= 100) return 1.1;
      return 1.22;
    };

    // Crossfade doux vers une nouvelle image (précharge avant d'animer)
    const crossfadeMainTo = (newSrc: string) => {
      if (!mainSlide) return;
      if (mainSlide.getAttribute('src') === newSrc) return;
      const preload = new Image();
      preload.onload = () => {
        mainSlide.style.opacity = '0';
        window.setTimeout(() => {
          mainSlide.src = newSrc;
          mainSlide.style.opacity = '1';
        }, 200);
      };
      preload.src = newSrc;
    };

    const applySize = (pill: HTMLButtonElement) => {
      const cl = Number(pill.dataset.sizeCl || 70);
      const label = pill.dataset.size || '';
      const sizeImage = pill.dataset.sizeImage;

      if (sizeImage) {
        // Vraie photo par taille disponible : on change l'image et on
        // réinitialise l'échelle (la photo communique déjà le format).
        crossfadeMainTo(sizeImage);
        if (firstSlide) firstSlide.style.transform = 'scale(1)';
      } else {
        // Fallback : on simule le format par une mise à l'échelle CSS
        const scale = scaleForCl(cl);
        if (firstSlide) {
          firstSlide.style.transformOrigin = 'center bottom';
          firstSlide.style.transform = `scale(${scale})`;
        }
      }

      if (sizeTag) sizeTag.style.opacity = '1';
      if (sizeLabel) sizeLabel.textContent = label;
    };

    sizePills.forEach((pill) => {
      pill.addEventListener('click', () => {
        sizePills.forEach((p) => {
          p.classList.remove('border-forest-700', 'bg-forest-800', 'text-cream-100', 'shadow-sm');
          p.classList.add('border-forest-200', 'text-ink-700', 'hover:border-forest-500', 'hover:bg-forest-50');
        });
        pill.classList.remove('border-forest-200', 'text-ink-700', 'hover:border-forest-500', 'hover:bg-forest-50');
        pill.classList.add('border-forest-700', 'bg-forest-800', 'text-cream-100', 'shadow-sm');
        applySize(pill as HTMLButtonElement);
        // Revenir sur la vue packshot si la vue d'ambiance est visible
        if (slides.length > 1) show(0);
      });
    });

    // Init : transitions + taille par défaut (70cl si présent, sinon premier)
    slides.forEach((el) => {
      el.style.transition = 'opacity 500ms ease-in-out, transform 380ms cubic-bezier(0.16, 1, 0.3, 1)';
    });
    const defaultPill =
      sizePills.find((p) => (p.dataset.size || '').includes('70')) || sizePills[0];
    if (defaultPill) {
      // État actif visuel sur la pill 70cl sans déclencher le crossfade
      sizePills.forEach((p) => {
        p.classList.remove('border-forest-700', 'bg-forest-800', 'text-cream-100', 'shadow-sm');
        p.classList.add('border-forest-200', 'text-ink-700', 'hover:border-forest-500', 'hover:bg-forest-50');
      });
      defaultPill.classList.remove('border-forest-200', 'text-ink-700', 'hover:border-forest-500', 'hover:bg-forest-50');
      defaultPill.classList.add('border-forest-700', 'bg-forest-800', 'text-cream-100', 'shadow-sm');
      if (sizeTag && defaultPill.dataset.size) {
        sizeTag.style.opacity = '1';
        if (sizeLabel) sizeLabel.textContent = defaultPill.dataset.size;
      }
    }
  })();
</script>
