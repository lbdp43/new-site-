---
/**
 * Page-pilier : "Apéritif artisanal — Le guide de l'apéritif aux plantes"
 *
 * Cible SEO :
 *  - "apéritif maison" (500-1.5k recherches/mois en France)
 *  - "apéritif amer" (500-1.5k/mois)
 *  - "apéritif artisanal" (200-500/mois)
 *  - "apéritif aux plantes" (100-300/mois)
 *  - "apéritif spritz maison" (200-500/mois)
 *
 * Volume potentiel cumulé : 1.5-4k visites organiques/mois.
 *
 * Couvre les 7 produits LBDP de la gamme apéritif :
 *  - Cerf'Gent, Pralicoquine, Menthor, Zéleste (gamme Apéritif)
 *  - Nectar d'Ostara, La Lime des Prés, La Flèche Ardente (gamme Brasserie
 *    en mode apéritif)
 *
 * Schema émis : Article + FAQPage + BreadcrumbList.
 */

import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';

const title = "Apéritif artisanal aux plantes — Le guide de l'apéritif maison | La Brasserie des Plantes";
const description = "Quel apéritif servir ? Apéritif amer, apéritif maison, spritz artisanal, apéritif aux plantes — guide complet pour choisir et servir un vrai apéritif artisanal français aux plantes.";

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Apéritif artisanal', item: `${site.url}/aperitif-artisanal` },
  ],
};

const faq = [
  {
    q: "Qu'est-ce qu'un apéritif artisanal ?",
    a: "Un apéritif artisanal est une boisson alcoolisée de petit volume, prise avant le repas pour ouvrir l'appétit, fabriquée en petite série par un producteur indépendant (sans arôme ni colorant industriel). En France, le titre alcoolique tourne autour de 15° à 22°, et la composition repose sur des plantes amères (gentiane, quinquina, écorces) ou aromatiques (verveine, fleurs, agrumes). Les apéritifs amers comme le Cerf'Gent, la Suze ou le Salers entrent dans cette catégorie ; les apéritifs floraux comme le Nectar d'Ostara aussi.",
  },
  {
    q: "Quelle est la différence entre apéritif et digestif ?",
    a: "L'apéritif se prend avant le repas et a pour fonction de stimuler l'appétit (titre 15-22°, plutôt amer ou frais). Le digestif se prend après le repas pour faciliter la digestion (titre 25-50°, souvent plus sucré, racinaire ou herbacé). Beaucoup de plantes peuvent jouer les deux rôles selon le dosage et le degré d'alcool — c'est notamment le cas de la verveine, de la mélisse et de la gentiane.",
  },
  {
    q: "Comment servir un apéritif amer ?",
    a: "Un apéritif amer (gentiane, quinquina) se sert très frais (3-5°C) pour atténuer l'amertume et tendre la bouche. Trois usages classiques : (1) pur sur glace dans un verre tulipé, 4 cl ; (2) en spritz amer — 4 cl d'amer + 6 cl de tonic Indian (Fever-Tree) + zeste d'orange ; (3) en cocktail amer-doux type Negroni ou Americano. Toujours en début de soirée, accompagné d'olives, charcuterie sèche ou fromage affiné.",
  },
  {
    q: "Quel apéritif maison choisir pour un débutant ?",
    a: "Pour quelqu'un qui découvre les apéritifs aux plantes, commencer par un apéritif floral et léger — le Nectar d'Ostara (sureau, bleuet, fleurs blanches) ou le Zéleste (trio d'agrumes) sont d'accès immédiat, pas trop amers, magnifiques en spritz avec du Prosecco. Les amers (Cerf'Gent gentiane, Pralicoquine praline-amande) demandent une habitude de palais — à venir dans un second temps.",
  },
  {
    q: "Spritz maison : quelle proportion ?",
    a: "La règle italienne est 3-2-1 : 3 mesures de Prosecco, 2 mesures de liqueur amère ou florale, 1 mesure d'eau pétillante (ou tonic). Soit pour un grand verre à vin : 9 cl de Prosecco + 6 cl de liqueur (Aperol traditionnel, ou Cerf'Gent / Nectar d'Ostara / Zéleste pour une version artisanale française) + 3 cl de tonic Indian. Glaçons généreux, zeste d'orange, feuille de basilic. Sert très frais dans les 5 minutes après préparation — le Prosecco perd sa pétillance vite.",
  },
  {
    q: "Combien de temps se conserve un apéritif artisanal ?",
    a: "Un apéritif aux plantes se conserve 2 à 5 ans selon le titre alcoolique : un apéritif à 15-18° (notre Lime des Prés, La Flèche Ardente) doit être consommé dans les 2 ans après ouverture, idéalement au frais. Un amer à 22-30° (Cerf'Gent, Pralicoquine) tient 3-5 ans. Toujours conserver à l'abri de la lumière directe (les arômes d'agrumes et fleurs sont photosensibles) et à température fraîche (10-15°C). Une fois ouvert, l'amertume reste stable mais les notes florales s'estompent au fil des mois.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Apéritif artisanal — Le guide de l\'apéritif maison aux plantes',
  description,
  author: { '@id': `${site.url}#localbusiness` },
  publisher: { '@id': `${site.url}#localbusiness` },
  datePublished: '2026-04-28',
  dateModified: '2026-04-28',
  inLanguage: 'fr-FR',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${site.url}/aperitif-artisanal`,
  },
};

const schema = [breadcrumb, articleSchema, faqSchema];

const familles = [
  {
    titre: 'Les amers — la tradition française',
    description: "L'apéritif amer est une institution française. Gentiane, quinquina, racines amères : ils stimulent l'appétit en sollicitant les papilles avant que le repas n'arrive. Servis très frais (3-5°C), ils ouvrent la bouche.",
    products: [
      { slug: 'cerf-gent', name: "Le Cerf'Gent", angle: 'Gentiane jaune + quinquina + zestes — 15° — Médaille d\'Or CGA 2025' },
      { slug: 'pralicoquine', name: 'La Pralicoquine', angle: 'Praline + amande + amers — 15° — pour les amateurs de Suze qui veulent essayer autre chose' },
    ],
  },
  {
    titre: 'Les floraux — pour le spritz et l\'été',
    description: 'Sureau, bleuet, fleur blanche : les apéritifs floraux sont la base d\'un spritz maison réussi. Plus accessibles qu\'un amer, plus intéressants qu\'un sirop, ils accompagnent l\'apéritif estival sans alourdir.',
    products: [
      { slug: 'nectar-ostara', name: "Le Nectar d'Ostara", angle: 'Sureau + bleuet + fleurs blanches — 24° — apéritif printemps/été par excellence' },
    ],
  },
  {
    titre: 'Les agrumes — fraîcheur immédiate',
    description: 'Citron, citron vert, orange, combava : les apéritifs aux agrumes sont les plus universels. Ils marchent en spritz, en tonic, en pur sur glace, et accompagnent à peu près tous les amuse-bouches d\'été.',
    products: [
      { slug: 'zeleste', name: 'Le Zéleste', angle: 'Trio de zestes (citron jaune, citron vert, orange) — 17,5° — version artisanale du Triple Sec' },
      { slug: 'lime-des-pres', name: 'La Lime des Prés', angle: 'Mélisse + citron — 18° — léger, parfait sur glace ou en mojito sans rhum' },
    ],
  },
  {
    titre: 'Les herbacés — apéritif fraîcheur',
    description: 'Menthe, verveine, plantes mentholées : l\'apéritif herbacé est le moins alcoolisé, le plus rafraîchissant. À privilégier les soirs d\'été ou en début de soirée quand on veut éviter de tomber dans le repas trop vite.',
    products: [
      { slug: 'menthor', name: 'Le Menthor', angle: 'Trio de menthes (poivrée, verte, agastache) — 17,5° — alternative artisanale au Get 27' },
      { slug: 'fleche-ardente', name: 'La Flèche Ardente', angle: 'Fruits rouges + vanille — 27° — apéritif gourmand un peu plus structuré' },
    ],
  },
];
---
<Layout
  title={title}
  description={description}
  schema={schema}
>
  <!-- Breadcrumb -->
  <div class="bg-cream-50 py-5 border-b border-forest-100/60">
    <div class="max-w-5xl mx-auto px-6 text-xs text-ink-500">
      <a href="/" class="hover:text-forest-700">Accueil</a>
      <span class="mx-2">/</span>
      <span class="text-forest-700">Apéritif artisanal</span>
    </div>
  </div>

  <!-- Hero -->
  <section class="relative bg-gradient-to-b from-cream-100 via-cream-50 to-white py-20 md:py-28">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-xs uppercase tracking-[0.3em] text-forest-600 font-medium mb-4">
        Guide complet
      </div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-forest-900 mb-6 leading-[1.1]">
        Apéritif <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">artisanal</em>
      </h1>
      <p class="text-lg md:text-xl text-ink-700 leading-relaxed max-w-3xl">
        Apéritif amer, apéritif floral, apéritif aux agrumes ou aux plantes —
        sept de nos liqueurs sont conçues pour le moment-clé d'avant repas.
        Voici le guide complet de l'<strong>apéritif maison artisanal</strong>
        à la française : familles, recettes, accords, comment servir un
        spritz maison réussi, et toutes nos références.
      </p>
    </div>
  </section>

  <!-- Intro générale -->
  <section class="py-16 bg-white border-y border-forest-100/60">
    <div class="max-w-3xl mx-auto px-6 prose prose-lg max-w-none
                prose-headings:font-display prose-headings:text-forest-900
                prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:tracking-tight
                prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                prose-p:text-ink-700 prose-p:leading-relaxed
                prose-a:text-forest-700 prose-a:underline prose-a:decoration-forest-300 prose-a:underline-offset-4
                prose-strong:text-forest-900 prose-strong:font-medium">
      <p>
        L'apéritif est un rituel français très ancien — la Suze a 135 ans,
        le Salers 140, et les apéritifs aux plantes existent depuis l'Antiquité
        sous des formes différentes. Mais les <strong>apéritifs artisanaux
        modernes</strong> — ceux qui sont fabriqués depuis 2018-2020 par
        des liquoristes indépendants comme nous — répondent à une demande
        nouvelle : des recettes plus aromatiques, moins sucrées, plus
        traçables, à dosage contemporain.
      </p>
      <h2>Apéritif maison : les 4 grandes familles</h2>
      <p>
        Avant d'attaquer les recettes, il faut savoir quel <strong>type
        d'apéritif</strong> on cherche. Quatre grandes familles structurent
        la palette française :
      </p>
      <ol>
        <li><strong>Les amers</strong> (gentiane, quinquina) : sec, structurant, ouvre l'appétit.</li>
        <li><strong>Les floraux</strong> (sureau, bleuet) : doux, parfumé, idéal en spritz.</li>
        <li><strong>Les agrumes</strong> (citron, orange) : universel, frais, marche partout.</li>
        <li><strong>Les herbacés</strong> (menthe, verveine) : léger, rafraîchissant, pour les soirs d'été.</li>
      </ol>
      <p>
        Chaque famille a ses usages, ses accords, ses règles de service.
        Voici nos sept apéritifs aux plantes, classés par famille.
      </p>
    </div>
  </section>

  <!-- Les 4 familles -->
  <section class="py-16 bg-cream-50/40">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">
          Notre gamme apéritif
        </div>
        <h2 class="font-display text-3xl md:text-4xl text-forest-900 leading-tight">
          Sept apéritifs aux <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">plantes</em>
        </h2>
      </div>

      <div class="space-y-12">
        {familles.map((f) => (
          <div>
            <h3 class="font-display text-2xl text-forest-900 mb-3">{f.titre}</h3>
            <p class="text-ink-700 leading-relaxed mb-6">{f.description}</p>
            <div class="grid sm:grid-cols-2 gap-5">
              {f.products.map((p) => (
                <a
                  href={`/boutique/${p.slug}`}
                  class="group block bg-white border border-forest-100/60 rounded-2xl p-5 hover:shadow-cream-lg transition-shadow"
                >
                  <h4 class="font-display text-xl text-forest-900 leading-tight mb-2 group-hover:text-forest-700 transition-colors">
                    {p.name}
                  </h4>
                  <p class="text-sm text-ink-600 leading-relaxed">{p.angle}</p>
                  <div class="mt-3 inline-flex items-center gap-2 text-xs font-medium text-forest-700">
                    Voir le produit
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Spritz maison — recette signature -->
  <section class="py-16 bg-white border-y border-forest-100/60">
    <div class="max-w-3xl mx-auto px-6 prose prose-lg max-w-none
                prose-headings:font-display prose-headings:text-forest-900
                prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:tracking-tight
                prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                prose-p:text-ink-700 prose-p:leading-relaxed
                prose-a:text-forest-700 prose-a:underline prose-a:decoration-forest-300 prose-a:underline-offset-4
                prose-strong:text-forest-900 prose-strong:font-medium
                prose-ul:my-3 prose-li:my-1">
      <h2>Le spritz maison : la règle 3-2-1</h2>
      <p>
        Le spritz est l'apéritif italien le plus universel — il a remplacé
        le kir dans 80 % des cafés français en moins de 10 ans. La règle
        de proportion classique est <strong>3-2-1</strong> : 3 mesures de
        Prosecco, 2 mesures de liqueur amère ou florale, 1 mesure d'eau
        pétillante (ou tonic). Pour un grand verre à vin :
      </p>
      <ul>
        <li><strong>9 cl de Prosecco</strong> bien frais</li>
        <li><strong>6 cl de liqueur</strong> (Cerf'Gent, Nectar d'Ostara, Zéleste — au choix)</li>
        <li><strong>3 cl de tonic Indian</strong> (Fever-Tree)</li>
        <li>Glaçons généreux, zeste d'orange ou de citron, feuille fraîche selon la liqueur choisie</li>
      </ul>
      <p>
        Le spritz se sert <strong>très frais</strong>, dans les 3-5 minutes
        après préparation. Le Prosecco perd sa pétillance vite — au-delà
        de 10 minutes, on a un cocktail plat. À reproduire avec n'importe
        laquelle de nos sept liqueurs apéritives. Voir aussi nos
        <a href="/cocktails">cinq recettes cocktails maison</a>.
      </p>
      <h2>Accords mets-apéritif</h2>
      <p>
        L'apéritif n'est jamais bu seul — c'est un moment social, donc
        culinaire. Voici nos accords préférés :
      </p>
      <ul>
        <li><strong>Apéritif amer (Cerf'Gent, Pralicoquine)</strong> — olives noires, charcuterie sèche (saucisson, jambon de Bayonne), fromage affiné (Comté 24 mois, Roquefort).</li>
        <li><strong>Apéritif floral (Nectar d'Ostara)</strong> — fromage frais (chèvre, mozzarella di bufala), tomates cerises, fruits rouges en brochette.</li>
        <li><strong>Apéritif aux agrumes (Zéleste, Lime des Prés)</strong> — fruits de mer (ceviche, tartare de daurade), feuilles de basilic, mozzarella.</li>
        <li><strong>Apéritif herbacé (Menthor)</strong> — concombre, tartare végétarien, fromage de chèvre frais aux herbes.</li>
      </ul>
    </div>
  </section>

  <!-- Tableau récap -->
  <section class="py-16 bg-cream-50/40">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-display text-2xl md:text-3xl text-forest-900 mb-3">
        Quel apéritif pour quel moment ?
      </h2>
      <p class="text-sm text-ink-500 mb-6 italic">
        Choisir selon la saison et le profil des invités.
      </p>
      <div class="overflow-x-auto bg-white rounded-2xl border border-forest-100/60">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-forest-200 text-left">
              <th class="py-3 px-4 font-display text-forest-900">Moment / occasion</th>
              <th class="py-3 px-4 font-display text-forest-900">Profil recommandé</th>
              <th class="py-3 px-4 font-display text-forest-900">Notre apéritif</th>
            </tr>
          </thead>
          <tbody class="text-ink-700">
            <tr class="border-b border-forest-100">
              <td class="py-3 px-4 align-top">Spritz d'été en terrasse</td>
              <td class="py-3 px-4 align-top">Floral léger</td>
              <td class="py-3 px-4 align-top"><a href="/boutique/nectar-ostara" class="text-forest-700 underline decoration-forest-300">Nectar d'Ostara</a></td>
            </tr>
            <tr class="border-b border-forest-100">
              <td class="py-3 px-4 align-top">Apéritif d'avant grand repas (gibier, plats riches)</td>
              <td class="py-3 px-4 align-top">Amer franc, sec</td>
              <td class="py-3 px-4 align-top"><a href="/boutique/cerf-gent" class="text-forest-700 underline decoration-forest-300">Cerf'Gent</a></td>
            </tr>
            <tr class="border-b border-forest-100">
              <td class="py-3 px-4 align-top">Apéritif de week-end relax</td>
              <td class="py-3 px-4 align-top">Agrumes universels</td>
              <td class="py-3 px-4 align-top"><a href="/boutique/zeleste" class="text-forest-700 underline decoration-forest-300">Zéleste</a></td>
            </tr>
            <tr class="border-b border-forest-100">
              <td class="py-3 px-4 align-top">Apéritif gourmand fin d'année</td>
              <td class="py-3 px-4 align-top">Praliné, doux-amer</td>
              <td class="py-3 px-4 align-top"><a href="/boutique/pralicoquine" class="text-forest-700 underline decoration-forest-300">Pralicoquine</a></td>
            </tr>
            <tr class="border-b border-forest-100">
              <td class="py-3 px-4 align-top">Apéritif soirée d'été chaude</td>
              <td class="py-3 px-4 align-top">Mentholé, rafraîchissant</td>
              <td class="py-3 px-4 align-top"><a href="/boutique/menthor" class="text-forest-700 underline decoration-forest-300">Menthor</a></td>
            </tr>
            <tr class="border-b border-forest-100">
              <td class="py-3 px-4 align-top">Apéritif léger, pas trop alcoolisé</td>
              <td class="py-3 px-4 align-top">Citron-mélisse, 18°</td>
              <td class="py-3 px-4 align-top"><a href="/boutique/lime-des-pres" class="text-forest-700 underline decoration-forest-300">La Lime des Prés</a></td>
            </tr>
            <tr>
              <td class="py-3 px-4 align-top">Apéritif sexy, dîner romantique</td>
              <td class="py-3 px-4 align-top">Fruits rouges, vanille</td>
              <td class="py-3 px-4 align-top"><a href="/boutique/fleche-ardente" class="text-forest-700 underline decoration-forest-300">La Flèche Ardente</a></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-cream-50">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">FAQ</div>
      <h2 class="font-display text-3xl md:text-4xl text-forest-900 mb-10 leading-tight">
        Questions <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">fréquentes</em>
      </h2>
      <div class="space-y-6">
        {faq.map((item) => (
          <details class="group bg-white border border-forest-100/60 rounded-xl">
            <summary class="cursor-pointer list-none flex items-start justify-between gap-4 p-5 md:p-6">
              <h3 class="font-display text-lg md:text-xl text-forest-900 leading-tight pr-2">
                {item.q}
              </h3>
              <svg class="flex-none w-5 h-5 text-forest-700 transition-transform group-open:rotate-45 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </summary>
            <p class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Mention Évin + CTA -->
  <section class="py-12 bg-white border-y border-forest-100/60">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-xs italic border-l-4 border-forest-500 pl-4 bg-forest-50 py-3 text-ink-700 leading-relaxed">
        <strong class="not-italic font-medium text-forest-900">L'abus d'alcool est dangereux pour la santé,
        à consommer avec modération.</strong>
        Vente d'alcool interdite aux mineurs. Un apéritif se prend en
        petite quantité (4 à 6 cl par verre) et n'est jamais une finalité
        en soi — c'est l'introduction d'un repas, pas un objectif de
        consommation.
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-16 bg-forest-900 text-cream-100 text-center">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-display text-3xl md:text-4xl mb-6 leading-tight">
        Toute notre gamme apéritif
      </h2>
      <p class="text-cream-200/90 leading-relaxed mb-8 max-w-2xl mx-auto">
        Sept apéritifs aux plantes, à 15-27° d'alcool, fabriqués artisanalement
        en Haute-Loire. Sans arôme, sans colorant. Le vrai apéritif maison
        français.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/boutique" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-cream-50 text-forest-900 hover:bg-cream-100 font-medium transition-colors">
          Voir toute la gamme
