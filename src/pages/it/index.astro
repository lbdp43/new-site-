---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: `${site.url}/it/`,
    inLanguage: 'it-IT',
    publisher: { '@id': `${site.url}#localbusiness` },
  },
];
---
<Layout
  lang="it"
  title="La Brasserie des Plantes | Liquori artigianali biologici — Haute-Loire, Francia"
  description="Liquori e infusioni artigianali di piante d'Alvernia. L'Alchimie Végétale, Miglior Digestivo del Mondo 2025. Produttore indipendente in Haute-Loire, Francia."
  schema={schema}
>
  <section class="py-24 bg-gradient-to-b from-forest-900 via-forest-800 to-forest-950 text-cream-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <img
        src="/images/brand/logo-clair-transparent.png"
        alt="La Brasserie des Plantes"
        class="mx-auto h-20 mb-8"
      />
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-500/15 border border-gold-500/40 text-gold-400 text-xs font-medium tracking-wide uppercase mb-8">
        Miglior Digestivo del Mondo 2025
      </div>
      <h1 class="font-display text-4xl md:text-5xl leading-tight mb-6 text-cream-100">
        Liquori artigianali<br />
        <em class="not-italic font-normal text-gold-400" style="font-family: var(--font-script);">di piante d'Alvernia</em>
      </h1>
      <p class="text-lg text-cream-200/80 leading-relaxed mb-10 max-w-2xl mx-auto">
        Da Saint-Didier-en-Velay (Haute-Loire, Francia), Étienne, Guillaume
        e Bastien compongono liquori e infusioni a partire da piante dimenticate
        dell'Alvernia. <em>L'Alchimie Végétale</em> è stata incoronata Miglior
        Digestivo del Mondo 2025 ai World Drinks Awards di Londra.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mb-12">
        <a href="/it/bottega" class="inline-flex items-center gap-2 px-7 py-4 rounded-full bg-cream-50 hover:bg-cream-100 text-forest-900 font-medium transition-all">
          Scopri la bottega
        </a>
        <a href="/it/la-nostra-storia" class="inline-flex items-center gap-2 px-7 py-4 rounded-full border border-cream-100/30 hover:border-cream-100/60 text-cream-100 font-medium transition-colors">
          La nostra storia
        </a>
      </div>
      <div class="pt-8 border-t border-cream-100/10 text-sm text-cream-200/60">
        Il sito è in corso di traduzione in italiano. Nel frattempo, puoi anche
        visitare la versione <a href="/" class="underline hover:text-cream-100">francese</a>
        o <a href="/en/" class="underline hover:text-cream-100">inglese</a>.
      </div>
    </div>
  </section>
</Layout>
