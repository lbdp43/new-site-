---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import GoogleReviewsEmbed from '../components/GoogleReviewsEmbed.astro';
import ProductCarousel from '../components/ProductCarousel.astro';
import PressStrip from '../components/PressStrip.astro';
import { site } from '../data/site';
import { featuredProducts, products } from '../data/products';
import { buildAggregateRatingSchema } from '../lib/featurable';

// AggregateRating injecté UNIQUEMENT à partir des vrais avis Google
// (via Featurable). Si l'API est down ou le widget non configuré, on
// renvoie null et la propriété est omise du schema — pas d'invention
// de valeurs (pénalité manuelle Google sur les rich-snippets factices).
// On l'attache au LocalBusiness/Organization (brand-level), PAS au
// Product schema (les avis Google ne sont pas split par SKU — attacher
// la note brand sur chaque Product = inflation artificielle = sanction).
const aggregateRating = await buildAggregateRatingSchema();

// LocalBusiness + Organization fusionnés dans un seul bloc pour éviter la
// double entité dans le Knowledge Graph. On garde toutes les propriétés
// (horaires, paiements, zone, fondateurs, GBP) et on y ajoute l'award.
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'Organization'],
  '@id': `${site.url}#localbusiness`,
  name: site.name,
  alternateName: [site.shortName, 'Liquoristes artisanaux du Velay'],
  description: site.defaultDescription,
  slogan: site.slogan,
  // Keywords lus par le Knowledge Graph et certains crawlers IA. Mots-clés
  // génériques de la profession (liqueur artisanale, digestif artisanal…)
  // ancrés sur le terroir local (Auvergne, Haute-Loire).
  keywords: site.keywords.join(', '),
  image: [new URL(site.defaultOgImage, site.url).toString()],
  logo: new URL('/images/brand/logo-complet-fond-blanc.webp', site.url).toString(),
  url: site.url,
  telephone: site.phone,
  email: site.email,
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Credit Card, Apple Pay, Google Pay, PayPal, SEPA',
  foundingDate: site.founded,
  founders: site.founders.map((f) => ({ '@type': 'Person', name: f })),
  award: `${site.award.title} ${site.award.year} — ${site.award.issuer}`,
  sameAs: [site.social.instagram, site.social.facebook, site.googleBusiness.url],
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    postalCode: site.address.postalCode,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  hasMap: site.googleBusiness.url,
  // Place ID officiel de la fiche Google Business Profile — signal fort
  // pour relier ce LocalBusiness à la fiche Maps + GBP (colocalisation).
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'Google Place ID',
    value: site.googleBusiness.placeId,
  },
  // Horaires structurés uniquement — plus riches que `openingHours` (string),
  // utilisés par Google Maps + assistants vocaux ("quand est-ce que La
  // Brasserie des Plantes est ouverte ?"). On ne duplique plus avec
  // `openingHours` simple — l'audit schema avait flagué le doublon.
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Wednesday', 'Friday', 'Saturday'],
      opens: '09:00',
      closes: '18:30',
    },
  ],
  areaServed: [
    { '@type': 'Country', name: 'France' },
    { '@type': 'Country', name: 'Belgium' },
    { '@type': 'Country', name: 'Switzerland' },
    { '@type': 'Country', name: 'Luxembourg' },
  ],
  // SIRET = identifiant fiscal français (taxID). PAS de vatID : un VAT
  // intracommunautaire FR est calculé (FR + clé + SIREN), différent du
  // SIRET. À ajouter le jour où LBDP fournit son numéro TVA réel.
  taxID: site.siret,
  // AggregateRating Google injecté seulement si Featurable a répondu OK.
  // Spread conditionnel : la propriété n'est pas émise du tout si null.
  ...(aggregateRating ? { aggregateRating } : {}),
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  alternateName: 'Liqueurs artisanales La Brasserie des Plantes',
  url: site.url,
  inLanguage: 'fr-FR',
  publisher: { '@id': `${site.url}#localbusiness` },
  // SearchAction → éligibilité au "sitelinks search box" Google. La cible
  // pointe vers /boutique avec un paramètre ?q= (filtrage côté client sur
  // les 18 produits).
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${site.url}/boutique?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};

// VideoObject — vidéo de présentation atelier (lbdp-pro.mp4), indexable par
// Google Video + AI Overviews
const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: "Visite de l'atelier — La Brasserie des Plantes",
  description:
    "Tour des cuves, du séchage des plantes et de l'embouteillage dans notre atelier de Saint-Didier-en-Velay (Haute-Loire).",
  thumbnailUrl: new URL('/videos/lbdp-pro-poster.jpg', site.url).toString(),
  contentUrl: new URL('/videos/lbdp-pro.mp4', site.url).toString(),
  uploadDate: '2025-04-18',
  duration: 'PT1M32S',
  inLanguage: 'fr-FR',
  publisher: { '@id': `${site.url}#localbusiness` },
};

const schema = [localBusinessSchema, websiteSchema, videoSchema];
---
<Layout
  title="La Brasserie des Plantes — Liqueurs artisanales aux plantes oubliées (Haute-Loire)"
  description="Liqueur de verveine, de gentiane, de menthe, digestif aux 27 plantes (Meilleur Digestif du Monde 2025). Liqueurs artisanales fabriquées à la main en Haute-Loire, à partir de plantes oubliées sourcées auprès de cueilleurs et maraîchers partenaires. Boutique en ligne, livraison offerte dès 65 €."
  schema={schema}
  hasHero={true}
  preloadImage="/videos/lbdp-pro-poster.jpg"
>
  <!-- HERO VIDÉO plein écran — même pattern que /professionnels : vidéo en
       background + overlay sombre + contenu centré (badge + H1 + intro + CTAs). -->
  <section class="relative min-h-[100dvh] w-full overflow-hidden bg-forest-950">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/videos/lbdp-pro-poster.jpg"
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="/videos/lbdp-pro.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-forest-950/70 via-forest-950/40 to-forest-950/80"></div>

    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6 text-cream-100 py-20 min-h-[100dvh]">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-500/20 border border-gold-500/50 text-gold-400 text-xs font-medium tracking-[0.2em] uppercase mb-6 backdrop-blur-sm">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
        Meilleur Digestif du Monde 2025
      </div>
      <img
        src="/images/brand/logo-mark.webp"
        alt="La Brasserie des Plantes — emblème"
        width="527"
        height="600"
        class="h-24 md:h-32 lg:h-36 w-auto mb-6 drop-shadow-[0_6px_24px_rgba(0,0,0,0.45)]"
        loading="eager"
        decoding="async"
      />
      <h1 class="font-display leading-[1.05] mb-6">
        <em class="not-italic text-cream-50 font-normal block text-5xl sm:text-6xl md:text-7xl lg:text-8xl sm:whitespace-nowrap leading-[1.1]" style="font-family: var(--font-script);">La Brasserie des Plantes</em>
        <span class="text-gold-400 block text-3xl sm:text-4xl md:text-6xl lg:text-7xl mt-3 leading-tight">Artisanat, Terroir<br />Passion</span>
      </h1>
      <p class="text-lg md:text-xl text-cream-100/90 max-w-2xl leading-relaxed mb-10">
        Depuis Saint-Didier-en-Velay, nous composons des liqueurs et infusions
        à partir de plantes oubliées, sourcées chez nos cueilleurs et maraîchers
        partenaires. L'Alchimie Végétale, couronnée
        <strong class="text-gold-300 font-medium">Meilleur Digestif du Monde 2025</strong>
        aux World Drinks Awards.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/boutique" class="inline-flex items-center gap-2 px-7 py-4 rounded-full bg-cream-50 text-forest-900 hover:bg-cream-100 font-medium transition-all shadow-xl">
          Découvrir la boutique
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
        </a>
        <a href="/notre-histoire" class="inline-flex items-center gap-2 px-7 py-4 rounded-full border border-cream-100/50 hover:bg-cream-100/10 text-cream-100 font-medium transition-colors backdrop-blur-sm">
          Notre histoire
        </a>
      </div>
    </div>
  </section>

  <!-- CAROUSEL PRODUITS — découverte rapide après le hero -->
  <ProductCarousel
    items={products.filter((p) => p.range !== 'accessoire')}
    kicker="Notre gamme complète"
    heading="Dix-huit flacons, quatre gammes"
    subtitle="Parcourez toutes nos liqueurs, de la Brasserie signature à la Lumière Obscure."
  />

  <!-- HISTOIRE -->
  <section class="py-24 bg-cream-50">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="gold-divider mb-8">
        <span class="font-display italic text-xs uppercase tracking-[0.3em] text-gold-600">Notre savoir-faire</span>
      </div>
      <h2 class="font-display text-4xl md:text-5xl text-forest-900 mb-8 leading-tight">
        Des plantes oubliées,<br />assemblées avec patience.
      </h2>
      <div class="space-y-6 text-lg text-ink-700 leading-relaxed">
        <p>
          La Brasserie des Plantes est née en {site.founded} dans un petit village
          de la <strong class="font-medium text-forest-800">Haute-Loire</strong>, à Saint-Didier-en-Velay.
          Deux amis d'enfance — Étienne et Guillaume — réunis autour d'une idée
          simple : faire revivre les plantes médicinales et aromatiques que nos
          grand-mères préparaient, et les inviter dans la mixologie contemporaine.
        </p>
        <p>
          Étienne, biotechnologue des plantes formé à Toulouse, choisit,
          compose et conduit la production. Guillaume, ancien de la
          restauration, imagine les accords et les usages. Ensemble, ils
          travaillent avec une
          <strong class="font-medium text-forest-800">quarantaine de plantes, racines,
          écorces, fleurs et épices</strong> — verveine, serpolet, gentiane,
          génépi, hysope, sureau… — récoltées par des cueilleurs et des
          maraîchers choisis un par un.
        </p>
        <p>
          En 2025, leur liqueur phare <em>L'Alchimie Végétale</em> remporte
          le titre de <strong class="font-medium text-gold-600">Meilleur Digestif du Monde</strong>
          aux World Drinks Awards — une reconnaissance internationale pour
          un terroir discret, confirmée par le palais des plus grands jurys.
        </p>
      </div>
      <div class="mt-10 flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm">
        <a href="/notre-histoire" class="inline-flex items-center gap-1.5 text-forest-700 hover:text-forest-900 font-medium border-b border-forest-300 hover:border-forest-700 pb-0.5 transition-colors">
          Notre histoire
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/nos-plantes" class="inline-flex items-center gap-1.5 text-forest-700 hover:text-forest-900 font-medium border-b border-forest-300 hover:border-forest-700 pb-0.5 transition-colors">
          Toutes nos plantes
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/lumiere-obscure" class="inline-flex items-center gap-1.5 text-forest-700 hover:text-forest-900 font-medium border-b border-forest-300 hover:border-forest-700 pb-0.5 transition-colors">
          Gamme CBD Lumière Obscure
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/ateliers" class="inline-flex items-center gap-1.5 text-forest-700 hover:text-forest-900 font-medium border-b border-forest-300 hover:border-forest-700 pb-0.5 transition-colors">
          Venir faire un atelier
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- VIDÉO DE PRÉSENTATION — version longue (même que la page pros) -->
  <section class="relative py-0 bg-forest-950 overflow-hidden">
    <div class="relative w-full aspect-[21/9] md:aspect-[21/8] max-h-[85vh]">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="none"
        poster="/videos/lbdp-intro-poster.jpg"
        class="absolute inset-0 w-full h-full object-cover"
      >
        <source src="/videos/lbdp-intro.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-b from-forest-950/65 via-forest-950/25 to-forest-950/80"></div>
      <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6 text-cream-100">
        <span style="font-family: var(--font-script);" class="text-gold-400 text-3xl md:text-4xl mb-3">— Dans notre atelier —</span>
        <h2 class="font-display text-4xl md:text-6xl leading-tight max-w-4xl mb-4 text-cream-100">
          Chaque flacon, une histoire<br /><em class="not-italic text-gold-400 font-normal" style="font-family: var(--font-script);">faite main</em>
        </h2>
        <p class="text-cream-100/85 text-base md:text-lg max-w-2xl leading-relaxed">
          Récolte, composition, assemblage, embouteillage — tout se passe
          à Saint-Didier-en-Velay, entre nos quatre mains.
        </p>
      </div>
    </div>
  </section>

  <!-- AVIS GOOGLE — placés juste après le bandeau vidéo "chaque flacon une histoire faite main" -->
  <GoogleReviewsEmbed />

  <!-- COFFRET DIY — teaser éditorial sobre (cream on cream, bouteilles empilées) -->
  <section class="py-20 md:py-28 bg-cream-50 relative overflow-hidden">
    <!-- Filet décoratif très subtil -->
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-forest-200 to-transparent" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-6 grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-20 items-center">
      <!-- Colonne gauche : copy minimal -->
      <div>
        <div class="text-[10px] uppercase tracking-[0.35em] text-gold-600 font-medium mb-5">
          Coffret sur-mesure
        </div>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.05] text-forest-900 mb-6">
          Composez<br />
          <em class="not-italic font-normal text-forest-600" style="font-family: var(--font-script);">votre propre coffret</em>
        </h2>
        <p class="text-ink-700 text-base md:text-lg leading-relaxed mb-10 max-w-md">
          Trois liqueurs au choix parmi notre gamme. Nos bouteilles s'empilent
          naturellement — un cadeau unique, prêt à offrir.
        </p>
        <div class="flex flex-wrap gap-3 items-center">
          <a
            href="/composer-mon-coffret"
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-forest-900 hover:bg-forest-800 text-cream-50 text-sm font-medium transition-colors group"
          >
            Composer mon coffret
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <a
            href="/boutique?range=accessoire"
            class="inline-flex items-center gap-1.5 px-5 py-3.5 text-forest-800 hover:text-forest-900 text-sm font-medium underline decoration-gold-500 decoration-1 underline-offset-4 hover:decoration-2 transition-all"
          >
            Voir les coffrets prêts
          </a>
        </div>
      </div>

      <!-- Colonne droite : 3 bouteilles 20cl empilées (palets pré-croppés).
           Z-index décroissant du haut vers le bas : la bouteille du top
           domine celle du milieu, qui domine celle du bas. Sans ça, l'ordre
           DOM naturel ferait l'inverse (la dernière serait au-dessus).
           mt négatif 27% = 22% × ratio_hauteur 1.22 pour vrai overlap
           proportionnel à la hauteur de l'image. -->
      <div class="relative flex items-center justify-center">
        <div class="relative" style="width: 120px;">
          <!-- Top (z=3 : domine le reste) -->
          <img
            src="/images/products/sizes/alchimie-vegetale-20cl-stack.webp"
            alt="L'Alchimie Végétale — format empilable 20cl"
            class="relative block mx-auto w-full h-auto"
            style="filter: drop-shadow(0 8px 14px rgba(10, 107, 67, 0.22)); z-index: 3;"
            loading="lazy"
          />
          <!-- Milieu (z=2) -->
          <img
            src="/images/products/sizes/nectar-ostara-20cl-stack.webp"
            alt="Le Nectar d'Ostara — format empilable 20cl"
            class="relative block mx-auto w-full h-auto -mt-[27%]"
            style="filter: drop-shadow(0 8px 14px rgba(10, 107, 67, 0.22)); z-index: 2;"
            loading="lazy"
          />
          <!-- Bas (z=1 : sous les autres) -->
          <img
            src="/images/products/sizes/cerf-gent-20cl-stack.webp"
            alt="Le Cerf'Gent — format empilable 20cl"
            class="relative block mx-auto w-full h-auto -mt-[27%]"
            style="filter: drop-shadow(0 8px 14px rgba(10, 107, 67, 0.22)); z-index: 1;"
            loading="lazy"
          />
          <!-- Ombre au sol -->
          <div
            class="mx-auto mt-1.5 h-2.5 rounded-full pointer-events-none"
            style="width: 85%; background: radial-gradient(ellipse, rgba(10, 107, 67, 0.28), transparent 65%);"
            aria-hidden="true"
          ></div>
        </div>
      </div>
    </div>
  </section>

  <!-- COCKTAILS -->
  <section class="py-24 bg-cream-100/60">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">Mixologie</div>
        <h2 class="font-display text-4xl md:text-5xl text-forest-900 mb-6 leading-tight">
          Nos liqueurs<br />en cocktails
        </h2>
        <p class="text-lg text-ink-700 leading-relaxed mb-8">
          Cinq recettes imaginées par nos soins — du Spritz Efflorescent au
          Black Mule, en passant par le Philtre d'Éros. Chaque cocktail met
          en lumière l'une de nos liqueurs.
        </p>
        <a href="/cocktails" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-forest-700/40 hover:border-forest-700 text-forest-900 font-medium transition-colors">
          Découvrir les recettes
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <a href="/cocktails#spritz-efflorescent" class="group aspect-square rounded-2xl overflow-hidden relative bg-forest-50 hover:shadow-xl transition-shadow">
          <img src="/images/cocktails/spritz-efflorescent.webp" alt="Cocktail Le Spritz Efflorescent" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest-900/80 via-forest-900/20 to-transparent"></div>
          <h3 class="absolute bottom-4 left-4 right-4 font-display text-lg text-cream-50 leading-tight">Spritz Efflorescent</h3>
        </a>
        <a href="/cocktails#verveine-printaniere" class="group aspect-square rounded-2xl overflow-hidden relative mt-8 bg-forest-50 hover:shadow-xl transition-shadow">
          <img src="/images/cocktails/verveine-printaniere.webp" alt="Cocktail La Verveine Printanière" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest-900/80 via-forest-900/20 to-transparent"></div>
          <h3 class="absolute bottom-4 left-4 right-4 font-display text-lg text-cream-50 leading-tight">Verveine Printanière</h3>
        </a>
        <a href="/cocktails#philtre-eros" class="group aspect-square rounded-2xl overflow-hidden relative bg-forest-50 hover:shadow-xl transition-shadow">
          <img src="/images/cocktails/philtre-eros.webp" alt="Cocktail Le Philtre d'Éros" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest-900/80 via-forest-900/20 to-transparent"></div>
          <h3 class="absolute bottom-4 left-4 right-4 font-display text-lg text-cream-50 leading-tight">Philtre d'Éros</h3>
        </a>
        <a href="/cocktails#black-mule" class="group aspect-square rounded-2xl overflow-hidden relative mt-8 bg-forest-50 hover:shadow-xl transition-shadow">
          <img src="/images/cocktails/black-mule.webp" alt="Cocktail Le Black Mule" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest-900/80 via-forest-900/20 to-transparent"></div>
          <h3 class="absolute bottom-4 left-4 right-4 font-display text-lg text-cream-50 leading-tight">Black Mule</h3>
        </a>
      </div>
    </div>
  </section>

  <!-- VISITE BOUTIQUE — invite à venir à Saint-Didier, vidéo sortie boutique -->
  <section class="py-20 md:py-24 bg-cream-50">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="aspect-[4/5] sm:aspect-[4/3] lg:aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl bg-forest-950 order-2 lg:order-1">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="none"
          poster="/videos/boutique-sortie-poster.jpg"
          aria-label="Sortie de la boutique de La Brasserie des Plantes à Saint-Didier-en-Velay"
          class="w-full h-full object-cover"
        >
          <source src="/videos/boutique-sortie.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="order-1 lg:order-2">
        <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">Venez nous voir</div>
        <h2 class="font-display text-4xl md:text-5xl text-forest-900 leading-tight mb-6">
          Notre boutique, au cœur du <em class="not-italic text-forest-600 font-normal" style="font-family: var(--font-script);">Velay</em>
        </h2>
        <p class="text-lg text-ink-700 leading-relaxed mb-8">
          On vous accueille au {site.address.street} à {site.address.city}, à deux pas de la Grand Place.
          Dégustation libre, conseil sans pression, et toute la gamme disponible à l'unité —
          y compris les éditions confidentielles qu'on ne met pas en ligne.
        </p>
        <dl class="grid sm:grid-cols-2 gap-5 mb-10 text-sm">
          <div>
            <dt class="text-xs uppercase tracking-wider text-forest-600 font-medium mb-1.5">Adresse</dt>
            <dd class="text-ink-700 leading-relaxed">
              {site.address.street}<br />{site.address.postalCode} {site.address.city}
            </dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wider text-forest-600 font-medium mb-1.5">Horaires</dt>
            <dd class="text-ink-700 leading-relaxed">{site.hoursDisplay}</dd>
          </div>
        </dl>
        <div class="flex flex-wrap gap-3">
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.address.street + ', ' + site.address.postalCode + ' ' + site.address.city)}`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-forest-800 hover:bg-forest-900 text-cream-100 font-medium transition-colors"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Voir sur Google Maps
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-forest-700/40 hover:border-forest-700 text-forest-900 font-medium transition-colors">
            Nous contacter
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- INSTAGRAM -->
  <InstagramFeed variant="light" />

  <!-- CTA FINAL -->
  <section class="py-24 bg-gradient-to-br from-forest-800 via-forest-900 to-forest-950 text-cream-100 relative overflow-hidden">
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <span style="font-family: var(--font-script);" class="text-gold-400 text-2xl">— À votre table —</span>
      <h2 class="font-display text-4xl md:text-5xl mt-4 mb-6 leading-tight text-cream-100">
        Offrez une parenthèse<br />végétale.
      </h2>
      <p class="text-cream-200/80 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
        Flacons seuls, coffrets d'initiation, éditions limitées — livraison
        offerte dès 65 € d'achats, sous 2 à 3 jours ouvrés en France.
      </p>
      <a href="/boutique" class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-cream-50 hover:bg-cream-100 text-forest-900 font-medium transition-all hover:shadow-2xl">
        Explorer la boutique
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

  <!-- ILS PARLENT DE NOUS — bandeau presse avec logos des médias qui
       nous ont couverts. Les logos sont récupérés depuis les apple-touch-icon
       des sites (ou Google favicons en fallback) et stockés dans
       /public/images/press/. Clic → article le plus récent de ce média. -->
  <PressStrip />

  <!-- PRODUITS VEDETTES — sélection mise en avant en toute fin de page -->
  <section class="py-24 bg-gradient-to-b from-forest-50/50 to-cream-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
        <div>
          <div class="text-xs uppercase tracking-[0.25em] text-forest-600 font-medium mb-3">Sélection</div>
          <h2 class="font-display text-4xl md:text-5xl text-forest-900 leading-tight">Six flacons à découvrir</h2>
        </div>
        <a href="/boutique" class="inline-flex items-center gap-2 text-forest-700 hover:text-forest-900 font-medium">
          Voir tous les produits
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
        {featuredProducts.map((p) => <ProductCard product={p} />)}
      </div>
    </div>
  </section>
</Layout>
