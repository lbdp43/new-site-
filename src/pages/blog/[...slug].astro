---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Carte d'auteur : si l'auteur est un fondateur, on génère un Person schema ;
// sinon (La Brasserie des Plantes), on reste Organization.
const authorBios: Record<string, { role: string; description: string }> = {
  'Étienne': {
    role: 'Biotechnologue des plantes',
    description: "Cofondateur de La Brasserie des Plantes. Formé à la biotechnologie végétale à Toulouse, il compose les recettes et supervise les macérations.",
  },
  'Guillaume': {
    role: 'Accords et usages',
    description: "Cofondateur de La Brasserie des Plantes. Ancien restaurateur à Saint-Étienne, il conçoit les accords cocktails et le discours produit.",
  },
};

const authorSchema = authorBios[post.data.author]
  ? {
      '@type': 'Person',
      name: post.data.author,
      jobTitle: authorBios[post.data.author].role,
      description: authorBios[post.data.author].description,
      worksFor: { '@id': `${site.url}#localbusiness` },
    }
  : { '@type': 'Organization', name: post.data.author };

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated ?? post.data.date).toISOString(),
  author: authorSchema,
  publisher: { '@id': `${site.url}#localbusiness` },
  // Toujours fournir une image (fallback OG par défaut) pour garantir
  // l'éligibilité au rich result Article même si un article arrive sans cover.
  image: new URL(post.data.cover ?? '/og-default.jpg', site.url).toString(),
  wordCount: (post.body ?? '').split(/\s+/).filter(Boolean).length,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${site.url}/blog/${post.id}`,
  },
  articleSection: post.data.category,
  inLanguage: 'fr-FR',
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Actualité', item: `${site.url}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: `${site.url}/blog/${post.id}` },
  ],
};
---
<Layout
  title={`${post.data.title} | Actualité — ${site.name}`}
  description={post.data.description}
  ogImage={post.data.cover}
  ogType="article"
  schema={[articleSchema, breadcrumb]}
>
  <article>
    <!-- En-tête -->
    <header class="relative bg-gradient-to-b from-cream-50 to-cream-100 pt-16 pb-12">
      <div class="max-w-3xl mx-auto px-6">
        <nav class="text-xs text-ink-500 mb-6">
          <a href="/" class="hover:text-forest-700">Accueil</a>
          <span class="mx-2">/</span>
          <a href="/blog" class="hover:text-forest-700">Actualité</a>
          <span class="mx-2">/</span>
          <span class="text-forest-700">{post.data.category}</span>
        </nav>
        <div class="flex items-center gap-3 text-xs text-ink-500 mb-4">
          <span class="uppercase tracking-[0.25em] text-forest-600 font-medium">{post.data.category}</span>
          <span>·</span>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
          <span>·</span>
          <span>{post.data.readingTime} de lecture</span>
        </div>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-forest-900 leading-[1.1] mb-5">
          {post.data.title}
        </h1>
        <p class="text-lg text-ink-700 leading-relaxed italic max-w-2xl">
          {post.data.description}
        </p>
      </div>
    </header>

    {post.data.cover && (
      <div class="max-w-5xl mx-auto px-6 -mt-4 mb-12">
        <div class="aspect-[5/2] rounded-3xl overflow-hidden shadow-xl">
          <img src={post.data.cover} alt={post.data.title} class="w-full h-full object-cover" />
        </div>
      </div>
    )}

    <!-- Contenu -->
    <div class="max-w-2xl mx-auto px-6 pb-20">
      <div class="prose prose-lg max-w-none
                  prose-headings:font-display prose-headings:text-forest-900
                  prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:tracking-tight
                  prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                  prose-p:text-ink-700 prose-p:leading-relaxed
                  prose-a:text-forest-700 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
                  prose-strong:text-forest-900 prose-strong:font-medium
                  prose-em:text-forest-800
                  prose-blockquote:not-italic prose-blockquote:border-l-0 prose-blockquote:pl-0
                  prose-blockquote:my-6 prose-blockquote:rounded-xl
                  prose-blockquote:bg-cream-100 prose-blockquote:border prose-blockquote:border-forest-100
                  prose-blockquote:px-5 prose-blockquote:py-3
                  prose-blockquote:text-sm prose-blockquote:text-forest-800
                  prose-blockquote:shadow-cream
                  prose-ol:my-6 prose-li:my-1
                  prose-hr:border-forest-200 prose-hr:my-12">
        <Content />
      </div>
    </div>

    <!-- Auteur + retour -->
    <div class="max-w-2xl mx-auto px-6 pb-20">
      {authorBios[post.data.author] && (
        <div class="mt-6 p-6 rounded-2xl bg-cream-100 border border-forest-100/60 flex items-start gap-5">
          <div class="flex-none w-14 h-14 rounded-full bg-forest-800 text-gold-400 flex items-center justify-center font-display text-2xl">
            {post.data.author.charAt(0)}
          </div>
          <div class="flex-1">
            <div class="text-xs uppercase tracking-[0.25em] text-gold-600 font-medium mb-1">
              Écrit par
            </div>
            <div class="font-display text-xl text-forest-900">{post.data.author}</div>
            <div class="text-sm text-forest-700 mb-2">{authorBios[post.data.author].role}</div>
            <p class="text-sm text-ink-700 leading-relaxed">{authorBios[post.data.author].description}</p>
          </div>
        </div>
      )}

      <div class="pt-8 mt-8 border-t border-forest-200 flex flex-wrap items-center justify-between gap-4">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm text-forest-700 hover:text-forest-900 font-medium">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Retour à l'actualité
        </a>
        {post.data.updated && (
          <div class="text-xs text-ink-500 italic">
            Mis à jour le {post.data.updated.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </div>
        )}
      </div>
    </div>
  </article>

  <!-- CTA -->
  <section class="py-20 bg-forest-900 text-cream-100">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl mb-4">Découvrir nos liqueurs</h2>
      <p class="text-cream-200/80 mb-8">Les plantes dont on parle ici se retrouvent dans nos flacons.</p>
      <a href="/boutique" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-cream-50 text-forest-900 font-medium hover:bg-cream-100 transition-colors">
        Explorer la boutique
      </a>
    </div>
  </section>
</Layout>
