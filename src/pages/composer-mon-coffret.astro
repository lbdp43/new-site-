---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CoffretBuilder, { type CoffretProduct } from '../components/coffret/CoffretBuilder';
import { products } from '../data/products';
import { site } from '../data/site';

// Filtrer : uniquement les bouteilles (pas les accessoires), avec un wcId pour
// pouvoir être ajoutées au panier. On conserve Brasserie, Apéritifs, Lumière
// Obscure et Éditions limitées — toutes les bouteilles éligibles comme cadeau.
const eligibleProducts: CoffretProduct[] = products
  .filter((p) => p.range !== 'accessoire' && p.wcId !== undefined)
  .map((p) => ({
    slug: p.slug,
    name: p.name,
    range: p.range,
    priceMin: p.priceMin,
    image: p.image,
    // Photo du format empilable 20cl = vraie visualisation de l'USP.
    // Fallback sur l'image principale si pas disponible.
    stackImage: p.sizeImages?.[20],
    alcohol: p.alcohol,
    tagline: p.tagline,
    wcId: p.wcId as number,
    // Par défaut on commande la contenance 20cl (format empilable) si dispo,
    // sinon la plus petite disponible.
    defaultSize: p.sizeImages?.[20]
      ? 20
      : p.sizes && p.sizes.length > 0
        ? parseInt(p.sizes[0])
        : undefined,
    wcSizeAttribute: p.wcSizeAttribute,
  }));

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Composer mon coffret', item: `${site.url}/composer-mon-coffret` },
  ],
};

// Product schema bundle — on déclare un "concept" de coffret pour le SEO
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Coffret cadeau personnalisé — 3 bouteilles au choix',
  description: "Composez votre propre coffret : 3 liqueurs artisanales au choix parmi toute la gamme de La Brasserie des Plantes. Bouteilles empilables, livraison offerte dès 65 €.",
  image: new URL('/images/stories/coffret-diy-hero.webp', site.url).toString(),
  brand: { '@type': 'Brand', name: site.name },
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'EUR',
    lowPrice: '48',
    highPrice: '210',
    availability: 'https://schema.org/InStock',
    offerCount: eligibleProducts.length,
  },
};

const schema = [breadcrumb, productSchema];
---
<Layout
  title="Composez votre coffret | 3 bouteilles au choix — La Brasserie des Plantes"
  description="Créez votre propre coffret : choisissez 3 liqueurs artisanales parmi notre gamme de 18 références. Bouteilles empilables, livraison offerte dès 65 €."
  schema={schema}
>
  <PageHeader
    kicker="Coffret personnalisé"
    title="Composez<br /><em class='not-italic font-normal text-forest-600' style='font-family: var(--font-script);'>votre coffret</em>"
    subtitle="Trois bouteilles au choix parmi notre gamme. Nos bouteilles s'empilent naturellement — un cadeau unique, prêt à offrir ou à s'offrir."
    breadcrumb={[{ label: 'Accueil', href: '/' }, { label: 'Composer mon coffret' }]}
  />

  <section class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Bandeau d'explication — 3 étapes concises -->
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 rounded-2xl bg-cream-50 border border-forest-100/60">
          <div class="w-10 h-10 rounded-full bg-forest-100 text-forest-700 flex items-center justify-center mb-3 font-display text-lg">1</div>
          <h3 class="font-display text-lg text-forest-900 mb-1">Empilez vos bouteilles</h3>
          <p class="text-sm text-ink-700 leading-relaxed">3 ou plus selon votre envie. Toute la gamme est cliquable — digestifs, apéritifs, infusions CBD, éditions limitées.</p>
        </div>
        <div class="p-6 rounded-2xl bg-cream-50 border border-forest-100/60">
          <div class="w-10 h-10 rounded-full bg-forest-100 text-forest-700 flex items-center justify-center mb-3 font-display text-lg">2</div>
          <h3 class="font-display text-lg text-forest-900 mb-1">Format 20 cl empilable</h3>
          <p class="text-sm text-ink-700 leading-relaxed">Notre format breveté qui s'empile naturellement — préparé dans notre atelier à Saint-Didier-en-Velay.</p>
        </div>
        <div class="p-6 rounded-2xl bg-cream-50 border border-forest-100/60">
          <div class="w-10 h-10 rounded-full bg-forest-100 text-forest-700 flex items-center justify-center mb-3 font-display text-lg">3</div>
          <h3 class="font-display text-lg text-forest-900 mb-1">Expédition rapide</h3>
          <p class="text-sm text-ink-700 leading-relaxed">Livraison offerte dès 65 €, sous 2 à 3 jours ouvrés en France métropolitaine.</p>
        </div>
      </div>

      <!-- Builder (pile + grille + trios suggérés inclus) -->
      <CoffretBuilder products={eligibleProducts} size={3} lang="fr" client:load />
    </div>
  </section>
</Layout>
