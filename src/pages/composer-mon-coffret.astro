---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CoffretBuilder, { type CoffretProduct } from '../components/coffret/CoffretBuilder';
import { products } from '../data/products';
import { site } from '../data/site';

// Filtrer : bouteilles 20cl empilables uniquement. On exclut :
// - accessoire (coffrets/flasques, pas des liqueurs 20cl)
// - edition-limitee (les cuvées ne sont pas déclinées en 20cl)
// - lumiere-obscure (gamme CBD pas encore shootée en 20cl empilable)
// - les produits sans wcId (pas achetables via panier)
const eligibleProducts: CoffretProduct[] = products
  .filter(
    (p) =>
      p.range !== 'accessoire' &&
      p.range !== 'edition-limitee' &&
      p.range !== 'lumiere-obscure' &&
      p.wcId !== undefined
  )
  .map((p) => {
    // Détermine la contenance par défaut : 20cl si on a la photo empilable,
    // sinon la plus petite des sizes déclarées.
    const defaultSize = p.sizeImages?.[20]
      ? 20
      : p.sizes && p.sizes.length > 0
        ? parseInt(p.sizes[0])
        : undefined;
    // Cherche le LIBELLÉ exact de cette contenance dans p.sizes (ex:
    // "Empilable 20cl", "70cl", "Magnum 150cl"). WooCommerce matche la
    // variation sur ce libellé exact — si on envoie juste "20cl" alors que
    // WC a enregistré "Empilable 20cl", l'ajout panier échoue.
    const defaultSizeLabel =
      defaultSize != null && p.sizes
        ? p.sizes.find((s) => parseInt(s.replace(/[^0-9]/g, ''), 10) === defaultSize)
        : undefined;
    return {
      slug: p.slug,
      name: p.name,
      range: p.range,
      priceMin: p.priceMin,
      image: p.image,
      // Photo du format empilable 20cl — on utilise la version pré-croppée
      // (`-20cl-stack.webp` générée par scripts/crop-stack-images.mjs) qui
      // supprime tout le transparent autour de la bouteille → empilement
      // propre bout-à-bout. Fallback sur la version non-croppée ou l'image
      // principale si pas disponible.
      stackImage: p.sizeImages?.[20]
        ? p.sizeImages[20].replace('-20cl.webp', '-20cl-stack.webp')
        : undefined,
      alcohol: p.alcohol,
      tagline: p.tagline,
      wcId: p.wcId as number,
      defaultSize,
      defaultSizeLabel,
      wcSizeAttribute: p.wcSizeAttribute,
    };
  });

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Composer mon coffret', item: `${site.url}/composer-mon-coffret` },
  ],
};

// Product schema bundle — on déclare un "concept" de coffret pour le SEO
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Coffret cadeau personnalisé — 3 bouteilles au choix',
  description: "Composez votre propre coffret : 3 liqueurs artisanales au choix parmi toute la gamme de La Brasserie des Plantes. Bouteilles empilables, livraison offerte dès 65 €.",
  image: new URL('/images/products/sizes/alchimie-vegetale-20cl-stack.webp', site.url).toString(),
  brand: { '@type': 'Brand', name: site.name },
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'EUR',
    lowPrice: '48',
    highPrice: '210',
    availability: 'https://schema.org/InStock',
    offerCount: eligibleProducts.length,
  },
};

const schema = [breadcrumb, productSchema];
---
<Layout
  title="Composez votre coffret | 3 bouteilles au choix — La Brasserie des Plantes"
  description="Créez votre propre coffret : choisissez 3 liqueurs artisanales parmi notre gamme de 18 références. Bouteilles empilables, livraison offerte dès 65 €."
  schema={schema}
>
  <PageHeader
    kicker="Coffret personnalisé"
    title="Composez<br /><em class='not-italic font-normal text-forest-600' style='font-family: var(--font-script);'>votre coffret</em>"
    subtitle="Trois bouteilles au choix parmi notre gamme. Nos bouteilles s'empilent naturellement — un cadeau unique, prêt à offrir ou à s'offrir."
    breadcrumb={[{ label: 'Accueil', href: '/' }, { label: 'Composer mon coffret' }]}
  />

  <section class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Builder (pile + grille + trios suggérés inclus) -->
      <CoffretBuilder products={eligibleProducts} size={3} lang="fr" client:load />
    </div>
  </section>

  <!-- Bloc éditorial en bas de page — densifie le contenu statique
       (le builder au-dessus est une île React, son texte n'est pas
       indexable par les crawlers qui n'exécutent pas JS) et donne au
       visiteur le contexte du coffret après l'avoir manipulé. -->
  <section class="py-12 md:py-16 bg-cream-50/60 border-t border-forest-100/60">
    <div class="max-w-3xl mx-auto px-6 prose prose-lg max-w-none
                prose-headings:font-display prose-headings:text-forest-900
                prose-h2:text-2xl prose-h2:mt-8 prose-h2:mb-3 prose-h2:tracking-tight
                prose-p:text-ink-700 prose-p:leading-relaxed
                prose-a:text-forest-700 prose-a:underline prose-a:decoration-forest-300 prose-a:underline-offset-4
                prose-strong:text-forest-900 prose-strong:font-medium">
      <p>
        Le <strong>coffret personnalisé La Brasserie des Plantes</strong> est
        un cadeau composé à la carte : vous choisissez <strong>trois bouteilles
        empilables au format 20 cl</strong> parmi notre gamme de 18 références.
        Les contenants sont conçus pour s'emboîter à la verticale — leur
        empilement <em>"Chute &amp; rebond"</em> tient au design des bouchons
        et des bases. Pas de boîte cadeau standard : la pile <em>est</em> le
        cadeau.
      </p>
      <h2>Pour qui, pour quoi ?</h2>
      <p>
        Idéal pour <strong>découvrir trois recettes différentes sans
        s'engager sur des grands formats</strong>, pour offrir à un amateur
        curieux qui n'a jamais goûté nos liqueurs, ou pour composer une
        dégustation à plusieurs. Trois familles à explorer librement :
        digestifs amers (<a href="/boutique/cerf-gent">Cerf'Gent</a>,
        <a href="/boutique/alchimie-vegetale">L'Alchimie Végétale</a>),
        liqueurs herbacées (<a href="/boutique/herbe-des-druides">L'Herbe des
        Druides</a>, Le Gorgeon des Machurés) et apéritifs floraux ou fruités
        (Le Nectar d'Ostara, La Flèche Ardente, Le Zéleste).
      </p>
      <h2>Comment ça marche</h2>
      <p>
        Cliquez sur trois bouteilles dans la grille ci-dessus : elles
        viennent se poser tour à tour dans la pile à gauche, avec un effet
        d'animation. Vous pouvez retirer une bouteille en cliquant dessus
        dans la pile, ou repartir d'un trio suggéré en un clic. Une fois
        votre composition validée, ajoutez-la au panier — chaque bouteille
        20 cl reste indépendante côté livraison et facturation
        (<strong>livraison offerte dès 65 € d'achat</strong> en France
        métropolitaine, Belgique, Suisse, Luxembourg). Possibilité d'ajouter
        un mot personnalisé sur la commande.
      </p>
    </div>
  </section>
</Layout>
