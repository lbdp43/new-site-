{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(self \"https://js.stripe.com\" \"https://hooks.stripe.com\")"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.stripe.com https://*.stripe.network https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; media-src 'self' blob: https://*.labrasseriedesplantes.fr; connect-src 'self' https://*.labrasseriedesplantes.fr https://*.stripe.com https://*.stripe.network https://maps.googleapis.com; frame-src 'self' https://*.stripe.com https://*.stripe.network https://challenges.cloudflare.com; object-src 'self'; base-uri 'self'; form-action 'self' https://*.stripe.com; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/admin/:path*",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; img-src 'self' data: https: blob:; font-src 'self' data: https://unpkg.com https://cdn.jsdelivr.net; connect-src 'self' https://api.github.com https://auth.sveltia.app https://unpkg.com https://cdn.jsdelivr.net https://raw.githubusercontent.com https://*.githubusercontent.com; frame-src 'self' https://github.com; form-action 'self' https://github.com https://auth.sveltia.app; object-src 'none'; base-uri 'self'"
        }
      ]
    },
    {
      "source": "/images/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/videos/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "test.labrasseriedesplantes.fr"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/shop/lalchimie-vegetale/:path*",
      "destination": "/boutique/alchimie-vegetale",
      "permanent": true
    },
    {
      "source": "/shop/lalchimie-vegetale-cuvee-michel/:path*",
      "destination": "/boutique/alchimie-cuvee-michel",
      "permanent": true
    },
